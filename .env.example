# Copy this file to .env.local and fill in real values (never commit .env or .env.local).
# See config/jwt/README.md for generating JWT PEM files locally.

# Database Configuration
DATABASE_URL="mysql://user:password@127.0.0.1:3306/brewery_db?serverVersion=8.0"

# JWT Configuration (Lexik bundle — PEM paths for local dev)
JWT_SECRET_KEY="%kernel.project_dir%/config/jwt/private.pem"
JWT_PUBLIC_KEY="%kernel.project_dir%/config/jwt/public.pem"
JWT_PASSPHRASE=""

# Google OAuth (Firebase project brewery-f7ace — use the Web client, NOT Android client)
# Find in Google Cloud Console → brewery-f7ace → Credentials → Web client
# Or in android/app/google-services.json oauth_client with client_type 3
GOOGLE_CLIENT_ID="673892684199-evepoqt3sjv3bjl1gpmaemc5mcrn6ueb.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-web-client-secret-from-google-console"

# Symfony browser login (/connect/google) — same Web client as above
OAUTH_GOOGLE_CLIENT_ID="673892684199-evepoqt3sjv3bjl1gpmaemc5mcrn6ueb.apps.googleusercontent.com"
OAUTH_GOOGLE_CLIENT_SECRET="your-web-client-secret-from-google-console"

# App Environment
APP_ENV=prod
APP_SECRET="your_app_secret"
APP_URL=https://webdev2-staging.up.railway.app

# CORS Configuration
# For React Native development, use * to allow all origins
# For production, specify your frontend domain
CORS_ALLOW_ORIGIN="*"

# Email Configuration (for verification emails)
MAILER_DSN=smtp://user:password@smtp.example.com:587

# Brevo (contact form API)
BREVO_API_KEY="your-brevo-api-key"

# Mercure Configuration (for WebSocket/real-time)
MERCURE_URL=https://webdev2-staging.up.railway.app/.well-known/mercure
MERCURE_PUBLIC_URL=https://webdev2-staging.up.railway.app/.well-known/mercure
MERCURE_JWT_SECRET="!ChangeMercureSecretToSecureRandomString123!"

# Trusted Proxies (required by framework.yaml)
TRUSTED_PROXIES="127.0.0.1,REMOTE_ADDR"
