# Database Configuration
DATABASE_URL="mysql://user:password@127.0.0.1:3306/brewery_db?serverVersion=8.0"

# JWT Configuration
JWT_SECRET_KEY="%kernel.project_dir%/config/jwt/private.pem"
JWT_PUBLIC_KEY="%kernel.project_dir%/config/jwt/public.pem"
JWT_PASSPHRASE="your_jwt_passphrase"

# Google OAuth
GOOGLE_CLIENT_ID="your_google_client_id"
GOOGLE_CLIENT_SECRET="your_google_client_secret"

# App Environment
APP_ENV=prod
APP_SECRET="your_app_secret"
APP_URL=https://your-app.railway.app

# CORS Configuration
CORS_ALLOW_ORIGIN="https://your-frontend-domain.com"

# Email Configuration (for verification emails)
MAILER_DSN=smtp://user:password@smtp.example.com:587

# Mercure Configuration (for WebSocket/real-time)
MERCURE_URL=http://127.0.0.1:3000/.well-known/mercure
MERCURE_PUBLIC_URL=http://127.0.0.1:3000/.well-known/mercure
MERCURE_JWT_SECRET="!ChangeThisMercureSecret!"
