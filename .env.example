# Database Configuration
DATABASE_URL="mysql://user:password@127.0.0.1:3306/brewery_db?serverVersion=8.0"

# JWT Configuration
# For Railway deployment, use the actual key content as environment variables
# For local development, use file paths
JWT_SECRET_KEY="%kernel.project_dir%/config/jwt/private.pem"
JWT_PUBLIC_KEY="%kernel.project_dir%/config/jwt/public.pem"
JWT_PASSPHRASE=""

# Google OAuth
# React Native app uses this Client ID for /api/auth/google endpoint
GOOGLE_CLIENT_ID="673892684199-evepoqt3sjv3bjl1gpmaemc5mcrn6ueb.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="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"

# Web OAuth flow (optional - for web-based Google login)
OAUTH_GOOGLE_CLIENT_ID="317197442052-0vlbmcdmgl429o8hvsi5i1hlphujl23a.apps.googleusercontent.com"
OAUTH_GOOGLE_CLIENT_SECRET="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"

# App Environment
APP_ENV=prod
APP_SECRET="your_app_secret"
APP_URL=https://webdev2-staging.up.railway.app

# CORS Configuration
# For React Native development, use * to allow all origins
# For production, specify your frontend domain
CORS_ALLOW_ORIGIN="*"

# Email Configuration (for verification emails)
MAILER_DSN=smtp://user:password@smtp.example.com:587

# Mercure Configuration (for WebSocket/real-time)
MERCURE_URL=http://127.0.0.1:3000/.well-known/mercure
MERCURE_PUBLIC_URL=http://127.0.0.1:3000/.well-known/mercure
MERCURE_JWT_SECRET="!ChangeThisMercureSecret!"

# Trusted Proxies (required by framework.yaml)
TRUSTED_PROXIES="127.0.0.1,REMOTE_ADDR"
