{% extends 'base.html.twig' %}

{% block title %}About Us - Samaco Brewery{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
            line-height: 1.6;
            color: #e2e8f0;
            overflow-x: hidden;
            background: #0a0a0a;
        }

        .container {
            max-width: 1400px;
            margin: 0 auto;
            padding: 0 32px;
        }

        /* Typography */
        h1, h2, h3, h4, h5, h6 {
            font-weight: 700;
            line-height: 1.2;
        }

        .section-title {
            font-size: 2.8rem;
            text-align: center;
            margin-bottom: 1rem;
            background: linear-gradient(135deg, #FFD700 0%, #FFC107 100%);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
            letter-spacing: -0.01em;
        }

        .section-subtitle {
            text-align: center;
            color: #9ca3af;
            font-size: 1.2rem;
            max-width: 700px;
            margin: 0 auto 3.5rem;
        }

        /* Buttons */
        .btn-primary {
            display: inline-block;
            background: linear-gradient(135deg, #FFD700 0%, #FFC107 100%);
            color: #000;
            padding: 12px 28px;
            border-radius: 50px;
            text-decoration: none;
            font-weight: 600;
            transition: all 0.3s ease;
            border: none;
            cursor: pointer;
        }

        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(255, 215, 0, 0.3);
        }

        .btn-secondary {
            display: inline-block;
            background: transparent;
            color: #FFD700;
            padding: 12px 28px;
            border-radius: 50px;
            text-decoration: none;
            font-weight: 600;
            border: 2px solid #FFD700;
            transition: all 0.3s ease;
        }

        .btn-secondary:hover {
            background: rgba(255, 215, 0, 0.1);
            transform: translateY(-2px);
        }

        /* Navigation */
        .navbar {
            background: linear-gradient(180deg, #000000 0%, #0a0a0a 100%);
            border-bottom: 2px solid #FFD700;
            position: fixed;
            width: 100%;
            top: 0;
            z-index: 1000;
        }

        .navbar .container {
            display: flex;
            justify-content: space-between;
            align-items: center;
            height: 80px;
        }

        .logo {
            display: flex;
            align-items: center;
            gap: 12px;
            text-decoration: none;
        }

        .logo img {
            height: 40px;
            width: auto;
        }

        .logo span {
            font-size: 1.25rem;
            font-weight: 700;
            background: linear-gradient(135deg, #FFD700 0%, #FFC107 100%);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
        }

        .nav-links {
            display: flex;
            gap: 32px;
            align-items: center;
        }

        .nav-links a {
            text-decoration: none;
            color: #e2e8f0;
            font-weight: 500;
            transition: color 0.3s;
        }

        .nav-links a:hover,
        .nav-links a.active {
            color: #FFD700;
        }

        .nav-buttons {
            display: flex;
            gap: 12px;
        }

        /* Mobile Menu */
        .mobile-menu-btn {
            display: none;
            background: none;
            border: none;
            cursor: pointer;
            padding: 8px;
            color: #FFD700;
            font-size: 28px;
        }

        .mobile-menu {
            display: none;
            position: fixed;
            top: 80px;
            left: 0;
            right: 0;
            background: #000000;
            border-bottom: 2px solid #FFD700;
            padding: 1rem;
            z-index: 999;
        }

        .mobile-menu.active {
            display: block;
        }

        .mobile-menu a {
            display: block;
            padding: 12px 16px;
            color: #e2e8f0;
            text-decoration: none;
            font-weight: 500;
            transition: color 0.3s;
        }

        .mobile-menu a:hover {
            color: #FFD700;
        }

        /* Hero Section */
        .about-hero {
            padding: 400px 0 150px;
            min-height: 60vh;
            display: flex;
            align-items: center;
            text-align: center;
            position: relative;
            background-size: cover;
            background-position: center;
            background-repeat: no-repeat;
        }

        .hero-overlay {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: linear-gradient(135deg, rgba(0,0,0,0.0) 0%, rgba(0,0,0,0.0) 100%);
            z-index: 1;
        }

        .about-hero .container {
            position: relative;
            z-index: 2;
        }

        .about-hero-bg {
            background-image: url('../images/brewery-interior.jpg');
        }

        .hero-content {
            position: relative;
            z-index: 2;
        }

        .about-hero::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: url('data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100" opacity="0.05"><path fill="%23FFD700" d="M50,10 L60,30 L80,35 L65,50 L70,70 L50,60 L30,70 L35,50 L20,35 L40,30 Z"/></svg>') repeat;
            opacity: 0.1;
            pointer-events: none;
        }

        .about-hero h1 {
            font-size: 4rem;
            margin-bottom: 1.2rem;
            background: linear-gradient(135deg, #FFD700 0%, #FFC107 100%);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
        }

        .about-hero p {
            font-size: 1.25rem;
            color: #9ca3af;
            max-width: 700px;
            margin: 0 auto;
            line-height: 1.8;
        }

        /* Story Section */
        .story-section {
            padding: 100px 0;
            background: #000000;
        }

        .story-content {
            max-width: 900px;
            margin: 0 auto;
            text-align: center;
            font-size: 1.2rem;
            line-height: 1.8;
            color: #9ca3af;
        }

        /* Values Section */
        .values-section {
            padding: 100px 0;
            background: linear-gradient(180deg, #0a0a0a 0%, #000000 100%);
        }

        .values-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 48px;
            margin-top: 60px;
        }

        .value-card {
            background: linear-gradient(135deg, #0a0a0a 0%, #111111 100%);
            border: 1px solid rgba(255, 215, 0, 0.1);
            border-radius: 28px;
            padding: 2.5rem;
            text-align: center;
            transition: all 0.3s;
        }

        .value-card:hover {
            border-color: rgba(255, 215, 0, 0.3);
            transform: translateY(-6px);
        }

        .value-icon {
            width: 80px;
            height: 80px;
            background: linear-gradient(135deg, rgba(255, 215, 0, 0.1) 0%, rgba(255, 215, 0, 0.05) 100%);
            border-radius: 28px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 1.8rem;
            font-size: 2.5rem;
            border: 1px solid rgba(255, 215, 0, 0.2);
        }

        .value-card h3 {
            font-size: 1.5rem;
            margin-bottom: 1rem;
            color: #FFD700;
        }

        .value-card p {
            color: #9ca3af;
            font-size: 1rem;
            line-height: 1.6;
        }

        /* Team Section */
        .team-section {
            padding: 100px 0;
            background: #000000;
        }

        .team-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 48px;
            margin-top: 60px;
        }

        .team-card {
            background: linear-gradient(135deg, #0a0a0a 0%, #111111 100%);
            border-radius: 28px;
            overflow: hidden;
            transition: all 0.4s ease;
            text-align: center;
            border: 1px solid rgba(255, 215, 0, 0.1);
        }

        .team-card:hover {
            transform: translateY(-10px);
            border-color: rgba(255, 215, 0, 0.3);
            box-shadow: 0 25px 55px rgba(0, 0, 0, 0.5);
        }

        .team-photo {
            height: 280px;
            width: 100%;
            object-fit: cover;
            background: linear-gradient(135deg, #1a1a1a 0%, #000000 100%);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 5rem;
            border-bottom: 1px solid rgba(255, 215, 0, 0.2);
        }

        /* Make sure images cover properly */
        .team-photo img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .team-info {
            padding: 2rem;
        }

        .team-name {
            font-size: 1.6rem;
            font-weight: 700;
            color: #FFD700;
            margin-bottom: 0.3rem;
        }

        .team-role {
            color: #FFD700;
            font-weight: 600;
            font-size: 1rem;
            margin-bottom: 1rem;
            letter-spacing: 0.5px;
            opacity: 0.8;
        }

        .team-bio {
            color: #9ca3af;
            font-size: 0.95rem;
            line-height: 1.6;
        }

        /* Milestones Section */
        .milestones-section {
            padding: 100px 0;
            background: linear-gradient(180deg, #0a0a0a 0%, #000000 100%);
        }

        .milestones-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 40px;
            margin-top: 60px;
        }

        .milestone-card {
            text-align: center;
            padding: 2rem;
            background: linear-gradient(135deg, #0a0a0a 0%, #111111 100%);
            border-radius: 24px;
            transition: all 0.3s;
            border: 1px solid rgba(255, 215, 0, 0.1);
        }

        .milestone-card:hover {
            transform: translateY(-6px);
            border-color: rgba(255, 215, 0, 0.3);
        }

        .milestone-year {
            font-size: 2.2rem;
            font-weight: 800;
            background: linear-gradient(135deg, #FFD700 0%, #FFC107 100%);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
            margin-bottom: 0.75rem;
        }

        .milestone-title {
            font-weight: 700;
            font-size: 1.1rem;
            margin-bottom: 0.5rem;
            color: #FFD700;
        }

        .milestone-desc {
            font-size: 0.9rem;
            color: #9ca3af;
        }

        /* Section Separators - Yellow Lines */
        .story-section, .values-section, .team-section, .milestones-section {
            border-bottom: 2px solid rgba(255, 215, 0, 0.25);
            position: relative;
        }

        /* CTA Section */
        .cta-section {
            padding: 100px 0;
            background: linear-gradient(135deg, #FFD700 0%, #FFC107 100%);
            text-align: center;
        }

        .cta-section h2 {
            font-size: 2.8rem;
            margin-bottom: 1rem;
            color: #000;
        }

        .cta-section p {
            font-size: 1.2rem;
            margin-bottom: 2rem;
            color: #1a1a1a;
            opacity: 0.95;
        }

        .btn-white {
            display: inline-block;
            background: #000;
            color: #FFD700;
            padding: 14px 36px;
            border-radius: 50px;
            text-decoration: none;
            font-weight: 700;
            font-size: 1rem;
            transition: all 0.3s;
        }

        .btn-white:hover {
            transform: translateY(-3px);
            box-shadow: 0 12px 30px rgba(0, 0, 0, 0.3);
        }

        /* Footer */
        .footer {
            background: #000000;
            color: #9ca3af;
            padding: 70px 0 35px;
            border-top: 2px solid #FFD700;
        }

        .footer-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 55px;
            margin-bottom: 55px;
        }

        .footer-logo {
            display: flex;
            align-items: center;
            gap: 12px;
            margin-bottom: 20px;
            text-decoration: none;
        }

        .footer-logo span {
            font-size: 1.125rem;
            font-weight: 700;
            background: linear-gradient(135deg, #FFD700 0%, #FFC107 100%);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
        }

        .footer h4 {
            color: #FFD700;
            margin-bottom: 24px;
            font-size: 1.2rem;
        }

        .footer-links {
            list-style: none;
        }

        .footer-links li {
            margin-bottom: 14px;
        }

        .footer-links a {
            color: #9ca3af;
            text-decoration: none;
            transition: color 0.3s;
        }

        .footer-links a:hover {
            color: #FFD700;
        }

        .footer-bottom {
            text-align: center;
            padding-top: 35px;
            border-top: 1px solid rgba(255, 215, 0, 0.2);
            font-size: 0.9rem;
        }

        /* Responsive Design */
        @media (max-width: 1024px) {
            .values-grid,
            .team-grid,
            .milestones-grid {
                grid-template-columns: repeat(2, 1fr);
                gap: 32px;
            }
            .container {
                padding: 0 24px;
            }
        }

        @media (max-width: 768px) {
            .values-grid,
            .team-grid,
            .milestones-grid,
            .footer-grid {
                grid-template-columns: 1fr;
                gap: 32px;
            }
            
            .section-title {
                font-size: 2.2rem;
            }
            
            .about-hero h1 {
                font-size: 2.8rem;
            }
            
            .about-hero {
                padding: 140px 0 80px;
            }
            
            .nav-links {
                display: none;
            }
            
            .mobile-menu-btn {
                display: block;
            }
            
            .cta-section h2 {
                font-size: 2rem;
            }

            .team-name {
                font-size: 1.4rem;
            }
        }

        @media (max-width: 480px) {
            .container {
                padding: 0 20px;
            }
            
            .about-hero h1 {
                font-size: 2.2rem;
            }

            .section-title {
                font-size: 1.9rem;
            }
            
            .team-photo {
                height: 220px;
                font-size: 3.5rem;
            }
        }
    </style>
{% endblock %}

{% block body %}
<!-- Navigation -->
<nav class="navbar">
    <div class="container">
        <a href="{{ path('app_landing') }}" class="logo">
            <img src="{{ asset('images/logo.png') }}" alt="Samaco Brewery">
            <span>Samaco Brewery</span>
        </a>
        
        <div class="nav-links">
            <a href="{{ path('app_landing') }}">Home</a>
            <a href="{{ path('app_about') }}" class="active">About</a>
            <a href="{{ path('app_contact') }}">Contact</a>
        </div>
        
        <div class="nav-buttons">
            <a href="{{ path('app_login') }}" class="btn-secondary" style="padding: 8px 20px;">Login</a>
            <a href="{{ path('app_register') }}" class="btn-primary" style="padding: 8px 20px;">Get Started</a>
        </div>
        
        <button class="mobile-menu-btn" id="mobileMenuBtn">☰</button>
    </div>
</nav>

<!-- Mobile Menu -->
<div class="mobile-menu" id="mobileMenu">
    <a href="{{ path('app_landing') }}">Home</a>
    <a href="{{ path('app_about') }}" class="active">About</a>
    <a href="{{ path('app_contact') }}">Contact</a>
</div>

<!-- Hero Section -->
<section class="about-hero about-hero-bg">
    <div class="hero-overlay"></div>
    <div class="container hero-content">
        <h1>About Samaco Brewery</h1>
        <p>Crafting exceptional Filipino beers with passion, tradition, and innovation since 2020.</p>
    </div>
</section>

<!-- Story Section -->
<section class="story-section">
    <div class="container">
        <h2 class="section-title">Our Story</h2>
        <div class="story-content">
            <p>Founded in 2020 in the heart of the Philippines, Samaco Brewery brings together centuries-old brewing traditions with modern craft beer innovation. We use locally sourced ingredients and sustainable practices to create beers that celebrate Filipino culture and flavors.</p>
            <p style="margin-top: 1.8rem;">What started as a small passion project has grown into one of the most respected craft breweries in the country. Every batch we brew is a testament to our commitment to quality, authenticity, and the rich brewing heritage of the Philippines.</p>
        </div>
    </div>
</section>

<!-- Values Section -->
<section class="values-section">
    <div class="container">
        <h2 class="section-title">Our Values</h2>
        <p class="section-subtitle">The principles that guide everything we do</p>
        
        <div class="values-grid">
            <div class="value-card">
                <div class="value-icon">🌱</div>
                <h3>Sustainability</h3>
                <p>Committed to eco-friendly brewing practices and local ingredient sourcing.</p>
            </div>
            
            <div class="value-card">
                <div class="value-icon">⭐</div>
                <h3>Quality</h3>
                <p>Every batch is crafted with precision and passion for the perfect taste.</p>
            </div>
            
            <div class="value-card">
                <div class="value-icon">👥</div>
                <h3>Community</h3>
                <p>Building connections through great beer and shared experiences.</p>
            </div>
        </div>
    </div>
</section>

<!-- Team Section -->
<section class="team-section">
    <div class="container">
        <h2 class="section-title">Meet the Team</h2>
        <p class="section-subtitle">The passionate people behind your favorite brews</p>
        
        <div class="team-grid">
            <!-- Team Member 1: Juan Dela Cruz -->
            <div class="team-card">
                <img src="{{ asset('images/team/jhon.jpg') }}" alt="Juan Dela Cruz" class="team-photo" onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';">
                <div class="team-photo" style="display: none;">👨‍🍺</div>
                <div class="team-info">
                    <h3 class="team-name">Juan Dela Cruz</h3>
                    <p class="team-role">Master Brewer</p>
                    <p class="team-bio">20+ years of brewing experience, certified cicerone, and craft beer pioneer in the Philippines.</p>
                </div>
            </div>
            
            <!-- Team Member 2: Maria Santos -->
            <div class="team-card">
                <img src="{{ asset('images/team/maria.jpg') }}" alt="Maria Santos" class="team-photo" onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';">
                <div class="team-photo" style="display: none;">🔬🧴</div>
                <div class="team-info">
                    <h3 class="team-name">Maria Santos</h3>
                    <p class="team-role">Quality Control Manager</p>
                    <p class="team-bio">Food scientist ensuring every batch meets our highest quality standards.</p>
                </div>
            </div>
            
            <!-- Team Member 3: Roberto Lim -->
            <div class="team-card">
                <img src="{{ asset('images/team/roberto.jpg') }}" alt="Roberto Lim" class="team-photo" onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';">
                <div class="team-photo" style="display: none;">♻️📊</div>
                <div class="team-info">
                    <h3 class="team-name">Roberto Lim</h3>
                    <p class="team-role">Operations Director</p>
                    <p class="team-bio">Leading brewery operations with a focus on sustainability and innovation.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Milestones Section -->
<section class="milestones-section">
    <div class="container">
        <h2 class="section-title">Our Journey</h2>
        <p class="section-subtitle">Key milestones in our brewing history</p>
        
        <div class="milestones-grid">
            <div class="milestone-card">
                <div class="milestone-year">2020</div>
                <div class="milestone-title">Founded</div>
                <div class="milestone-desc">Samaco Brewery established in Manila</div>
            </div>
            
            <div class="milestone-card">
                <div class="milestone-year">2021</div>
                <div class="milestone-title">First Award</div>
                <div class="milestone-desc">Gold medal at Asian Beer Championship</div>
            </div>
            
            <div class="milestone-card">
                <div class="milestone-year">2023</div>
                <div class="milestone-title">Expansion</div>
                <div class="milestone-desc">Opened second production facility</div>
            </div>
            
            <div class="milestone-card">
                <div class="milestone-year">2025</div>
                <div class="milestone-title">10,000+ Customers</div>
                <div class="milestone-desc">Serving beer lovers nationwide</div>
            </div>
        </div>
    </div>
</section>

<!-- CTA Section -->
<section class="cta-section">
    <div class="container">
        <h2>Join Our Brewery Family</h2>
        <p>Experience the best of Filipino craft beer. Visit us or order online!</p>
        <a href="{{ path('app_contact') }}" class="btn-white">Get in Touch</a>
    </div>
</section>

<!-- Footer -->
<footer class="footer">
    <div class="container">
        <div class="footer-grid">
            <div>
                <a href="{{ path('app_landing') }}" class="footer-logo">
                    <img src="{{ asset('images/logo.png') }}" alt="Samaco Brewery" style="height: 32px;">
                    <span>Samaco Brewery</span>
                </a>
                <p style="margin-top: 20px;">Crafting excellence in every pour since 2020.</p>
            </div>
            
            <div>
                <h4>Quick Links</h4>
                <ul class="footer-links">
                    <li><a href="{{ path('app_landing') }}">Home</a></li>
                    <li><a href="{{ path('app_about') }}">About</a></li>
                    <li><a href="{{ path('app_contact') }}">Contact</a></li>
                </ul>
            </div>
            
            <div>
                <h4>Account</h4>
                <ul class="footer-links">
                    <li><a href="{{ path('app_login') }}">Login</a></li>
                    <li><a href="{{ path('app_register') }}">Register</a></li>
                </ul>
            </div>
            
            <div>
                <h4>Contact</h4>
                <ul class="footer-links">
                    <li>123 Brewery Street</li>
                    <li>Manila, Philippines</li>
                    <li>info@samacobrewery.com</li>
                    <li>+63 123 456 7890</li>
                </ul>
            </div>
        </div>
        
        <div class="footer-bottom">
            <p>&copy; 2026 Samaco Brewery. All rights reserved.</p>
        </div>
    </div>
</footer>

<script>
    const mobileMenuBtn = document.getElementById('mobileMenuBtn');
    const mobileMenu = document.getElementById('mobileMenu');
    
    if (mobileMenuBtn && mobileMenu) {
        mobileMenuBtn.addEventListener('click', function() {
            mobileMenu.classList.toggle('active');
        });
        
        const mobileLinks = mobileMenu.querySelectorAll('a');
        mobileLinks.forEach(link => {
            link.addEventListener('click', function() {
                mobileMenu.classList.remove('active');
            });
        });
        
        window.addEventListener('resize', function() {
            if (window.innerWidth >= 768) {
                mobileMenu.classList.remove('active');
            }
        });
    }
</script>
{% endblock %}