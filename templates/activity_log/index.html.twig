{% extends 'layout.html.twig' %}

{% block title %}Activity Logs - Samaco Brewery{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <!-- DataTables CSS -->
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css">

    <style>
        .dataTables_paginate .paginate_button {
            display: inline-block !important;
            margin: 0 2px !important;
        }

        .dataTables_paginate {
            display: flex !important;
            flex-wrap: wrap !important;
            justify-content: flex-end !important;
            align-items: center !important;
            gap: 4px !important;
        }

        .dataTables_info {
            display: flex !important;
            align-items: center !important;
        }
    </style>
    
{% endblock %}

{% block dashboard_content %}
<div class="container mx-auto px-4 py-8">
    <!-- Page Header with Delete Button -->
    <div class="bg-gradient-to-r from-black to-gray-900 rounded-lg border-l-4 border-yellow-500 p-6 mb-6 shadow-lg">
        <div class="flex justify-between items-center">
            <div>
                <h1 class="text-3xl font-bold text-yellow-500 mb-1">📊 Activity Logs</h1>
                <p class="text-gray-400">Audit trail of all system activities and user actions</p>
            </div>
            <button id="deleteAllLogs" class="bg-red-600 hover:bg-red-700 text-white px-4 py-2 rounded-lg transition duration-200">
                🗑️ Delete All Logs
            </button>
        </div>
    </div>

    <!-- Advanced Filters -->
    <div class="bg-gray-800/80 rounded-lg border border-yellow-500/15 p-5 mb-6 shadow-lg">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
            <div>
                <label for="searchUser" class="block text-yellow-500 text-sm font-semibold mb-2">User Email</label>
                <input type="text" id="searchUser" class="w-full px-3 py-2 bg-gray-700 border border-yellow-500/30 rounded-md text-white focus:outline-none focus:ring-2 focus:ring-yellow-500" placeholder="Search by user email...">
            </div>

            <div>
                <label for="filterAction" class="block text-yellow-500 text-sm font-semibold mb-2">Action Type</label>
                <select id="filterAction" class="w-full px-3 py-2 bg-gray-700 border border-yellow-500/30 rounded-md text-white focus:outline-none focus:ring-2 focus:ring-yellow-500">
                    <option value="">All Actions</option>
                    <option value="LOGIN">Login</option>
                    <option value="LOGOUT">Logout</option>
                    <option value="CREATE_">Create</option>
                    <option value="UPDATE_">Update</option>
                    <option value="DELETE_">Delete</option>
                    <option value="STOCK_ADD">Stock Add</option>
                    <option value="STOCK_REMOVE">Stock Remove</option>
                    <option value="STOCK_SET">Stock Set</option>
                </select>
            </div>

            <div>
                <label for="filterTarget" class="block text-yellow-500 text-sm font-semibold mb-2">Target Entity</label>
                <select id="filterTarget" class="w-full px-3 py-2 bg-gray-700 border border-yellow-500/30 rounded-md text-white focus:outline-none focus:ring-2 focus:ring-yellow-500">
                    <option value="">All Entities</option>
                    <option value="User">User</option>
                    <option value="Product">Product</option>
                    <option value="Category">Category</option>
                    <option value="Customer">Customer</option>
                    <option value="Order">Order</option>
                </select>
            </div>

            <div>
                <label for="filterRole" class="block text-yellow-500 text-sm font-semibold mb-2">User Role</label>
                <select id="filterRole" class="w-full px-3 py-2 bg-gray-700 border border-yellow-500/30 rounded-md text-white focus:outline-none focus:ring-2 focus:ring-yellow-500">
                    <option value="">All Roles</option>
                    <option value="ADMIN">Admin</option>
                    <option value="STAFF">Staff</option>
                    <option value="USER">User</option>
                </select>
            </div>

            <div>
                <label for="filterDate" class="block text-yellow-500 text-sm font-semibold mb-2">Date</label>
                <input type="date" id="filterDate" class="w-full px-3 py-2 bg-gray-700 border border-yellow-500/30 rounded-md text-white focus:outline-none focus:ring-2 focus:ring-yellow-500">
            </div>
        </div>

        <div class="mt-4">
            <button id="resetFilters" class="px-5 py-2 bg-gray-700 text-gray-400 border border-gray-500 rounded-md font-semibold hover:bg-gray-600 hover:text-white transition-all duration-200">
                Reset All Filters
            </button>
        </div>
    </div>

    <!-- Activity Logs Table -->
    <div class="bg-gray-800/80 rounded-lg shadow-lg p-6">
        {% if activity_logs is empty %}
            <div class="text-center py-12">
                <div class="text-5xl mb-3 opacity-60">📝</div>
                <h3 class="text-yellow-500 text-xl mb-2">No Activity Logs Found</h3>
                <p class="text-yellow-500/70">System activities will appear here as they occur</p>
            </div>
        {% else %}
            <table id="activityTable" class="display w-full">
                <thead>
                    <tr class="bg-yellow-500/15">
                        <th class="px-4 py-3 text-left text-xs font-semibold text-yellow-500 uppercase tracking-wider">ID</th>
                        <th class="px-4 py-3 text-left text-xs font-semibold text-yellow-500 uppercase tracking-wider">User</th>
                        <th class="px-4 py-3 text-left text-xs font-semibold text-yellow-500 uppercase tracking-wider">Role</th>
                        <th class="px-4 py-3 text-left text-xs font-semibold text-yellow-500 uppercase tracking-wider">Action</th>
                        <th class="px-4 py-3 text-left text-xs font-semibold text-yellow-500 uppercase tracking-wider">Target</th>
                        <th class="px-4 py-3 text-left text-xs font-semibold text-yellow-500 uppercase tracking-wider">Target ID</th>
                        <th class="px-4 py-3 text-left text-xs font-semibold text-yellow-500 uppercase tracking-wider">Details</th>
                        <th class="px-4 py-3 text-left text-xs font-semibold text-yellow-500 uppercase tracking-wider">Date/Time</th>
                    </tr>
                </thead>
                <tbody>
                {% for log in activity_logs %}
                    {% set userRole = log.userRole|default('') %}
                    {% if userRole == '' and log.user is defined %}
                        {% if 'ROLE_ADMIN' in log.user.roles %}
                            {% set userRole = 'ROLE_ADMIN' %}
                        {% elseif 'ROLE_STAFF' in log.user.roles %}
                            {% set userRole = 'ROLE_STAFF' %}
                        {% else %}
                            {% set userRole = 'ROLE_USER' %}
                        {% endif %}
                    {% endif %}

                    {% set normalizedRole = userRole|replace({'ROLE_': ''})|upper %}

                    <tr class="border-b border-gray-700 hover:bg-yellow-500/10 transition-colors">
                        <td class="px-4 py-3 text-sm text-white">{{ log.id }}</td>
                        <td class="px-4 py-3 text-sm text-white">{{ log.user.email }}</td>
                        <td class="px-4 py-3">
                            {% set roleClasses = 'inline-block px-3 py-1 rounded-full text-xs font-semibold border' %}
                            {% if normalizedRole == 'ADMIN' %}
                                <span class="{{ roleClasses }} bg-red-900/30 text-red-300 border-red-500/50">ADMIN</span>
                            {% elseif normalizedRole == 'STAFF' %}
                                <span class="{{ roleClasses }} bg-yellow-900/30 text-yellow-300 border-yellow-500/50">STAFF</span>
                            {% else %}
                                <span class="{{ roleClasses }} bg-gray-700 text-gray-300 border-gray-500/50">USER</span>
                            {% endif %}
                        </td>
                        <td class="px-4 py-3">
                            {% set actionClasses = 'inline-block px-3 py-1 rounded-full text-xs font-semibold border' %}
                            {% if log.action starts with 'LOGIN' %}
                                <span class="{{ actionClasses }} bg-green-900/30 text-green-300 border-green-500/50">LOGIN</span>
                            {% elseif log.action starts with 'LOGOUT' %}
                                <span class="{{ actionClasses }} bg-gray-700 text-gray-300 border-gray-500/50">LOGOUT</span>
                            {% elseif log.action starts with 'CREATE' %}
                                <span class="{{ actionClasses }} bg-blue-900/30 text-blue-300 border-blue-500/50">CREATE</span>
                            {% elseif log.action starts with 'UPDATE' %}
                                <span class="{{ actionClasses }} bg-yellow-900/30 text-yellow-300 border-yellow-500/50">UPDATE</span>
                            {% elseif log.action starts with 'DELETE' %}
                                <span class="{{ actionClasses }} bg-red-900/30 text-red-300 border-red-500/50">DELETE</span>
                            {% elseif log.action starts with 'STOCK' %}
                                <span class="{{ actionClasses }} bg-purple-900/30 text-purple-300 border-purple-500/50">{{ log.action|replace({'_': ' '}) }}</span>
                            {% else %}
                                <span class="{{ actionClasses }} bg-purple-900/30 text-purple-300 border-purple-500/50">{{ log.action|replace({'_': ' '}) }}</span>
                            {% endif %}
                        </td>
                        <td class="px-4 py-3">
                            {% set targetClasses = 'inline-block px-3 py-1 rounded-full text-xs font-semibold border' %}
                            {% if log.targetEntity == 'User' %}
                                <span class="{{ targetClasses }} bg-pink-900/30 text-pink-300 border-pink-500/50">User</span>
                            {% elseif log.targetEntity == 'Product' %}
                                <span class="{{ targetClasses }} bg-teal-900/30 text-teal-300 border-teal-500/50">Product</span>
                            {% elseif log.targetEntity == 'Category' %}
                                <span class="{{ targetClasses }} bg-orange-900/30 text-orange-300 border-orange-500/50">Category</span>
                            {% elseif log.targetEntity == 'Customer' %}
                                <span class="{{ targetClasses }} bg-indigo-900/30 text-indigo-300 border-indigo-500/50">Customer</span>
                            {% elseif log.targetEntity == 'Order' %}
                                <span class="{{ targetClasses }} bg-blue-900/30 text-blue-300 border-blue-500/50">Order</span>
                            {% else %}
                                <span class="{{ targetClasses }} bg-gray-700 text-gray-300 border-gray-500/50">{{ log.targetEntity }}</span>
                            {% endif %}
                        </td>
                        <td class="px-4 py-3 text-sm text-gray-400">{{ log.targetId ?? '-' }}</td>
                        <td class="px-4 py-3 text-sm text-gray-300">{{ log.details }}</td>
                        <td class="px-4 py-3 text-sm text-gray-400">{{ log.createdAt|date('Y-m-d H:i:s') }}</td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        {% endif %}
    </div>
</div>

<!-- Delete Confirmation Modal -->
<div id="deleteModal" class="fixed inset-0 bg-black bg-opacity-50 hidden items-center justify-center z-50">
    <div class="bg-gray-800 rounded-lg p-6 max-w-md mx-4 border border-yellow-500/30">
        <h3 class="text-xl font-bold text-yellow-500 mb-4">Delete All Activity Logs?</h3>
        <p class="text-gray-300 mb-6">This action cannot be undone. All activity logs will be permanently deleted.</p>
        <div class="flex justify-end gap-3">
            <button id="cancelDelete" class="px-4 py-2 bg-gray-600 text-white rounded-lg hover:bg-gray-700 transition">Cancel</button>
            <button id="confirmDelete" class="px-4 py-2 bg-red-600 text-white rounded-lg hover:bg-red-700 transition">Delete All</button>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}

    <!-- DataTables JS -->
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>

    <script>
    document.addEventListener('DOMContentLoaded', function() {
        if ($('#activityTable').length && !$.fn.DataTable.isDataTable('#activityTable')) {
            window.activityTable = $('#activityTable').DataTable({
                paging: true,
                pageLength: 10,
                lengthMenu: [[10, 25, 50, 100], [10, 25, 50, 100]],
                searching: true,
                ordering: true,
                order: [[0, 'desc']],
                responsive: true,
                autoWidth: false,
                language: {
                    search: "Search:",
                    searchPlaceholder: "Type to search...",
                    lengthMenu: "Show _MENU_ entries",
                    info: "Showing _START_ to _END_ of _TOTAL_ logs",
                    infoEmpty: "Showing 0 to 0 of 0 logs",
                    infoFiltered: "(filtered from _MAX_ total logs)",
                    zeroRecords: "No matching logs found",
                    paginate: {
                        first: "« First",
                        last: "Last »",
                        next: "Next →",
                        previous: "← Previous"
                    }
                },
                dom: '<"flex flex-wrap justify-between items-center mb-4"l<"ml-auto"f>>rt<"flex flex-wrap justify-between items-center mt-4"ip>',
            });

            // Advanced Filters
            $('#searchUser').on('keyup', function() {
                window.activityTable.column(1).search(this.value).draw();
            });

            $('#filterAction').on('change', function() {
                var actionFilter = this.value;
                if (actionFilter) {
                    if (actionFilter.endsWith('_')) {
                        var actionPrefix = actionFilter.replace('_', '');
                        window.activityTable.column(3).search('^' + actionPrefix, true, false).draw();
                    } else {
                        window.activityTable.column(3).search('^' + actionFilter + '$', true, false).draw();
                    }
                } else {
                    window.activityTable.column(3).search('').draw();
                }
            });

            $('#filterTarget').on('change', function() {
                var targetFilter = this.value;
                if (targetFilter) {
                    window.activityTable.column(4).search('^' + targetFilter + '$', true, false).draw();
                } else {
                    window.activityTable.column(4).search('').draw();
                }
            });

            $('#filterRole').on('change', function() {
                var roleFilter = this.value;
                if (roleFilter) {
                    window.activityTable.column(2).search(roleFilter).draw();
                } else {
                    window.activityTable.column(2).search('').draw();
                }
            });

            $('#filterDate').on('change', function() {
                var dateFilter = this.value;
                if (dateFilter) {
                    window.activityTable.column(7).search('^' + dateFilter, true, false).draw();
                } else {
                    window.activityTable.column(7).search('').draw();
                }
            });

            $('#resetFilters').on('click', function() {
                $('#searchUser').val('');
                $('#filterAction').val('');
                $('#filterTarget').val('');
                $('#filterRole').val('');
                $('#filterDate').val('');
                if (window.activityTable) {
                    window.activityTable.search('');
                    window.activityTable.columns().search('');
                    window.activityTable.draw();
                }
            });
        }

        // Delete all logs functionality
        $('#deleteAllLogs').on('click', function() {
            $('#deleteModal').removeClass('hidden').addClass('flex');
        });

        $('#cancelDelete').on('click', function() {
            $('#deleteModal').removeClass('flex').addClass('hidden');
        });

        $('#confirmDelete').on('click', function() {
            $.ajax({
                url: '{{ path("app_activity_log_delete_all") }}',
                method: 'POST',
                headers: {
                    'X-Requested-With': 'XMLHttpRequest'
                },
                success: function(response) {
                    if (response.success) {
                        $('#deleteModal').removeClass('flex').addClass('hidden');
                        location.reload();
                    }
                },
                error: function() {
                    alert('Failed to delete logs. Please try again.');
                    $('#deleteModal').removeClass('flex').addClass('hidden');
                }
            });
        });
    });
    </script>
{% endblock %}