{% extends 'layout.html.twig' %}

{% block title %}Categories - Samaco Brewery{% endblock %}

{% block dashboard_content %}
<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
    
    <!-- Page Header -->
    <div class="bg-gradient-to-r from-black to-gray-900 rounded-lg border-l-4 border-yellow-400 p-6 mb-6 shadow-lg">
        <h1 class="text-2xl md:text-3xl font-bold text-yellow-400 mb-1">🏷️ Beer Categories</h1>
        <p class="text-gray-400 text-sm md:text-base">Manage your brewery's beer styles and categories</p>
    </div>

    <!-- Create Button -->
    <div class="mb-6">
        <a href="{{ path('app_category_new') }}" 
           class="inline-flex items-center gap-2 px-6 py-3 bg-yellow-500 text-black font-semibold rounded-lg hover:bg-yellow-400 transition-all duration-200 shadow-md shadow-yellow-500/25">
            <span class="text-xl">+</span>
            <span>Create New Category</span>
        </a>
    </div>

    <!-- Filter Section -->
    <div class="bg-gray-600 rounded-lg p-5 border border-yellow-500/15 mb-6 shadow-md">
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
            <div>
                <label class="block text-yellow-400 text-sm font-semibold mb-2">Category ID</label>
                <input type="text" id="searchId" placeholder="Search by ID..." 
                    class="w-full px-4 py-2 bg-white/5 border border-yellow-500/20 rounded-md text-gray-200 focus:outline-none focus:border-yellow-500 focus:ring-1 focus:ring-yellow-500 transition">
            </div>
            <div>
                <label class="block text-yellow-400 text-sm font-semibold mb-2">Category Name</label>
                <input type="text" id="searchName" placeholder="Search by name..." 
                    class="w-full px-4 py-2 bg-white/5 border border-yellow-500/20 rounded-md text-gray-200 focus:outline-none focus:border-yellow-500 focus:ring-1 focus:ring-yellow-500 transition">
            </div>
            <div>
                <label class="block text-yellow-400 text-sm font-semibold mb-2">Description</label>
                <input type="text" id="searchDescription" placeholder="Search in description..." 
                    class="w-full px-4 py-2 bg-white/5 border border-yellow-500/20 rounded-md text-gray-200 focus:outline-none focus:border-yellow-500 focus:ring-1 focus:ring-yellow-500 transition">
            </div>
        </div>
        <div class="flex justify-end mt-4">
            <button id="resetFilters" class="px-4 py-2 bg-gray-700 text-gray-300 font-semibold rounded-md hover:bg-gray-600 transition">
                Reset All Filters
            </button>
        </div>
    </div>  

    <!-- Categories Grid -->
    {% if categories is empty %}
        <div class="text-center py-12 px-4 bg-gray-800 rounded-lg border border-yellow-500/15">
            <div class="text-5xl mb-3 opacity-60">🍺</div>
            <h3 class="text-xl font-bold text-yellow-400 mb-2">No Categories Found</h3>
            <p class="text-yellow-400/70 mb-4">Create your first beer category to get started!</p>
            <a href="{{ path('app_category_new') }}" class="inline-flex items-center gap-2 px-5 py-2 bg-gradient-to-r from-yellow-400 to-yellow-500 text-black font-semibold rounded-lg hover:scale-105 transition mt-4">
                <span>+</span>
                <span>Create First Category</span>
            </a>
        </div>
    {% else %}
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-8" id="categoriesGrid">
            {% for category in categories %}
                <div class="category-card bg-gray-600 rounded-lg p-6 border border-yellow-500/15 hover:border-yellow-500/30 hover:-translate-y-1 transition-all duration-300 relative overflow-hidden"
                     data-id="{{ category.id }}"
                     data-name="{{ category.name|lower }}" 
                     data-description="{{ category.description|default('')|lower }}">
                    <div class="absolute top-0 left-0 right-0 h-1 bg-yellow-400 opacity-70"></div>
                    
                    <div class="flex justify-between items-start mb-3">
                        <h3 class="text-xl font-bold text-yellow-400">{{ category.name }}</h3>
                        <span class="text-xs text-yellow-400 bg-yellow-400/15 px-2 py-1 rounded-full border border-yellow-500/30">#{{ category.id }}</span>
                    </div>
                    
                    <p class="text-gray-400 text-sm leading-relaxed min-h-[80px] mb-4">
                        {{ category.description ?? 'No description provided' }}
                    </p>
                    
                    <div class="flex gap-2 pt-4 border-t border-gray-700">
                        <a href="{{ path('app_category_show', {'id': category.id}) }}" 
                        class="flex-1 text-center px-3 py-2 text-sm font-medium text-green-400 bg-green-900/30 rounded hover:bg-green-900/50 transition">
                            👁️ View
                        </a>
                        <a href="{{ path('app_category_edit', {'id': category.id}) }}" 
                        class="flex-1 text-center px-3 py-2 text-sm font-medium text-blue-400 bg-blue-900/30 rounded hover:bg-blue-900/50 transition">
                            ✏️ Edit
                        </a>
                        <a href="{{ path('app_category_delete', {'id': category.id}) }}" 
                        onclick="event.preventDefault(); if(confirm('Are you sure you want to delete this category? This action cannot be undone.')) { document.getElementById('delete-form-{{ category.id }}').submit(); }"
                        class="flex-1 text-center px-3 py-2 text-sm font-medium text-red-400 bg-red-900/30 rounded hover:bg-red-900/50 transition">
                            🗑️ Delete
                        </a>
                        <form id="delete-form-{{ category.id }}" method="post" action="{{ path('app_category_delete', {'id': category.id}) }}" style="display: none;">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ category.id) }}">
                        </form>
                    </div>
                </div>
            {% endfor %}
        </div>
        
        <!-- No Results Message -->
        <div id="noResults" class="text-center py-12 px-4 bg-gray-800/50 rounded-lg border border-yellow-500/15 hidden">
            <div class="text-5xl mb-3 opacity-60">🔍</div>
            <h3 class="text-xl font-bold text-yellow-400 mb-2">No Categories Found</h3>
            <p class="text-gray-400">No categories match your filter criteria. Try adjusting your search.</p>
        </div>
    {% endif %}
</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const searchId = document.getElementById('searchId');
            const searchName = document.getElementById('searchName');
            const searchDesc = document.getElementById('searchDescription');
            const resetBtn = document.getElementById('resetFilters');
            const cards = document.querySelectorAll('.category-card');
            const noResults = document.getElementById('noResults');
            const categoriesGrid = document.getElementById('categoriesGrid');
            
            if (!cards.length) return;
            
            function filterCategories() {
                const idFilter = searchId ? searchId.value.toLowerCase() : '';
                const nameFilter = searchName ? searchName.value.toLowerCase() : '';
                const descFilter = searchDesc ? searchDesc.value.toLowerCase() : '';
                
                let visibleCount = 0;
                
                cards.forEach(card => {
                    const id = card.dataset.id;
                    const name = card.dataset.name;
                    const description = card.dataset.description;
                    
                    const matchesId = idFilter === '' || id.includes(idFilter);
                    const matchesName = nameFilter === '' || name.includes(nameFilter);
                    const matchesDesc = descFilter === '' || description.includes(descFilter);
                    
                    if (matchesId && matchesName && matchesDesc) {
                        card.style.display = 'block';
                        visibleCount++;
                    } else {
                        card.style.display = 'none';
                    }
                });
                
                // Show/hide no results message
                if (noResults && categoriesGrid) {
                    if (visibleCount === 0) {
                        noResults.classList.remove('hidden');
                        categoriesGrid.classList.add('hidden');
                    } else {
                        noResults.classList.add('hidden');
                        categoriesGrid.classList.remove('hidden');
                    }
                }
            }
            
            // Add event listeners
            if (searchId) searchId.addEventListener('input', filterCategories);
            if (searchName) searchName.addEventListener('input', filterCategories);
            if (searchDesc) searchDesc.addEventListener('input', filterCategories);
            
            // Reset button
            if (resetBtn) {
                resetBtn.addEventListener('click', function() {
                    if (searchId) searchId.value = '';
                    if (searchName) searchName.value = '';
                    if (searchDesc) searchDesc.value = '';
                    filterCategories();
                });
            }
            
            // Initial filter
            filterCategories();
        });
    </script>
{% endblock %}