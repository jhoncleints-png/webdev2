{% extends 'layout.html.twig' %}

{% block title %}New Category - Samaco Brewery{% endblock %}

{% block dashboard_content %}
<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
    
    <!-- Page Header -->
    <div class="mb-8">
        <!-- Breadcrumb -->
        <nav class="flex items-center gap-2 text-sm text-gray-400 mb-6">
            <a href="{{ path('app_category_index') }}" 
               class="hover:text-yellow-400 transition-colors duration-200">
                Categories
            </a>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
            </svg>
            <span class="text-yellow-400 font-medium">New Category</span>
        </nav>
        
        <!-- Main Heading -->
        <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
            <div>
                <h1 class="text-3xl md:text-4xl font-bold text-white mb-2 flex items-center gap-3">
                    <svg class="w-8 h-8 text-yellow-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path>
                    </svg>
                    Create New Category
                </h1>
                <p class="text-gray-400 ml-11">
                    Add a new beer category to organize your brewery products
                </p>
            </div>
            
            <!-- Back Button -->
            <a href="{{ path('app_category_index') }}"
               class="inline-flex items-center gap-2 px-5 py-3 text-sm font-semibold text-gray-300 
                      bg-gray-800/50 rounded-xl hover:bg-gray-800 hover:text-white transition-all duration-200
                      border border-gray-700/50 focus:outline-none focus:ring-2 focus:ring-gray-500 focus:ring-offset-2 focus:ring-offset-gray-900
                      self-start sm:self-center">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
                </svg>
                Back to Categories
            </a>
        </div>
    </div>

    <!-- Form Section -->
    <div class="bg-gray-900/50 backdrop-blur-sm rounded-2xl border border-gray-700/50 shadow-xl p-6 md:p-8">
        <div class="mb-8">
            <h2 class="text-2xl font-bold text-yellow-400 mb-2 flex items-center gap-3">
                <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
                Category Details
            </h2>
            <p class="text-gray-400">Fill in the details for your new beer category</p>
        </div>
        
        <!-- Include Form -->
        <div class="max-w-4xl mx-auto">
            {{ include('category/_form.html.twig') }}
        </div>
    </div>

    <!-- Quick Tips Section -->
    <div class="mt-8 bg-blue-900/10 backdrop-blur-sm rounded-2xl border border-blue-800/30 shadow-xl p-6 md:p-8">
        <div class="flex items-start gap-4">
            <svg class="w-6 h-6 text-blue-400 mt-1 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
            <div>
                <h3 class="text-lg font-semibold text-blue-300 mb-3">Tips for creating categories</h3>
                <ul class="text-gray-400 space-y-2 text-sm">
                    <li class="flex items-start gap-2">
                        <span class="text-blue-400">•</span>
                        <span>Use descriptive names like "IPAs", "Stouts", "Seasonal Brews"</span>
                    </li>
                    <li class="flex items-start gap-2">
                        <span class="text-blue-400">•</span>
                        <span>Include alcohol content, flavor profiles, or serving suggestions in descriptions</span>
                    </li>
                    <li class="flex items-start gap-2">
                        <span class="text-blue-400">•</span>
                        <span>Keep categories broad enough to group multiple products</span>
                    </li>
                    <li class="flex items-start gap-2">
                        <span class="text-blue-400">•</span>
                        <span>Consider seasonal categories for limited-time offerings</span>
                    </li>
                </ul>
            </div>
        </div>
    </div>

</div>
{% endblock %}