<div class="max-w-4xl mx-auto p-4">
    {{ form_start(form, {'attr': {'class': 'space-y-8'}}) }}
        
        <!-- Form Container -->
        <div class="bg-gray-900/80 backdrop-blur-sm rounded-2xl border border-gray-700/50 shadow-2xl p-6 md:p-8">
            
            <!-- Form Header -->
            <div class="mb-8">
                <h2 class="text-2xl md:text-3xl font-bold text-yellow-400 mb-2">
                    {{ button_label|default('Create Customer') }}
                </h2>
                <p class="text-gray-400 text-sm md:text-base">Add a new customer to your brewery database</p>
            </div>

            <!-- Form Fields -->
            <div class="space-y-8">
                <!-- Name & Email Grid - Responsive: 1 column on mobile, 2 on tablet/desktop -->
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <!-- Name Field -->
                    <div>
                        {{ form_label(form.name, 'Full Name', {
                            'label_attr': {
                                'class': 'block text-sm font-semibold text-yellow-300 mb-2'
                            }
                        }) }}
                        
                        {{ form_widget(form.name, {
                            'attr': {
                                'class': 'w-full px-4 py-3.5 bg-gray-800/50 border border-gray-700 rounded-xl 
                                         text-white placeholder-gray-500 focus:outline-none focus:ring-2 
                                         focus:ring-yellow-500 focus:border-yellow-500 transition duration-200
                                         hover:border-gray-600 text-base',
                                'placeholder': 'Enter customer name'
                            }
                        }) }}
                        
                        {{ form_errors(form.name) }}
                    </div>

                    <!-- Email Field -->
                    <div>
                        {{ form_label(form.email, 'Email Address', {
                            'label_attr': {
                                'class': 'block text-sm font-semibold text-yellow-300 mb-2'
                            }
                        }) }}
                        
                        {{ form_widget(form.email, {
                            'attr': {
                                'class': 'w-full px-4 py-3.5 bg-gray-800/50 border border-gray-700 rounded-xl 
                                         text-white placeholder-gray-500 focus:outline-none focus:ring-2 
                                         focus:ring-yellow-500 focus:border-yellow-500 transition duration-200
                                         hover:border-gray-600 text-base',
                                'placeholder': 'customer@example.com'
                            }
                        }) }}
                        
                        {{ form_errors(form.email) }}
                    </div>
                </div>

                <!-- Phone & Address Grid - Responsive: 1 column on mobile, 2 on tablet/desktop -->
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <!-- Phone Field -->
                    <div>
                        {{ form_label(form.phone, 'Phone Number', {
                            'label_attr': {
                                'class': 'block text-sm font-semibold text-yellow-300 mb-2'
                            }
                        }) }}
                        
                        {{ form_widget(form.phone, {
                            'attr': {
                                'class': 'w-full px-4 py-3.5 bg-gray-800/50 border border-gray-700 rounded-xl 
                                         text-white placeholder-gray-500 focus:outline-none focus:ring-2 
                                         focus:ring-yellow-500 focus:border-yellow-500 transition duration-200
                                         hover:border-gray-600 text-base',
                                'placeholder': '+1 (555) 123-4567'
                            }
                        }) }}
                        
                        {{ form_errors(form.phone) }}
                    </div>

                    <!-- Address Field -->
                    <div>
                        {{ form_label(form.address, 'Address', {
                            'label_attr': {
                                'class': 'block text-sm font-semibold text-yellow-300 mb-2'
                            }
                        }) }}
                        
                        {{ form_widget(form.address, {
                            'attr': {
                                'class': 'w-full px-4 py-3.5 bg-gray-800/50 border border-gray-700 rounded-xl 
                                         text-white placeholder-gray-500 focus:outline-none focus:ring-2 
                                         focus:ring-yellow-500 focus:border-yellow-500 transition duration-200
                                         hover:border-gray-600 text-base',
                                'placeholder': 'Enter customer address'
                            }
                        }) }}
                        
                        {{ form_errors(form.address) }}
                    </div>
                </div>
            </div>

            <!-- Action Buttons  -->
            <div class="flex flex-col sm:flex-row gap-4 mt-12 pt-8 border-t border-gray-700/50">
                <!-- Submit Button -->
                <button type="submit"
                        class="group inline-flex items-center justify-center gap-3 px-8 py-4 text-base font-bold 
                               bg-yellow-500 text-black rounded-xl
                               hover:bg-yellow-400 active:scale-[0.98]
                               shadow-lg hover:shadow-xl shadow-yellow-500/25
                               transition-all duration-200
                               focus:outline-none focus:ring-2 focus:ring-yellow-500 focus:ring-offset-2 focus:ring-offset-gray-900
                               w-full sm:w-auto min-h-[52px]">

                    <svg class="w-5 h-5 transition-transform group-hover:scale-110"
                        fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M5 13l4 4L19 7"></path>
                    </svg>
                    
                    <span>{{ button_label|default('Save Customer') }}</span>
                </button>

                <!-- Cancel Button -->
                <a href="{{ path('app_customer_index') }}"
                   class="inline-flex items-center justify-center gap-3 px-8 py-4 text-base font-semibold
                          bg-gray-600 text-white rounded-xl hover:bg-gray-500 hover:text-white
                          active:scale-[0.98] border border-gray-500/50 transition-all duration-200
                          focus:outline-none focus:ring-2 focus:ring-gray-500 focus:ring-offset-2 focus:ring-offset-gray-900
                          w-full sm:w-auto min-h-[52px]">
                    
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" 
                            d="M6 18L18 6M6 6l12 12"></path>
                    </svg>
                    
                    <span>Cancel</span>
                </a>
            </div>
        </div>

    {{ form_end(form) }}
</div>