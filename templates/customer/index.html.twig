{% extends 'layout.html.twig' %}

{% block title %}Customer Management - Samaco Brewery{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <!-- DataTables CSS -->
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css">
    
    <style>
        .dataTables_paginate .paginate_button {
            display: inline-block !important;
            margin: 0 2px !important;
        }

        .dataTables_paginate {
            display: flex !important;
            flex-wrap: wrap !important;
            justify-content: flex-end !important;
            align-items: center !important;
            gap: 4px !important;
        }

        .dataTables_info {
            display: flex !important;
            align-items: center !important;
        }
    </style>
{% endblock %}

{% block dashboard_content %}
<div class="container mx-auto px-4 py-8">
    <!-- Page Header -->
    <div class="bg-gradient-to-r from-black to-gray-900 rounded-lg border-l-4 border-yellow-500 p-6 mb-6 shadow-lg">
        <h1 class="text-3xl font-bold text-yellow-500 mb-1">💼 Customer Management</h1>
        <p class="text-gray-400">Manage your brewery's customer database and information</p>
    </div>

    <!-- Top Actions -->
    <div class="mb-4">
        <a href="{{ path('app_customer_new') }}" class="inline-flex items-center gap-2 px-6 py-3 bg-gradient-to-r from-yellow-500 to-yellow-300 text-black font-semibold rounded-lg hover:scale-105 transition duration-200 shadow-lg shadow-yellow-500/25">
            <span>+</span>
            <span>Create New Customer</span>
        </a>
    </div>

    <!-- Advanced Filters -->
    <div class="bg-gray-800/80 rounded-lg border border-yellow-500/15 p-5 mb-6 shadow-lg">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
            <div>
                <label for="searchName" class="block text-yellow-500 text-sm font-semibold mb-2">Customer Name</label>
                <input type="text" id="searchName" class="w-full px-3 py-2 bg-gray-700 border border-yellow-500/30 rounded-md text-white focus:outline-none focus:ring-2 focus:ring-yellow-500" placeholder="Search by name...">
            </div>
            
            <div>
                <label for="searchEmail" class="block text-yellow-500 text-sm font-semibold mb-2">Email Address</label>
                <input type="text" id="searchEmail" class="w-full px-3 py-2 bg-gray-700 border border-yellow-500/30 rounded-md text-white focus:outline-none focus:ring-2 focus:ring-yellow-500" placeholder="Search by email...">
            </div>
            
            <div>
                <label for="searchPhone" class="block text-yellow-500 text-sm font-semibold mb-2">Phone Number</label>
                <input type="text" id="searchPhone" class="w-full px-3 py-2 bg-gray-700 border border-yellow-500/30 rounded-md text-white focus:outline-none focus:ring-2 focus:ring-yellow-500" placeholder="Search by phone...">
            </div>
            
            <div>
                <label for="searchAddress" class="block text-yellow-500 text-sm font-semibold mb-2">Address</label>
                <input type="text" id="searchAddress" class="w-full px-3 py-2 bg-gray-700 border border-yellow-500/30 rounded-md text-white focus:outline-none focus:ring-2 focus:ring-yellow-500" placeholder="Search by address...">
            </div>
        </div>
        
        <div class="mt-4">
            <button id="resetFilters" class="px-5 py-2 bg-gray-700 text-gray-400 border border-gray-500 rounded-md font-semibold hover:bg-gray-600 hover:text-white transition-all duration-200">
                Reset All Filters
            </button>
        </div>
    </div>

    <!-- Customers Table -->
    <div class="bg-gray-800/80 rounded-lg shadow-lg p-6">
        {% if customers is empty %}
            <div class="text-center py-12">
                <div class="text-5xl mb-3 opacity-60">👥</div>
                <h3 class="text-yellow-500 text-xl mb-2">No Customers Found</h3>
                <p class="text-yellow-500/70">Start by creating your first customer to build your database</p>
                <a href="{{ path('app_customer_new') }}" class="inline-flex items-center gap-2 px-6 py-3 mt-4 bg-gradient-to-r from-yellow-500 to-yellow-300 text-black font-semibold rounded-lg hover:scale-105 transition duration-200">
                    <span>+</span>
                    <span>Create First Customer</span>
                </a>
            </div>
        {% else %}
            <table id="customerTable" class="display w-full">
                <thead>
                    <tr class="bg-yellow-500/15">
                        <th class="px-4 py-3 text-left text-xs font-semibold text-yellow-500 uppercase tracking-wider">ID</th>
                        <th class="px-4 py-3 text-left text-xs font-semibold text-yellow-500 uppercase tracking-wider">Name</th>
                        <th class="px-4 py-3 text-left text-xs font-semibold text-yellow-500 uppercase tracking-wider">Email</th>
                        <th class="px-4 py-3 text-left text-xs font-semibold text-yellow-500 uppercase tracking-wider">Phone</th>
                        <th class="px-4 py-3 text-left text-xs font-semibold text-yellow-500 uppercase tracking-wider">Address</th>
                        <th class="px-4 py-3 text-left text-xs font-semibold text-yellow-500 uppercase tracking-wider">Created By</th>
                        <th class="px-4 py-3 text-left text-xs font-semibold text-yellow-500 uppercase tracking-wider">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for customer in customers %}
                        <tr class="border-b border-gray-700 hover:bg-yellow-500/10 transition-colors">
                            <td class="px-4 py-3 text-sm text-white">{{ customer.id }}</td>
                            <td class="px-4 py-3 text-sm text-white font-medium">{{ customer.name }}</td>
                            <td class="px-4 py-3 text-sm text-gray-300">{{ customer.email }}</td>
                            <td class="px-4 py-3 text-sm text-gray-300">{{ customer.phone ?? '-' }}</td>
                            <td class="px-4 py-3 text-sm text-gray-300">{{ customer.address ?? '-' }}</td>
                            <td class="px-4 py-3">
                                {% if customer.createdBy %}
                                    {% set isCurrentUser = customer.createdBy.id == app.user.id %}
                                    <span class="inline-flex items-center gap-1 px-2 py-1 rounded-full text-xs font-semibold {% if isCurrentUser %}bg-green-900/30 text-green-300 border border-green-500/50{% else %}bg-yellow-900/30 text-yellow-300 border border-yellow-500/50{% endif %}">
                                        <span>👤</span>
                                        <span>{{ isCurrentUser ? 'You' : customer.createdBy.email }}</span>
                                    </span>
                                {% else %}
                                    <span class="text-gray-500 text-sm">Not assigned</span>
                                {% endif %}
                            </td>
                            <td class="px-4 py-3">
                                <div class="flex gap-2 flex-wrap">
                                    <a href="{{ path('app_customer_show', {'id': customer.id}) }}" class="inline-flex items-center gap-1 px-3 py-1.5 bg-teal-900/30 text-teal-300 border border-teal-500/50 rounded-md text-xs font-semibold hover:bg-teal-900/50 transition">
                                        👁️ View
                                    </a>
                                    
                                    {% if is_granted('ROLE_ADMIN') %}
                                        <a href="{{ path('app_customer_edit', {'id': customer.id}) }}" class="inline-flex items-center gap-1 px-3 py-1.5 bg-blue-900/30 text-blue-300 border border-blue-500/50 rounded-md text-xs font-semibold hover:bg-blue-900/50 transition">
                                            ✏️ Edit
                                        </a>
                                    {% endif %}
                                </div>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        {% endif %}
    </div>
</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    
    <!-- DataTables JS -->
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>
    
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            if ($('#customerTable').length && !$.fn.DataTable.isDataTable('#customerTable')) {
                window.customerTable = $('#customerTable').DataTable({
                    paging: true,
                    pageLength: 10,
                    lengthMenu: [[10, 25, 50, 100], [10, 25, 50, 100]],
                    searching: true,
                    ordering: true,
                    order: [[0, 'desc']],
                    responsive: true,
                    autoWidth: false,
                    language: {
                        search: "Search:",
                        searchPlaceholder: "Type to search...",
                        lengthMenu: "Show _MENU_ entries",
                        info: "Showing _START_ to _END_ of _TOTAL_ entries",
                        infoEmpty: "Showing 0 to 0 of 0 entries",
                        infoFiltered: "(filtered from _MAX_ total entries)",
                        zeroRecords: "No matching records found",
                        paginate: {
                            first: "« First",
                            last: "Last »",
                            next: "Next →",
                            previous: "← Previous"
                        }
                    },
                    dom: '<"flex flex-wrap justify-between items-center mb-4"l<"ml-auto"f>>rt<"flex flex-wrap justify-between items-center mt-4"ip>',
                });
                
                // Filters
                $('#searchName').on('keyup', function() {
                    window.customerTable.column(1).search(this.value).draw();
                });
                
                $('#searchEmail').on('keyup', function() {
                    window.customerTable.column(2).search(this.value).draw();
                });
                
                $('#searchPhone').on('keyup', function() {
                    window.customerTable.column(3).search(this.value).draw();
                });
                
                $('#searchAddress').on('keyup', function() {
                    window.customerTable.column(4).search(this.value).draw();
                });
                
                $('#resetFilters').on('click', function() {
                    $('#searchName').val('');
                    $('#searchEmail').val('');
                    $('#searchPhone').val('');
                    $('#searchAddress').val('');
                    if (window.customerTable) {
                        window.customerTable.search('');
                        window.customerTable.columns().search('');
                        window.customerTable.draw();
                    }
                });
            }
        });
    </script>
{% endblock %}