{% extends 'layout.html.twig' %}

{% block title %}{{ customer.name }} - Samaco Brewery{% endblock %}

{% block dashboard_content %}
<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
    
    <div class="mb-8">
        <nav class="flex items-center gap-2 text-sm text-black mb-6">
            <a href="{{ path('app_dashboard_home') }}" class="hover:text-yellow-400 transition-colors duration-200">Dashboard</a>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
            <a href="{{ path('app_customer_index') }}" class="hover:text-yellow-400 transition-colors duration-200">Customers</a>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
            <span class="text-yellow-400 font-medium">{{ customer.name }}</span>
        </nav>
        
        <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
            <div>
                <h1 class="text-3xl md:text-4xl font-bold text-black mb-2 flex items-center gap-3">
                    <svg class="w-8 h-8 text-yellow-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg>
                    {{ customer.name }}
                </h1>
                <p class="text-black ml-11">Customer Details</p>
            </div>
            
            <a href="{{ path('app_customer_index') }}"
               class="inline-flex items-center gap-2 px-5 py-3 text-sm font-semibold text-white 
                      bg-gray-700 rounded-xl hover:bg-gray-600 hover:text-white transition-all duration-200
                      border border-gray-600 focus:outline-none focus:ring-2 focus:ring-yellow-500 focus:ring-offset-2 focus:ring-offset-gray-900
                      self-start sm:self-center shadow-md">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
                </svg>
                Back to Customers
            </a>
        </div>
    </div>

    <div class="bg-gray-900/50 backdrop-blur-sm rounded-2xl border border-gray-700/50 shadow-xl p-6 md:p-8">
        
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
            <div class="bg-gray-900 rounded-xl border border-gray-700 p-6">
                <div class="flex items-center gap-4 mb-4">
                    <div class="w-12 h-12 flex items-center justify-center bg-blue-900/30 rounded-xl border border-blue-800/30">
                        <svg class="w-6 h-6 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg>
                    </div>
                    <h3 class="text-lg font-semibold text-white">Customer ID</h3>
                </div>
                <p class="text-3xl font-bold text-yellow-400">#{{ customer.id }}</p>
                <p class="text-sm text-white mt-2">Unique identifier</p>
            </div>
            
            <div class="bg-gray-900 rounded-xl border border-gray-700 p-6">
                <div class="flex items-center gap-4 mb-4">
                    <div class="w-12 h-12 flex items-center justify-center bg-green-900/30 rounded-xl border border-green-800/30">
                        <svg class="w-6 h-6 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 4.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
                    </div>
                    <h3 class="text-lg font-semibold text-white">Email Address</h3>
                </div>
                <p class="text-lg font-medium text-yellow-400">{{ customer.email }}</p>
                <p class="text-sm text-white mt-2">Primary contact email</p>
            </div>
            
            <div class="bg-gray-900 rounded-xl border border-gray-700 p-6">
                <div class="flex items-center gap-4 mb-4">
                    <div class="w-12 h-12 flex items-center justify-center bg-purple-900/30 rounded-xl border border-purple-800/30">
                        <svg class="w-6 h-6 text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
                    </div>
                    <h3 class="text-lg font-semibold text-white">Phone</h3>
                </div>
                <p class="text-lg font-medium text-yellow-400">{{ customer.phone ?? '-' }}</p>
                <p class="text-sm text-white mt-2">Contact number</p>
            </div>
            
            <div class="bg-gray-900 rounded-xl border border-gray-700 p-6">
                <div class="flex items-center gap-4 mb-4">
                    <div class="w-12 h-12 flex items-center justify-center bg-yellow-900/30 rounded-xl border border-yellow-800/30">
                        <svg class="w-6 h-6 text-yellow-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"></path></svg>
                    </div>
                    <h3 class="text-lg font-semibold text-white">Total Orders</h3>
                </div>
                <p class="text-3xl font-bold text-yellow-400">{{ customer.orders|length }}</p>
                <p class="text-sm text-white mt-2">Completed purchases</p>
            </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-8">
            <div class="bg-gray-900 rounded-xl border border-gray-700 p-6">
                <div class="flex items-center gap-4 mb-4">
                    <div class="w-12 h-12 flex items-center justify-center bg-indigo-900/30 rounded-xl border border-indigo-800/30">
                        <svg class="w-6 h-6 text-indigo-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                    </div>
                    <h3 class="text-lg font-semibold text-white">Address</h3>
                </div>
                <div class="bg-gray-800/50 rounded-xl p-4 border border-gray-700">
                    <p class="text-white">
                        {{ customer.address ?? 'No address provided for this customer.' }}
                    </p>
                </div>
                <p class="text-sm text-white mt-2">Delivery address</p>
            </div>
            
            <div class="bg-gray-900 rounded-xl border border-gray-700 p-6">
                <div class="flex items-center gap-4 mb-4">
                    <div class="w-12 h-12 flex items-center justify-center bg-teal-900/30 rounded-xl border border-teal-800/30">
                        <svg class="w-6 h-6 text-teal-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg>
                    </div>
                    <h3 class="text-lg font-semibold text-white">Created By</h3>
                </div>
                <div class="bg-gray-800/50 rounded-xl p-4 border border-gray-700">
                    {% if customer.createdBy %}
                        <div class="flex items-center gap-3">
                            <div class="w-10 h-10 flex items-center justify-center bg-teal-900/20 rounded-full border border-teal-800/30">
                                <svg class="w-5 h-5 text-teal-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg>
                            </div>
                            <div>
                                <p class="font-medium text-white">{{ customer.createdBy.email }}</p>
                                <p class="text-sm text-gray-400">Staff member</p>
                            </div>
                        </div>
                    {% else %}
                        <p class="text-gray-400 italic">Not assigned</p>
                    {% endif %}
                </div>
                <p class="text-sm text-white mt-2">Account creator</p>
            </div>
        </div>

        {% if customer.orders|length > 0 %}
        <div class="bg-gray-900 rounded-xl border border-gray-700 p-6 mb-8">
            <div class="mb-6">
                <h2 class="text-xl font-bold text-yellow-400 mb-2 flex items-center gap-3">
                    <svg class="w-6 h-6 text-yellow-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"></path></svg>
                    Recent Orders ({{ customer.orders|length }} total)
                </h2>
                <p class="text-white">Latest orders placed by this customer</p>
            </div>
            
            <div class="overflow-x-auto">
                <table class="w-full">
                    <thead>
                        <tr class="border-b border-gray-700">
                            <th class="py-3 px-4 text-left text-sm font-semibold text-yellow-300">Order #</th>
                            <th class="py-3 px-4 text-left text-sm font-semibold text-yellow-300">Date</th>
                            <th class="py-3 px-4 text-left text-sm font-semibold text-yellow-300">Status</th>
                            <th class="py-3 px-4 text-left text-sm font-semibold text-yellow-300">Total</th>
                            <th class="py-3 px-4 text-left text-sm font-semibold text-yellow-300">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for order in customer.orders|slice(0, 5) %}
                        <tr class="border-b border-gray-700/50 hover:bg-gray-800/30 transition-colors duration-150">
                            <td class="py-3 px-4 text-white">{{ order.orderNumber }}</td>
                            <td class="py-3 px-4 text-white">{{ order.orderDate|date('Y-m-d') }}</td>
                            <td class="py-3 px-4">
                                {% set statusColors = {
                                    'pending': 'bg-yellow-900/30 text-yellow-400 border-yellow-800/30',
                                    'delivered': 'bg-green-900/30 text-green-400 border-green-800/30',
                                    'cancelled': 'bg-red-900/30 text-red-400 border-red-800/30'
                                } %}
                                <span class="px-3 py-1 rounded-full text-xs font-medium border {{ statusColors[order.status|lower] ?? 'bg-gray-800 text-gray-300 border-gray-700' }}">
                                    {{ order.getStatusLabel() }}
                                </span>
                            </td>
                            <td class="py-3 px-4 font-semibold text-white">${{ order.totalAmount }}</td>
                            <td class="py-3 px-4">
                                <a href="{{ path('app_order_show', {'id': order.id}) }}" 
                                   class="inline-flex items-center gap-1 px-2 py-1 text-sm text-yellow-400 hover:text-yellow-300 
                                          bg-transparent hover:bg-yellow-900/20 rounded-lg transition-all duration-200">
                                    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path>
                                    </svg>
                                    View
                                </a>
                            </td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
                
                {% if customer.orders|length > 5 %}
                <div class="text-center mt-6 pt-4 border-t border-gray-700">
                    <p class="text-gray-500 text-sm">
                        Showing 5 of {{ customer.orders|length }} orders
                    </p>
                </div>
                {% endif %}
            </div>
        </div>
        {% endif %}

        <div class="bg-gray-900 rounded-xl border border-gray-700 p-4 md:p-6">
            <div class="mb-4">
                <h2 class="text-lg font-bold text-yellow-400 mb-1 flex items-center gap-2">
                    <svg class="w-5 h-5 text-yellow-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                    Customer Actions
                </h2>
                <p class="text-gray-400 text-sm">Manage this customer</p>
            </div>
            
            <div class="flex flex-col sm:flex-row gap-3">
                {% set canEdit = false %}
                {% if is_granted('ROLE_ADMIN') %}
                    {% set canEdit = true %}
                {% elseif is_granted('ROLE_STAFF') and customer.createdBy and customer.createdBy.id == app.user.id %}
                    {% set canEdit = true %}
                {% endif %}
                
                {% if canEdit %}
                <a href="{{ path('app_customer_edit', {'id': customer.id}) }}"
                   class="group inline-flex items-center justify-center gap-2 px-4 py-2 text-sm font-semibold 
                          bg-yellow-500 text-black rounded-lg
                          hover:bg-yellow-400 active:scale-[0.98]
                          shadow-md hover:shadow-lg shadow-yellow-500/25
                          transition-all duration-200
                          focus:outline-none focus:ring-2 focus:ring-yellow-500 focus:ring-offset-2 focus:ring-offset-gray-900">
                    
                    <svg class="w-4 h-4 transition-transform group-hover:scale-110" 
                         fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" 
                              d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
                    </svg>
                    
                    <span>Edit Customer</span>
                </a>
                {% endif %}

                {% if is_granted('ROLE_ADMIN') %}
                <div>
                    <form method="post" 
                          action="{{ path('app_customer_delete', {'id': customer.id}) }}" 
                          onsubmit="return confirm('Are you sure you want to delete this customer? This action cannot be undone.');">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ customer.id) }}">
                        <button type="submit"
                                class="group inline-flex items-center justify-center gap-2 px-4 py-2 text-sm font-semibold 
                                       bg-red-600 text-white rounded-lg
                                       hover:bg-red-500 active:scale-[0.98]
                                       shadow-md hover:shadow-lg shadow-red-900/30
                                       transition-all duration-200
                                       focus:outline-none focus:ring-2 focus:ring-red-500 focus:ring-offset-2 focus:ring-offset-gray-900">
                            
                            <svg class="w-4 h-4 transition-transform group-hover:scale-110" 
                                 fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" 
                                      d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
                            </svg>
                            
                            <span>Delete Customer</span>
                        </button>
                    </form>
                </div>
                {% endif %}
            </div>
        </div>
    </div>
</div>
{% endblock %}  