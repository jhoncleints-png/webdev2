{% extends 'layout.html.twig' %}

{% block title %}Dashboard - Samaco Brewery{% endblock %}

{% block dashboard_content %}
<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4 sm:py-6" data-user-id="{% if app.user %}{{ app.user.id }}{% endif %}" data-mercure-url="https://airy-connection-staging.up.railway.app/.well-known/mercure?topic=/orders/new&topic=/orders/update">
    
    <!-- Real-time Notification Banner -->
    <div id="notification-banner" class="hidden fixed top-4 right-4 z-50 max-w-sm">
        <div class="bg-gray-900 border-l-4 border-yellow-400 rounded-lg shadow-2xl p-4">
            <div class="flex items-start">
                <div class="flex-shrink-0">
                    <span class="text-2xl">🔔</span>
                </div>
                <div class="ml-3 flex-1">
                    <p id="notification-title" class="text-sm font-medium text-yellow-400"></p>
                    <p id="notification-message" class="mt-1 text-sm text-gray-300"></p>
                </div>
                <button onclick="hideNotification()" class="ml-3 flex-shrink-0 text-gray-400 hover:text-white">
                    <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                    </svg>
                </button>
            </div>
        </div>
    </div>

    <!-- Page Header -->
    <div class="bg-gradient-to-r from-black to-gray-900 rounded-xl sm:rounded-2xl border-l-4 border-yellow-400 p-4 sm:p-6 mb-6 sm:mb-8 shadow-xl">
        <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
            <div>
                <h1 class="text-xl sm:text-2xl md:text-3xl font-bold text-yellow-400 mb-1">
                    Brewery Dashboard
                </h1>
                <p class="text-gray-400 text-xs sm:text-sm">Welcome back! Manage your brewery system with powerful tools and real-time insights.</p>
            </div>
            {% if is_granted('ROLE_ADMIN') %}
                <span class="self-start sm:self-center px-3 py-1.5 text-xs font-bold rounded-full bg-red-900/40 text-red-300 border border-red-700/50">ADMIN</span>
            {% elseif is_granted('ROLE_STAFF') %}
                <span class="self-start sm:self-center px-3 py-1.5 text-xs font-bold rounded-full bg-yellow-900/40 text-yellow-300 border border-yellow-700/50">STAFF</span>
            {% else %}
                <span class="self-start sm:self-center px-3 py-1.5 text-xs font-bold rounded-full bg-blue-900/40 text-blue-300 border border-blue-700/50">USER</span>
            {% endif %}
        </div>
    </div>

    <!-- Stats Cards - Grey Outer Box with Black Inner Boxes -->
    <div class="bg-gray-900/50 backdrop-blur-sm rounded-2xl border border-gray-700/50 shadow-xl p-5 md:p-6 mb-8">
        <div class="flex justify-between items-center mb-4 pb-2 border-b border-gray-700">
            <h2 class="text-lg font-bold text-yellow-400">Statistics Overview</h2>
        </div>
        
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
            
            <!-- Total Users - Admin Only -->
            {% if is_granted('ROLE_ADMIN') %}
            <div class="bg-gray-900 rounded-xl border border-gray-700 p-4 text-center hover:border-yellow-500/30 hover:-translate-y-1 transition-all duration-300">
                <div class="w-12 h-12 bg-yellow-500/10 rounded-xl flex items-center justify-center border border-yellow-500/30 mx-auto mb-2">
                    <span class="text-xl">👥</span>
                </div>
                <h3 class="text-white font-semibold text-sm mb-1">Total Users</h3>
                <p class="text-3xl font-bold text-yellow-400 my-2">{{ user_count }}</p>
                <p class="text-gray-500 text-xs">All registered users in the system</p>
            </div>
            
            <!-- Staff Members - Admin Only -->
            <div class="bg-gray-900 rounded-xl border border-gray-700 p-4 text-center hover:border-yellow-500/30 hover:-translate-y-1 transition-all duration-300">
                <div class="w-12 h-12 bg-yellow-500/10 rounded-xl flex items-center justify-center border border-yellow-500/30 mx-auto mb-2">
                    <span class="text-xl">👨‍💼</span>
                </div>
                <h3 class="text-white font-semibold text-sm mb-1">Staff Members</h3>
                <p class="text-3xl font-bold text-yellow-400 my-2">{{ staff_count }}</p>
                <p class="text-gray-500 text-xs">Active staff accounts</p>
            </div>
            
            <!-- Total Records - Admin Only -->
            <div class="bg-gray-900 rounded-xl border border-gray-700 p-4 text-center hover:border-yellow-500/30 hover:-translate-y-1 transition-all duration-300">
                <div class="w-12 h-12 bg-yellow-500/10 rounded-xl flex items-center justify-center border border-yellow-500/30 mx-auto mb-2">
                    <span class="text-xl">📊</span>
                </div>
                <h3 class="text-white font-semibold text-sm mb-1">Total Records</h3>
                <p class="text-3xl font-bold text-yellow-400 my-2">{{ total_records }}</p>
                <p class="text-gray-500 text-xs">P: {{ product_count }} • C: {{ category_count }} • Cu: {{ customer_count }}</p>
            </div>
            
            <!-- Categories - Admin Only -->
            <div class="bg-gray-900 rounded-xl border border-gray-700 p-4 text-center hover:border-yellow-500/30 hover:-translate-y-1 transition-all duration-300">
                <div class="w-12 h-12 bg-yellow-500/10 rounded-xl flex items-center justify-center border border-yellow-500/30 mx-auto mb-2">
                    <span class="text-xl">🏷️</span>
                </div>
                <h3 class="text-white font-semibold text-sm mb-1">Categories</h3>
                <p class="text-3xl font-bold text-yellow-400 my-2">{{ category_count }}</p>
                <p class="text-gray-500 text-xs">Product categories available</p>
            </div>
            {% endif %}
            
            <!-- Total Products - Admin and Staff -->
            {% if is_granted('ROLE_ADMIN') or is_granted('ROLE_STAFF') %}
            <div class="bg-gray-900 rounded-xl border border-gray-700 p-4 text-center hover:border-yellow-500/30 hover:-translate-y-1 transition-all duration-300">
                <div class="w-12 h-12 bg-yellow-500/10 rounded-xl flex items-center justify-center border border-yellow-500/30 mx-auto mb-2">
                    <span class="text-xl">🍺</span>
                </div>
                <h3 class="text-white font-semibold text-sm mb-1">Total Products</h3>
                <p class="text-3xl font-bold text-yellow-400 my-2">{{ product_count }}</p>
                <p class="text-gray-500 text-xs">Brewery products in inventory</p>
            </div>
            {% endif %}
            
            <!-- Stock Items - Admin and Staff -->
            {% if is_granted('ROLE_ADMIN') or is_granted('ROLE_STAFF') %}
            <div class="bg-gray-900 rounded-xl border border-gray-700 p-4 text-center hover:border-yellow-500/30 hover:-translate-y-1 transition-all duration-300">
                <div class="w-12 h-12 bg-yellow-500/10 rounded-xl flex items-center justify-center border border-yellow-500/30 mx-auto mb-2">
                    <span class="text-xl">📦</span>
                </div>
                <h3 class="text-white font-semibold text-sm mb-1">Stock Items</h3>
                <p class="text-3xl font-bold text-yellow-400 my-2">{{ stock_count ?? 0 }}</p>
                <p class="text-gray-500 text-xs">Products in inventory</p>
            </div>
            {% endif %}
            
            <!-- Customers - Admin and Staff -->
            {% if is_granted('ROLE_ADMIN') or is_granted('ROLE_STAFF') %}
            <div class="bg-gray-900 rounded-xl border border-gray-700 p-4 text-center hover:border-yellow-500/30 hover:-translate-y-1 transition-all duration-300">
                <div class="w-12 h-12 bg-yellow-500/10 rounded-xl flex items-center justify-center border border-yellow-500/30 mx-auto mb-2">
                    <span class="text-xl">💼</span>
                </div>
                <h3 class="text-white font-semibold text-sm mb-1">Customers</h3>
                <p class="text-3xl font-bold text-yellow-400 my-2">{{ customer_count }}</p>
                <p class="text-gray-500 text-xs">Registered customer accounts</p>
            </div>
            {% endif %}
            
            <!-- System Status - Everyone -->
            <div class="bg-gray-900 rounded-xl border border-gray-700 p-4 text-center hover:border-yellow-500/30 hover:-translate-y-1 transition-all duration-300">
                <div class="w-12 h-12 bg-yellow-500/10 rounded-xl flex items-center justify-center border border-yellow-500/30 mx-auto mb-2">
                    <span class="text-xl">✅</span>
                </div>
                <h3 class="text-white font-semibold text-sm mb-1">System Status</h3>
                <p class="text-3xl font-bold text-green-400 my-2">100%</p>
                <p class="text-gray-500 text-xs">All systems operational</p>
            </div>
            
            <!-- Active Sessions - Everyone -->
            <div class="bg-gray-900 rounded-xl border border-gray-700 p-4 text-center hover:border-yellow-500/30 hover:-translate-y-1 transition-all duration-300">
                <div class="w-12 h-12 bg-yellow-500/10 rounded-xl flex items-center justify-center border border-yellow-500/30 mx-auto mb-2">
                    <span class="text-xl">👤</span>
                </div>
                <h3 class="text-white font-semibold text-sm mb-1">Active Sessions</h3>
                <p class="text-3xl font-bold text-yellow-400 my-2">{{ user_count }}</p>
                <p class="text-gray-500 text-xs">Currently active in system</p>
            </div>
        </div>
    </div>

    <!-- Quick Actions Section -->
    <div class="bg-gray-900/50 backdrop-blur-sm rounded-2xl border border-gray-700/50 shadow-xl p-5 md:p-6 mb-8">
        <div class="flex justify-between items-center mb-4 pb-2 border-b border-gray-700">
            <h2 class="text-lg font-bold text-yellow-400">Quick Actions</h2>
        </div>
        
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
            <!-- Manage Products -->
            <div class="bg-gray-900 rounded-xl border border-gray-700 p-4 text-center hover:border-yellow-500/30 hover:-translate-y-1 transition-all duration-300">
                <div class="w-12 h-12 bg-yellow-500/10 rounded-xl flex items-center justify-center border border-yellow-500/30 mx-auto mb-2">
                    <span class="text-xl">🍺</span>
                </div>
                <h3 class="text-white font-semibold text-sm mb-1">Manage Products</h3>
                <p class="text-gray-500 text-xs mb-3">Add, edit, or remove products</p>
                <a href="{{ path('app_product_index') }}" class="inline-flex items-center gap-1 px-3 py-1 text-xs font-medium text-yellow-400 bg-yellow-900/20 rounded-lg hover:bg-yellow-900/40 transition-all duration-200">
                    <span>View</span>
                    <span>→</span>
                </a>
            </div>
            
            <!-- View Orders -->
            <div class="bg-gray-900 rounded-xl border border-gray-700 p-4 text-center hover:border-yellow-500/30 hover:-translate-y-1 transition-all duration-300">
                <div class="w-12 h-12 bg-yellow-500/10 rounded-xl flex items-center justify-center border border-yellow-500/30 mx-auto mb-2">
                    <span class="text-xl">📦</span>
                </div>
                <h3 class="text-white font-semibold text-sm mb-1">View Orders</h3>
                <p class="text-gray-500 text-xs mb-3">Monitor customer orders</p>
                <a href="{{ path('app_order_index') }}" class="inline-flex items-center gap-1 px-3 py-1 text-xs font-medium text-yellow-400 bg-yellow-900/20 rounded-lg hover:bg-yellow-900/40 transition-all duration-200">
                    <span>View</span>
                    <span>→</span>
                </a>
            </div>

            <!-- Manage Stock - Admin and Staff -->
            {% if is_granted('ROLE_ADMIN') or is_granted('ROLE_STAFF') %}
            <div class="bg-gray-900 rounded-xl border border-gray-700 p-4 text-center hover:border-yellow-500/30 hover:-translate-y-1 transition-all duration-300">
                <div class="w-12 h-12 bg-yellow-500/10 rounded-xl flex items-center justify-center border border-yellow-500/30 mx-auto mb-2">
                    <span class="text-xl">📊</span>
                </div>
                <h3 class="text-white font-semibold text-sm mb-1">Manage Stock</h3>
                <p class="text-gray-500 text-xs mb-3">Track inventory levels</p>
                <a href="{{ path('app_stock_index') }}" class="inline-flex items-center gap-1 px-3 py-1 text-xs font-medium text-yellow-400 bg-yellow-900/20 rounded-lg hover:bg-yellow-900/40 transition-all duration-200">
                    <span>View</span>
                    <span>→</span>
                </a>
            </div>
            {% endif %}

            <!-- Manage Customers - Admin and Staff -->
            {% if is_granted('ROLE_ADMIN') or is_granted('ROLE_STAFF') %}
            <div class="bg-gray-900 rounded-xl border border-gray-700 p-4 text-center hover:border-yellow-500/30 hover:-translate-y-1 transition-all duration-300">
                <div class="w-12 h-12 bg-yellow-500/10 rounded-xl flex items-center justify-center border border-yellow-500/30 mx-auto mb-2">
                    <span class="text-xl">💼</span>
                </div>
                <h3 class="text-white font-semibold text-sm mb-1">Manage Customers</h3>
                <p class="text-gray-500 text-xs mb-3">Handle customer accounts</p>
                <a href="{{ path('app_customer_index') }}" class="inline-flex items-center gap-1 px-3 py-1 text-xs font-medium text-yellow-400 bg-yellow-900/20 rounded-lg hover:bg-yellow-900/40 transition-all duration-200">
                    <span>View</span>
                    <span>→</span>
                </a>
            </div>
            {% endif %}

            <!-- Manage Users - Admin Only -->
            {% if is_granted('ROLE_ADMIN') %}
            <div class="bg-gray-900 rounded-xl border border-gray-700 p-4 text-center hover:border-yellow-500/30 hover:-translate-y-1 transition-all duration-300">
                <div class="w-12 h-12 bg-yellow-500/10 rounded-xl flex items-center justify-center border border-yellow-500/30 mx-auto mb-2">
                    <span class="text-xl">👥</span>
                </div>
                <h3 class="text-white font-semibold text-sm mb-1">Manage Users</h3>
                <p class="text-gray-500 text-xs mb-3">Add, edit, or remove users</p>
                <a href="{{ path('app_user_index') }}" class="inline-flex items-center gap-1 px-3 py-1 text-xs font-medium text-yellow-400 bg-yellow-900/20 rounded-lg hover:bg-yellow-900/40 transition-all duration-200">
                    <span>View</span>
                    <span>→</span>
                </a>
            </div>

            <!-- Manage Categories - Admin Only -->
            <div class="bg-gray-900 rounded-xl border border-gray-700 p-4 text-center hover:border-yellow-500/30 hover:-translate-y-1 transition-all duration-300">
                <div class="w-12 h-12 bg-yellow-500/10 rounded-xl flex items-center justify-center border border-yellow-500/30 mx-auto mb-2">
                    <span class="text-xl">🏷️</span>
                </div>
                <h3 class="text-white font-semibold text-sm mb-1">Manage Categories</h3>
                <p class="text-gray-500 text-xs mb-3">Organize categories</p>
                <a href="{{ path('app_category_index') }}" class="inline-flex items-center gap-1 px-3 py-1 text-xs font-medium text-yellow-400 bg-yellow-900/20 rounded-lg hover:bg-yellow-900/40 transition-all duration-200">
                    <span>View</span>
                    <span>→</span>
                </a>
            </div>

            <!-- Activity Logs - Admin Only -->
            <div class="bg-gray-900 rounded-xl border border-gray-700 p-4 text-center hover:border-yellow-500/30 hover:-translate-y-1 transition-all duration-300">
                <div class="w-12 h-12 bg-yellow-500/10 rounded-xl flex items-center justify-center border border-yellow-500/30 mx-auto mb-2">
                    <span class="text-xl">📊</span>
                </div>
                <h3 class="text-white font-semibold text-sm mb-1">Activity Logs</h3>
                <p class="text-gray-500 text-xs mb-3">Monitor system activities</p>
                <a href="{{ path('app_activity_log_index') }}" class="inline-flex items-center gap-1 px-3 py-1 text-xs font-medium text-yellow-400 bg-yellow-900/20 rounded-lg hover:bg-yellow-900/40 transition-all duration-200">
                    <span>View</span>
                    <span>→</span>
                </a>
            </div>
            {% endif %}

            <!-- My Profile - Everyone -->
            <div class="bg-gray-900 rounded-xl border border-gray-700 p-4 text-center hover:border-yellow-500/30 hover:-translate-y-1 transition-all duration-300">
                <div class="w-12 h-12 bg-yellow-500/10 rounded-xl flex items-center justify-center border border-yellow-500/30 mx-auto mb-2">
                    <span class="text-xl">👤</span>
                </div>
                <h3 class="text-white font-semibold text-sm mb-1">My Profile</h3>
                <p class="text-gray-500 text-xs mb-3">View and edit your profile</p>
                <a href="{{ path('app_profile_index') }}" class="inline-flex items-center gap-1 px-3 py-1 text-xs font-medium text-yellow-400 bg-yellow-900/20 rounded-lg hover:bg-yellow-900/40 transition-all duration-200">
                    <span>View</span>
                    <span>→</span>
                </a>
            </div>
        </div>
    </div>

    <!-- Activity Logs Section - Admin Only -->
    {% if is_granted('ROLE_ADMIN') %}
    <div class="bg-gray-900/50 backdrop-blur-sm rounded-2xl border border-gray-700/50 shadow-xl p-5 md:p-6 mb-8">
        <div class="flex justify-between items-center mb-4 pb-2 border-b border-gray-700">
            <h2 class="text-lg font-bold text-yellow-400">Recent Activity Logs</h2>
        </div>
        
        <div class="overflow-x-auto">
            <table class="w-full min-w-[640px]">
                <thead>
                    <tr class="border-b border-gray-700">
                        <th class="py-2 px-3 text-left text-xs font-semibold text-yellow-400 uppercase">USER</th>
                        <th class="py-2 px-3 text-left text-xs font-semibold text-yellow-400 uppercase">ROLE</th>
                        <th class="py-2 px-3 text-left text-xs font-semibold text-yellow-400 uppercase">ACTION</th>
                        <th class="py-2 px-3 text-left text-xs font-semibold text-yellow-400 uppercase">DETAILS</th>
                        <th class="py-2 px-3 text-left text-xs font-semibold text-yellow-400 uppercase">TIME</th>
                    </tr>
                </thead>
                <tbody>
                    {% if recent_activities|length > 0 %}
                        {% for activity in recent_activities|slice(0, 5) %}
                            <tr class="border-b border-gray-800 hover:bg-yellow-500/5 transition-all duration-200">
                                <td class="py-2 px-3 text-yellow-400 font-medium text-sm">{{ activity.user.email|split('@')[0] }}</td>
                                <td class="py-2 px-3">
                                    {% if 'ROLE_ADMIN' in activity.user.roles %}
                                        <span class="px-2 py-0.5 text-xs font-semibold rounded-full bg-red-900/40 text-red-300 border border-red-700/50">ADMIN</span>
                                    {% elseif 'ROLE_STAFF' in activity.user.roles %}
                                        <span class="px-2 py-0.5 text-xs font-semibold rounded-full bg-yellow-900/40 text-yellow-300 border border-yellow-700/50">STAFF</span>
                                    {% else %}
                                        <span class="px-2 py-0.5 text-xs font-semibold rounded-full bg-blue-900/40 text-blue-300 border border-blue-700/50">USER</span>
                                    {% endif %}
                                </td>
                                <td class="py-2 px-3">
                                    <span class="px-2 py-0.5 text-xs font-semibold rounded-full 
                                        {% if activity.action == 'LOGIN' %}bg-green-900/40 text-green-300 border border-green-700/50
                                        {% elseif activity.action == 'LOGOUT' %}bg-gray-700 text-gray-400 border border-gray-600
                                        {% elseif activity.action == 'CREATE' %}bg-blue-900/40 text-blue-300 border border-blue-700/50
                                        {% elseif activity.action == 'UPDATE' %}bg-yellow-900/40 text-yellow-300 border border-yellow-700/50
                                        {% elseif activity.action == 'STATUS_CHANGE' %}bg-purple-900/40 text-purple-300 border border-purple-700/50
                                        {% elseif activity.action == 'STOCK_ADD' %}bg-emerald-900/40 text-emerald-300 border border-emerald-700/50
                                        {% elseif activity.action == 'STOCK_REMOVE' %}bg-orange-900/40 text-orange-300 border border-orange-700/50
                                        {% else %}bg-red-900/40 text-red-300 border border-red-700/50{% endif %}">
                                        {{ activity.action }}
                                    </span>
                                </td>
                                <td class="py-2 px-3 text-black text-sm">{{ activity.details[:50] }}{{ activity.details|length > 50 ? '...' : '' }}</td>
                                <td class="py-2 px-3 text-back text-xs">{{ activity.createdAt|date('m/d H:i') }}</td>
                            </tr>
                        {% endfor %}
                    {% else %}
                        <tr>
                            <td colspan="5" class="py-6 px-4 text-center text-gray-500 text-sm">No recent activities to display</td>
                        </tr>
                    {% endif %}
                </tbody>
            </table>
        </div>
    </div>
    {% endif %}

    <!-- System Status Section -->
    <div class="bg-gray-900/50 backdrop-blur-sm rounded-2xl border border-gray-700/50 shadow-xl p-5 md:p-6 mb-8">
        <h3 class="text-base sm:text-lg font-bold text-yellow-400 mb-4">System Status</h3>
        <div class="grid grid-cols-2 sm:grid-cols-2 lg:grid-cols-4 gap-4">
            <div class="flex justify-between items-center p-3 bg-gray-800/50 rounded-xl border-l-3 border-l-yellow-400">
                <span class="text-gray-300 text-sm font-medium">Application Status</span>
                <span class="text-green-400 font-semibold text-sm">Online</span>
            </div>
            <div class="flex justify-between items-center p-3 bg-gray-800/50 rounded-xl border-l-3 border-l-yellow-400">
                <span class="text-gray-300 text-sm font-medium">Database Status</span>
                <span class="text-green-400 font-semibold text-sm">Connected</span>
            </div>
            <div class="flex justify-between items-center p-3 bg-gray-800/50 rounded-xl border-l-3 border-l-yellow-400">
                <span class="text-gray-300 text-sm font-medium">Server Load</span>
                <span class="text-yellow-400 font-semibold text-sm">Low</span>
            </div>
            <div class="flex justify-between items-center p-3 bg-gray-800/50 rounded-xl border-l-3 border-l-yellow-400">
                <span class="text-gray-300 text-sm font-medium">Response Time</span>
                <span class="text-green-400 font-semibold text-sm">Fast</span>
            </div>
        </div>
    </div>

    <!-- System Footer -->
    <div class="bg-gray-900/50 backdrop-blur-sm rounded-2xl border border-gray-700/50 shadow-xl p-4 text-center">
        <p class="text-gray-500 text-xs">
            Samaco Brewery Management System • v1.0.0 • 
            <span class="text-green-400">● System Online</span> • 
            Last Updated: <span id="lastUpdated" class="text-yellow-400">Just now</span>
        </p>
    </div>
</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        function updateLastUpdated() {
            const lastUpdatedElem = document.getElementById('lastUpdated');
            const now = new Date();
            const options = { month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' };
            lastUpdatedElem.textContent = now.toLocaleDateString(undefined, options);
        }
        updateLastUpdated();
        setInterval(updateLastUpdated, 60000);

        // Notification Banner Functions
        function showNotification(title, message) {
            const banner = document.getElementById('notification-banner');
            const titleElem = document.getElementById('notification-title');
            const messageElem = document.getElementById('notification-message');
            
            titleElem.textContent = title;
            messageElem.textContent = message;
            banner.classList.remove('hidden');
            
            // Auto-hide after 5 seconds
            setTimeout(hideNotification, 5000);
        }

        function hideNotification() {
            const banner = document.getElementById('notification-banner');
            banner.classList.add('hidden');
        }

        // Mercure WebSocket Connection for Real-time Notifications
        (function() {
            const dashboard = document.querySelector('[data-mercure-url]');
            if (!dashboard) {
                console.error('[MERCURE] Dashboard element not found');
                return;
            }

            const mercureUrl = dashboard.getAttribute('data-mercure-url');
            console.log('[MERCURE] Mercure URL from data attribute:', mercureUrl);

            if (!mercureUrl) {
                console.error('[MERCURE] Mercure URL is empty');
                return;
            }

            console.log('[MERCURE] Attempting to connect to:', mercureUrl);

            try {
                const eventSource = new EventSource(mercureUrl);

                eventSource.onmessage = (event) => {
                    console.log('[MERCURE] Received event:', event.data);
                    try {
                        const order = JSON.parse(event.data);

                        if (order.updatedAt) {
                            showNotification('Order Updated', `Order #${order.id} status changed to ${order.status}`);
                            // Reload the page to show updated orders
                            setTimeout(() => location.reload(), 2000);
                        } else {
                            showNotification('New Order', `Order #${order.orderNumber} from ${order.customerName} - ₱${order.total}`);
                            // Reload the page to show new orders
                            setTimeout(() => location.reload(), 2000);
                        }

                        // Play notification sound
                        try {
                            const audio = new Audio('/sounds/notification.mp3');
                            audio.play().catch(e => console.log('Audio play failed:', e));
                        } catch (e) {
                            console.log('Audio not available:', e);
                        }
                    } catch (parseError) {
                        console.error('[MERCURE] Failed to parse event data:', parseError);
                    }
                };

                eventSource.onerror = (error) => {
                    console.error('[MERCURE] Connection error:', error);
                    console.error('[MERCURE] EventSource readyState:', eventSource.readyState);
                    // Don't close on error, let it retry
                    // eventSource.close();
                };

                eventSource.onopen = () => {
                    console.log('[MERCURE] Connected successfully to:', mercureUrl);
                };
            } catch (error) {
                console.error('[MERCURE] Failed to create EventSource:', error);
            }
        })();
    </script>
{% endblock %}