{% extends 'base.html.twig' %}

{% block title %}Dashboard{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        /* Mobile menu toggle */
        .mobile-menu-toggle {
            display: none;
            position: fixed;
            top: 15px;
            left: 15px;
            z-index: 1001;
            background: #000;
            border: 2px solid #FFD700;
            color: #FFD700;
            padding: 10px 15px;
            border-radius: 8px;
            cursor: pointer;
            font-size: 24px;
            font-weight: bold;
        }
        
        /* Sidebar */
        .sidebar-container {
            background: linear-gradient(180deg, #000000 0%, #1a1a1a 100%);
            border-right: 3px solid #FFD700;
            box-shadow: 4px 0 15px rgba(0, 0, 0, 0.3);
            position: fixed;
            top: 0;
            left: 0;
            width: 280px;
            height: 100vh;
            display: flex;
            flex-direction: column;
            z-index: 1000;
            overflow: hidden;
            transition: transform 0.3s ease;
        }
        
        /* Mobile state - hidden by default */
        @media (max-width: 1024px) {
            .sidebar-container {
                transform: translateX(-100%);
            }
            
            .sidebar-container.mobile-open {
                transform: translateX(0);
            }
        }
        
        /* Desktop - always visible */
        @media (min-width: 1025px) {
            .sidebar-container {
                transform: translateX(0) !important;
            }
        }
        
        .sidebar-container::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 4px;
            background: linear-gradient(90deg, #FFD700, #32CD32, #FFD700);
            z-index: 10;
        }
        
        .sidebar-content {
            flex: 1;
            display: flex;
            flex-direction: column;
            padding: 0.75rem;
            overflow-y: hidden;
        }
        
        
        .logo-container {
            background: linear-gradient(145deg, #FFD700 0%, #FFC107 100%);
            padding: 0.75rem;
            border-radius: 10px;
            margin: 0.5rem 0.5rem 1rem 0.5rem;
            box-shadow: 0 3px 10px rgba(255, 215, 0, 0.3);
            text-align: center;
        }
        
        .logo-img {
            max-width: 140px;
            height: auto;
            margin: 0 auto;
        }
        
        .nav-sections-container {
            flex: 1;
            margin-bottom: 0.5rem;
        }
        
        .user-section {
            background: rgba(255, 215, 0, 0.1);
            border-radius: 8px;
            margin: 0.5rem;
            padding: 0.75rem;
            border: 1px solid rgba(255, 215, 0, 0.2);
            flex-shrink: 0;
        }
        
        .nav-title {
            display: none;
        }
        
        .nav-section {
            margin-bottom: 0.75rem;
        }
        
        .nav-link {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            color: #e2e8f0;
            padding: 0.6rem 0.75rem;
            margin: 0.15rem 0;
            border-radius: 6px;
            text-decoration: none;
            transition: all 0.2s ease;
            font-size: 0.85rem;
            position: relative;
            overflow: hidden;
            animation: slideIn 0.3s ease-out forwards;
            opacity: 0;
        }
        
        .nav-link:nth-child(1) { animation-delay: 0.1s; }
        .nav-link:nth-child(2) { animation-delay: 0.15s; }
        .nav-link:nth-child(3) { animation-delay: 0.2s; }
        .nav-link:nth-child(4) { animation-delay: 0.25s; }
        .nav-link:nth-child(5) { animation-delay: 0.3s; }
        .nav-link:nth-child(6) { animation-delay: 0.35s; }
        .nav-link:nth-child(7) { animation-delay: 0.4s; }
        .nav-link:nth-child(8) { animation-delay: 0.45s; }
        
        .nav-link::before {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(255, 215, 0, 0.15), transparent);
            transition: left 0.5s ease;
            z-index: 1;
        }
        
        .nav-link:hover::before {
            left: 100%;
        }
        
        .nav-link:hover {
            background: linear-gradient(90deg, rgba(255, 215, 0, 0.15), rgba(255, 215, 0, 0.05));
            color: #FFD700;
            transform: translateX(5px);
        }
        
        .nav-link.active {
            background: linear-gradient(90deg, rgba(255, 215, 0, 0.25), rgba(255, 215, 0, 0.15));
            color: #FFD700;
            border-left: 3px solid #FFD700;
            box-shadow: inset 0 0 15px rgba(255, 215, 0, 0.1);
        }
        
        .nav-link > span {
            position: relative;
            z-index: 2;
        }
        
        .user-info {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            margin-bottom: 0.5rem;
            padding-bottom: 0.5rem;
            border-bottom: 1px solid rgba(255, 215, 0, 0.2);
        }
        
        .user-avatar {
            width: 30px;
            height: 30px;
            background: linear-gradient(135deg, #FFD700, #FFC107);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #000;
            font-weight: bold;
            font-size: 0.9rem;
            flex-shrink: 0;
        }
        
        .user-email {
            color: #FFD700;
            font-size: 0.75rem;
            font-weight: 500;
            display: block;
            margin-bottom: 0.15rem;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
        }
        
        .user-role {
            display: inline-block;
            padding: 0.1rem 0.4rem;
            background: rgba(50, 205, 50, 0.2);
            color: #32CD32;
            font-size: 0.6rem;
            border-radius: 8px;
            font-weight: 600;
            border: 1px solid rgba(50, 205, 50, 0.3);
        }
        
        .user-role.admin {
            background: rgba(220, 53, 69, 0.2);
            color: #dc3545;
        }
        
        .user-role.staff {
            background: rgba(255, 193, 7, 0.2);
            color: #ffc107;
        }
        
        .user-section .nav-link {
            padding: 0.5rem 0.75rem;
            font-size: 0.8rem;
            margin: 0.1rem 0;
        }
        
        .sidebar-overlay {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(0, 0, 0, 0.8);
            z-index: 999;
        }
        
        .sidebar-overlay.active {
            display: block;
        }
        
        main {
            margin-left: 280px;
            background: #f8f9fa;
            min-height: 100vh;
            padding: 1.5rem;
        }
        
        @keyframes slideIn {
            from {
                opacity: 0;
                transform: translateX(-20px);
            }
            to {
                opacity: 1;
                transform: translateX(0);
            }
        }
        
        @media (max-width: 1024px) {
            .mobile-menu-toggle {
                display: block;
            }
            
            main {
                margin-left: 0 !important;
                padding: 20px;
                padding-top: 70px;
            }
            
            .nav-title {
                display: block;
                color: #FFD700;
                font-size: 0.75rem;
                font-weight: 600;
                text-transform: uppercase;
                letter-spacing: 1px;
                margin-bottom: 0.5rem;
                padding: 0 0.75rem;
            }
            
            .nav-link {
                font-size: 0.9rem;
                padding: 0.75rem;
            }
            
            .logo-container {
                margin: 15px;
                padding: 1rem;
            }
        }
        
        @media (max-width: 480px) {
            .sidebar-container {
                width: 100%;
            }
            
            main {
                padding: 15px;
                padding-top: 60px;
            }
        }
    </style>
{% endblock %}

{% block body %}
<button class="mobile-menu-toggle" id="mobileToggle">
    ☰
</button>

<div class="sidebar-overlay" id="sidebarOverlay"></div>

<div class="min-h-screen">
    <aside class="sidebar-container" id="sidebar">
        <div class="sidebar-content">
            <div class="logo-container">
                <img src="{{ asset('images/logo.png') }}" alt="Samaco Brewery Logo" class="logo-img">
            </div>
            
            <div class="nav-sections-container">
                <div class="nav-section">
                    <div class="nav-title">Dashboard</div>
                    <a href="{{ path('app_dashboard_home') }}" 
                       class="nav-link {% if app.request.get('_route') == 'app_dashboard_home' %}active{% endif %}">
                        <span>🏠</span>
                        <span>Home</span>
                    </a>
                </div>

                {% if is_granted('ROLE_ADMIN') or is_granted('ROLE_STAFF') %}
                <div class="nav-section">
                    <div class="nav-title">Brewery Management</div>
                    <a href="{{ path('app_product_index') }}" 
                       class="nav-link {% if app.request.get('_route') == 'app_product_index' %}active{% endif %}">
                        <span>🍺</span>
                        <span>Products</span>
                    </a>
                    <a href="{{ path('app_customer_index') }}" 
                       class="nav-link {% if app.request.get('_route') == 'app_customer_index' %}active{% endif %}">
                        <span>👥</span>
                        <span>Customers</span>
                    </a>
                    <a href="{{ path('app_order_index') }}" 
                       class="nav-link {% if app.request.get('_route') == 'app_order_index' %}active{% endif %}">
                        <span>📦</span>
                        <span>Orders</span>
                    </a>
                    <a href="{{ path('app_stock_index') }}" 
                       class="nav-link {% if app.request.get('_route') == 'app_stock_index' %}active{% endif %}">
                        <span>📊</span>
                        <span>Stock</span>
                    </a>
                </div>
                {% endif %}

                {% if is_granted('ROLE_ADMIN') %}
                <div class="nav-section">
                    <div class="nav-title">System Administration</div>
                    <a href="{{ path('app_category_index') }}" 
                       class="nav-link {% if app.request.get('_route') == 'app_category_index' %}active{% endif %}">
                        <span>🏷️</span>
                        <span>Categories</span>
                    </a>
                    <a href="{{ path('app_user_index') }}" 
                       class="nav-link {% if app.request.get('_route') == 'app_user_index' %}active{% endif %}">
                        <span>👨‍💼</span>
                        <span>Manage Users</span>
                    </a>
                    <a href="{{ path('app_activity_log_index') }}" 
                       class="nav-link {% if app.request.get('_route') == 'app_activity_log_index' %}active{% endif %}">
                        <span>📊</span>
                        <span>Activity Logs</span>
                    </a>
                </div>
                {% endif %}
            </div>

            <div class="user-section">
                <div class="user-info">
                    <div class="user-avatar">{{ app.user.email|first|upper }}</div>
                    <div class="user-details">
                        <span class="user-email">{{ app.user.email }}</span>
                        {% if is_granted('ROLE_ADMIN') %}
                            <span class="user-role admin">ADMIN</span>
                        {% elseif is_granted('ROLE_STAFF') %}
                            <span class="user-role staff">STAFF</span>
                        {% else %}
                            <span class="user-role">USER</span>
                        {% endif %}
                    </div>
                </div>
                
                <div>
                    <a href="{{ path('app_profile_index') }}" class="nav-link">
                        <span>👤</span>
                        <span>My Profile</span>
                    </a>
                    <a href="{{ path('app_logout') }}" class="nav-link">
                        <span>🚪</span>
                        <span>Logout</span>
                    </a>
                </div>
            </div>
        </div>
    </aside>

    <main>
        {% block dashboard_content %}{% endblock %}
    </main>
</div>

{% block javascripts %}
    {{ parent() }}
    <script>
        (function() {
            // Wait for DOM to be ready
            function init() {
                var sidebar = document.getElementById('sidebar');
                var toggle = document.getElementById('mobileToggle');
                var overlay = document.getElementById('sidebarOverlay');
                
                // console.log('Sidebar found:', sidebar);
                // console.log('Toggle found:', toggle);
                // console.log('Overlay found:', overlay);
                
                if (!sidebar || !toggle) {
                    console.error('Missing elements!');
                    return;
                }
                
                function openSidebar() {
                    sidebar.classList.add('mobile-open');
                    if (overlay) overlay.classList.add('active');
                    document.body.style.overflow = 'hidden';
                    //console.log('Sidebar opened');
                }
                
                function closeSidebar() {
                    sidebar.classList.remove('mobile-open');
                    if (overlay) overlay.classList.remove('active');
                    document.body.style.overflow = '';
                    //console.log('Sidebar closed');
                }
                
                // Toggle function
                toggle.onclick = function(e) {
                    e.preventDefault();
                    e.stopPropagation();
                    //console.log('Toggle clicked!');
                    if (sidebar.classList.contains('mobile-open')) {
                        closeSidebar();
                    } else {
                        openSidebar();
                    }
                };
                
                // Overlay click
                if (overlay) {
                    overlay.onclick = function() {
                        closeSidebar();
                    };
                }
                
                // Close on escape key
                document.onkeydown = function(e) {
                    if (e.key === 'Escape' && sidebar.classList.contains('mobile-open')) {
                        closeSidebar();
                    }
                };
            }
            
            // Run when DOM is ready
            if (document.readyState === 'loading') {
                document.addEventListener('DOMContentLoaded', init);
            } else {
                init();
            }
        })();
    </script>
{% endblock %}
{% endblock %}