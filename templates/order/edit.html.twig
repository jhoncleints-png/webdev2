{% extends 'layout.html.twig' %}

{% block title %}Edit Order - Samaco Brewery{% endblock %}

{% block dashboard_content %}
{% if order.status == constant('App\\Entity\\Order::STATUS_DELIVERED') or order.status == constant('App\\Entity\\Order::STATUS_CANCELLED') %}
    <!-- Show message if order is delivered or cancelled -->
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
        <div class="bg-red-900/20 border border-red-800/30 rounded-2xl p-8 text-center">
            <svg class="w-16 h-16 text-red-400 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.282 16.5c-.77.833.192 2.5 1.732 2.5z"></path>
            </svg>
            <h2 class="text-2xl font-bold text-red-400 mb-4">Cannot Edit Order</h2>
            <p class="text-gray-300 mb-6">This order is already <span class="font-semibold text-red-300">{{ order.getStatusLabel() }}</span>. Delivered and cancelled orders cannot be edited.</p>
            <a href="{{ path('app_order_show', {'id': order.id}) }}" 
               class="inline-flex items-center gap-2 px-6 py-3 text-sm font-semibold 
                      bg-gray-800 text-gray-300 rounded-xl hover:bg-gray-700 
                      transition-all duration-200 border border-gray-700">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
                </svg>
                Back to Order Details
            </a>
        </div>
    </div>
{% else %}
    <!-- Edit form for pending orders -->
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
        
        <!-- Page Header -->
        <div class="mb-8">
            <!-- Breadcrumb -->
            <nav class="flex items-center gap-2 text-sm text-gray-400 mb-6">
                <a href="{{ path('app_dashboard_home') }}" 
                   class="hover:text-yellow-400 transition-colors duration-200">
                    Dashboard
                </a>
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                </svg>
                <a href="{{ path('app_order_index') }}" 
                   class="hover:text-yellow-400 transition-colors duration-200">
                    Orders
                </a>
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                </svg>
                <span class="text-yellow-400 font-medium">Edit Order</span>
            </nav>
            
            <!-- Main Heading -->
            <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
                <div>
                    <h1 class="text-3xl md:text-4xl font-bold text-black mb-2 flex items-center gap-3">
                        <svg class="w-8 h-8 text-yellow-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
                        </svg>
                        Edit Order
                    </h1>
                    <p class="text-gray-400 ml-11">
                        Update order details and information
                    </p>
                </div>
                
                <!-- Back Button -->
                <a href="{{ path('app_order_index') }}"
                   class="inline-flex items-center gap-2 px-5 py-3 text-sm font-semibold text-white 
                           bg-gray-700 rounded-xl hover:bg-gray-600 hover:text-white transition-all duration-200
                           border border-gray-600 focus:outline-none focus:ring-2 focus:ring-yellow-500 focus:ring-offset-2 focus:ring-offset-gray-900
                           self-start sm:self-center shadow-md">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
                    </svg>
                    Back to Orders
                </a>
            </div>
        </div>

        <!-- Single Grey Outer Box -->
        <div class="bg-gray-900/50 backdrop-blur-sm rounded-2xl border border-gray-700/50 shadow-xl p-6 md:p-8">
            
            <!-- Form Section -->
            <div class="mb-8">
                <div class="mb-6">
                    <h2 class="text-2xl font-bold text-yellow-400 mb-2 flex items-center gap-3">
                        <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
                        </svg>
                        Order Information
                    </h2>
                    <p class="text-gray-400">Modify the order details and status</p>
                </div>
                
                <!-- Include Form -->
                <div class="max-w-4xl mx-auto">
                    {{ include('order/_form.html.twig', {'button_label': 'Update Order'}) }}
                </div>
            </div>

            <!-- Danger Zone -->
            <div class="pt-8 border-t border-gray-700">
                <div class="mb-6">
                    <div class="flex items-center gap-3 mb-2">
                        <svg class="w-7 h-7 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.282 16.5c-.77.833.192 2.5 1.732 2.5z"></path>
                        </svg>
                        <h2 class="text-2xl font-bold text-red-400">Danger Zone</h2>
                    </div>
                    <p class="text-gray-400 ml-10">Irreversible actions that will permanently delete this order</p>
                </div>
                
                <!-- Delete Form - Black inner box -->
                <div class="bg-gray-900 rounded-xl border border-gray-700 p-6">
                    {{ include('order/_delete_form.html.twig') }}
                </div>
            </div>

        </div>
    </div>
{% endif %}
{% endblock %}