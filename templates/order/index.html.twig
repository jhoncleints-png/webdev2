{% extends 'layout.html.twig' %}

{% block title %}Orders - Samaco Brewery{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <!-- DataTables CSS -->
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css">
    
    <style>
        .dataTables_paginate .paginate_button {
            display: inline-block !important;
            margin: 0 2px !important;
        }

        .dataTables_paginate {
            display: flex !important;
            flex-wrap: wrap !important;
            justify-content: flex-end !important;
            align-items: center !important;
            gap: 4px !important;
        }

        .dataTables_info {
            display: flex !important;
            align-items: center !important;
        }
    </style>
{% endblock %}

{% block dashboard_content %}
<div class="container mx-auto px-4 py-8">
    <!-- Page Header -->
    <div class="bg-gradient-to-r from-black to-gray-900 rounded-lg border-l-4 border-yellow-500 p-6 mb-6 shadow-lg">
        <h1 class="text-3xl font-bold text-yellow-500 mb-1">📦 Orders</h1>
        <p class="text-gray-400">Manage customer orders and track order status</p>
    </div>

    <!-- Top Actions -->
    <div class="mb-4">
        <a href="{{ path('app_order_new') }}" class="inline-flex items-center gap-2 px-6 py-3 bg-gradient-to-r from-yellow-500 to-yellow-300 text-black font-semibold rounded-lg hover:scale-105 transition duration-200 shadow-lg shadow-yellow-500/25">
            <span>+</span>
            <span>Create New Order</span>
        </a>
    </div>

    <!-- Advanced Filters -->
    <div class="bg-gray-800/80 rounded-lg border border-yellow-500/15 p-5 mb-6 shadow-lg">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
            <div>
                <label for="searchOrderNumber" class="block text-yellow-500 text-sm font-semibold mb-2">Order Number</label>
                <input type="text" id="searchOrderNumber" class="w-full px-3 py-2 bg-gray-700 border border-yellow-500/30 rounded-md text-white focus:outline-none focus:ring-2 focus:ring-yellow-500" placeholder="Search by order #...">
            </div>
            
            <div>
                <label for="searchCustomer" class="block text-yellow-500 text-sm font-semibold mb-2">Customer</label>
                <input type="text" id="searchCustomer" class="w-full px-3 py-2 bg-gray-700 border border-yellow-500/30 rounded-md text-white focus:outline-none focus:ring-2 focus:ring-yellow-500" placeholder="Search by customer...">
            </div>
            
            <div>
                <label for="filterStatus" class="block text-yellow-500 text-sm font-semibold mb-2">Status</label>
                <select id="filterStatus" class="w-full px-3 py-2 bg-gray-700 border border-yellow-500/30 rounded-md text-white focus:outline-none focus:ring-2 focus:ring-yellow-500">
                    <option value="">All Status</option>
                    <option value="PENDING">Pending</option>
                    <option value="DELIVERED">Delivered</option>
                    <option value="CANCELLED">Cancelled</option>
                </select>
            </div>
            
            <div>
                <label for="filterDate" class="block text-yellow-500 text-sm font-semibold mb-2">Date Range</label>
                <input type="date" id="filterDate" class="w-full px-3 py-2 bg-gray-700 border border-yellow-500/30 rounded-md text-white focus:outline-none focus:ring-2 focus:ring-yellow-500">
            </div>
        </div>
        
        <div class="mt-4">
            <button id="resetFilters" class="px-5 py-2 bg-gray-700 text-gray-400 border border-gray-500 rounded-md font-semibold hover:bg-gray-600 hover:text-white transition-all duration-200">
                Reset All Filters
            </button>
        </div>
    </div>

    <!-- Orders Table -->
    <div class="bg-gray-800/80 rounded-lg shadow-lg p-6">
        {% if orders is empty %}
            <div class="text-center py-12">
                <div class="text-5xl mb-3 opacity-60">📦</div>
                <h3 class="text-yellow-500 text-xl mb-2">No Orders Found</h3>
                <p class="text-yellow-500/70">Create your first order to get started!</p>
                <a href="{{ path('app_order_new') }}" class="inline-flex items-center gap-2 px-6 py-3 mt-4 bg-gradient-to-r from-yellow-500 to-yellow-300 text-black font-semibold rounded-lg hover:scale-105 transition duration-200">
                    <span>+</span>
                    <span>Create First Order</span>
                </a>
            </div>
        {% else %}
            <table id="orderTable" class="display w-full" data-order-count="{{ orders|length }}">
                <thead>
                    <tr class="bg-yellow-500/15">
                        <th class="px-4 py-3 text-left text-xs font-semibold text-yellow-500 uppercase tracking-wider">Order #</th>
                        <th class="px-4 py-3 text-left text-xs font-semibold text-yellow-500 uppercase tracking-wider">Customer</th>
                        <th class="px-4 py-3 text-left text-xs font-semibold text-yellow-500 uppercase tracking-wider">Date</th>
                        <th class="px-4 py-3 text-left text-xs font-semibold text-yellow-500 uppercase tracking-wider">Total</th>
                        <th class="px-4 py-3 text-left text-xs font-semibold text-yellow-500 uppercase tracking-wider">Status</th>
                        <th class="px-4 py-3 text-left text-xs font-semibold text-yellow-500 uppercase tracking-wider">Created By</th>
                        <th class="px-4 py-3 text-left text-xs font-semibold text-yellow-500 uppercase tracking-wider">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for order in orders %}
                        <tr class="border-b border-gray-700 hover:bg-yellow-500/10 transition-colors">
                            <td class="px-4 py-3 text-sm text-white font-medium">{{ order.orderNumber }}</td>
                            <td class="px-4 py-3 text-sm text-gray-300">{{ order.customer.name }}</td>
                            <td class="px-4 py-3 text-sm text-gray-300">{{ order.orderDate|date('Y-m-d H:i') }}</td>
                            <td class="px-4 py-3 text-sm text-yellow-500 font-bold">${{ order.totalAmount|number_format(2) }}</td>
                            <td class="px-4 py-3">
                                {% set statusValue = order.status|upper %}
                                {% if statusValue == 'PENDING' %}
                                    <span style="display: inline-block; padding: 0.25rem 0.75rem; border-radius: 9999px; font-size: 0.75rem; font-weight: 600; background-color: #fbbf24; color: #78350f;">
                                        {{ order.getStatusLabel() }}
                                    </span>
                                {% elseif statusValue == 'DELIVERED' %}
                                    <span style="display: inline-block; padding: 0.25rem 0.75rem; border-radius: 9999px; font-size: 0.75rem; font-weight: 600; background-color: #22c55e; color: #14532d;">
                                        {{ order.getStatusLabel() }}
                                    </span>
                                {% elseif statusValue == 'CANCELLED' %}
                                    <span style="display: inline-block; padding: 0.25rem 0.75rem; border-radius: 9999px; font-size: 0.75rem; font-weight: 600; background-color: #ef4444; color: #7f1a1a;">
                                        {{ order.getStatusLabel() }}
                                    </span>
                                {% else %}
                                    <span style="display: inline-block; padding: 0.25rem 0.75rem; border-radius: 9999px; font-size: 0.75rem; font-weight: 600; background-color: #6b7280; color: #1f2937;">
                                        {{ order.status }} (Raw: {{ order.status }})
                                    </span>
                                {% endif %}
                            </td>
                            <td class="px-4 py-3">
                                {% if order.createdBy %}
                                    <span class="inline-flex items-center gap-1 px-2 py-1 rounded-full text-xs font-semibold bg-gray-700 text-gray-300 border border-gray-500/50">
                                        {{ order.createdBy.email }}
                                    </span>
                                {% else %}
                                    <span class="text-gray-500 text-sm">-</span>
                                {% endif %}
                            </td>
                            <td class="px-4 py-3">
                                <div class="flex gap-2 flex-wrap">
                                    <a href="{{ path('app_order_show', {'id': order.id}) }}" class="inline-flex items-center gap-1 px-3 py-1.5 bg-teal-900/30 text-teal-300 border border-teal-500/50 rounded-md text-xs font-semibold hover:bg-teal-900/50 transition">
                                        👁️ View
                                    </a>
                                    
                                    {% if (is_granted('ROLE_ADMIN') or (is_granted('ROLE_STAFF') and order.createdBy and order.createdBy.id == app.user.id)) and order.status == constant('App\\Entity\\Order::STATUS_PENDING') %}
                                        <a href="{{ path('app_order_edit', {'id': order.id}) }}" class="inline-flex items-center gap-1 px-3 py-1.5 bg-blue-900/30 text-blue-300 border border-blue-500/50 rounded-md text-xs font-semibold hover:bg-blue-900/50 transition">
                                            ✏️ Edit
                                        </a>
                                    {% endif %}
                                    
                                    {% if is_granted('ROLE_ADMIN') %}
                                        <form method="post" action="{{ path('app_order_delete', {'id': order.id}) }}" onsubmit="return confirm('Are you sure you want to delete this order? This action cannot be undone.');" style="display: inline;">
                                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ order.id) }}">
                                            <button type="submit" class="inline-flex items-center gap-1 px-3 py-1.5 bg-red-900/30 text-red-300 border border-red-500/50 rounded-md text-xs font-semibold hover:bg-red-900/50 transition cursor-pointer">
                                                🗑️ Delete
                                            </button>
                                        </form>
                                    {% endif %}
                                </div>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        {% endif %}
    </div>
</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    
    <!-- DataTables JS -->
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>
    
    <script>
    document.addEventListener('DOMContentLoaded', function() {
        if ($('#orderTable').length && !$.fn.DataTable.isDataTable('#orderTable')) {
            window.orderTable = $('#orderTable').DataTable({
                paging: true,
                pageLength: 10,
                lengthMenu: [[10, 25, 50, 100], [10, 25, 50, 100]],
                searching: true,
                ordering: true,
                order: [[2, 'desc']],
                responsive: true,
                autoWidth: false,
                language: {
                    search: "Search:",
                    searchPlaceholder: "Type to search...",
                    lengthMenu: "Show _MENU_ entries",
                    info: "Showing _START_ to _END_ of _TOTAL_ orders",
                    infoEmpty: "Showing 0 to 0 of 0 orders",
                    infoFiltered: "(filtered from _MAX_ total orders)",
                    zeroRecords: "No matching orders found",
                    paginate: {
                        first: "« First",
                        last: "Last »",
                        next: "Next →",
                        previous: "← Previous"
                    }
                },
                dom: '<"flex flex-wrap justify-between items-center mb-4"l<"ml-auto"f>>rt<"flex flex-wrap justify-between items-center mt-4"ip>',
            });
            
            // Filters
            $('#searchOrderNumber').on('keyup', function() {
                window.orderTable.column(0).search(this.value).draw();
            });
            
            $('#searchCustomer').on('keyup', function() {
                window.orderTable.column(1).search(this.value).draw();
            });
            
            $('#filterStatus').on('change', function() {
                var statusFilter = this.value;
                if (window.orderTable) {
                    if (statusFilter) {
                        // Filter by the text content of the status column
                        window.orderTable.column(4).search(statusFilter, false, false).draw();
                    } else {
                        window.orderTable.column(4).search('').draw();
                    }
                }
            });
            
            $('#filterDate').on('change', function() {
                var dateFilter = this.value;
                if (dateFilter) {
                    window.orderTable.column(2).search('^' + dateFilter, true, false).draw();
                } else {
                    window.orderTable.column(2).search('').draw();
                }
            });
            
            $('#resetFilters').on('click', function() {
                $('#searchOrderNumber').val('');
                $('#searchCustomer').val('');
                $('#filterStatus').val('');
                $('#filterDate').val('');
                if (window.orderTable) {
                    window.orderTable.search('');
                    window.orderTable.columns().search('');
                    window.orderTable.draw();
                }
            });
        }

        // Polling for new orders - eliminates F5 for admin
        var currentOrderIds = new Set();
        // Initialize with current order IDs from the table
        var rows = document.querySelectorAll('#orderTable tbody tr');
        for (var i = 0; i < rows.length; i++) {
            var row = rows[i];
            var firstCell = row.querySelector('td:first-child');
            if (firstCell) {
                var orderNumber = firstCell.textContent ? firstCell.textContent.trim() : '';
                if (orderNumber) {
                    currentOrderIds.add(orderNumber);
                }
            }
        }

        // SSE for real-time order updates
        var eventSource = new EventSource('/api/orders/events');
        
        eventSource.addEventListener('connected', function(event) {
            console.log('[SSE] Connected to server:', event.data);
        });
        
        eventSource.addEventListener('order_update', function(event) {
            console.log('[SSE] Order update received:', event.data);
            var data = JSON.parse(event.data);
            
            if (data.type === 'new_order') {
                showNotification('📦 New order received!', 'success');
                setTimeout(function() { location.reload(); }, 2000);
            } else if (data.type === 'status_change') {
                showNotification('📝 Order status updated', 'info');
                setTimeout(function() { location.reload(); }, 2000);
            }
        });
        
        eventSource.onerror = function(error) {
            console.error('[SSE] Connection error:', error);
            eventSource.close();
            // Reconnect after 5 seconds
            setTimeout(function() {
                console.log('[SSE] Reconnecting...');
                location.reload();
            }, 5000);
        };

        function showNotification(message, type) {
            var toast = document.createElement('div');
            toast.className = 'toast toast-' + type;
            toast.innerHTML = message;
            toast.style.cssText = 'position: fixed; top: 20px; right: 20px; background: #4CAF50; color: white; padding: 12px 20px; border-radius: 8px; z-index: 9999; animation: slideIn 0.3s ease; box-shadow: 0 4px 6px rgba(0,0,0,0.3);';
            document.body.appendChild(toast);
            setTimeout(function() { toast.remove(); }, 3000);
        }
    });
</script>
{% endblock %}