{% extends 'layout.html.twig' %}

{% block title %}New Order - Samaco Brewery{% endblock %}

{% block dashboard_content %}
<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
    
    <div class="mb-8">
        <nav class="flex items-center gap-2 text-sm text-black-400 mb-6">
            <a href="{{ path('app_dashboard_home') }}" 
               class="hover:text-yellow-400 transition-colors duration-200">
                Dashboard
            </a>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
            </svg>
            <a href="{{ path('app_order_index') }}" 
               class="hover:text-yellow-400 transition-colors duration-200">
                Orders
            </a>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
            </svg>
            <span class="text-yellow-400 font-medium">New Order</span>
        </nav>
        
        <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
            <div>
                <h1 class="text-3xl md:text-4xl font-bold text-black mb-2">
                    Create New Order
                </h1>
                <p class="text-black-400">
                    Create a new order for your brewery customers
                </p>
            </div>
            
            <a href="{{ path('app_order_index') }}"
               class="inline-flex items-center gap-2 px-5 py-3 text-sm font-semibold text-white 
                      bg-gray-700 rounded-xl hover:bg-gray-600 hover:text-white transition-all duration-200
                      border border-gray-600 focus:outline-none focus:ring-2 focus:ring-yellow-500 focus:ring-offset-2 focus:ring-offset-gray-900
                      self-start sm:self-center shadow-md">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
                </svg>
                Back to Orders
            </a>
        </div>
    </div>

    <!-- Grey Outer Box -->
    <div class="bg-gray-900/50 backdrop-blur-sm rounded-2xl border border-gray-700/50 shadow-xl p-6 md:p-8">
        <div class="mb-8">
            <h2 class="text-2xl font-bold text-yellow-400 mb-2 flex items-center gap-3">
                <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
                </svg>
                Order Details
            </h2>
            <p class="text-black-400">Fill in the details for your new order</p>
        </div>
        
        <!-- Black Inner Box -->
        <div class="bg-gray-900 rounded-xl border border-gray-700 p-6 md:p-8">
            {{ form_start(form, {'attr': {'class': 'space-y-8', 'id': 'order-form'}}) }}
                
                <div>
                    {{ form_label(form.customer, 'Customer', {'label_attr': {'class': 'block text-sm font-semibold text-yellow-300 mb-2'}})}}
                    {{ form_widget(form.customer, {'attr': {'class': 'w-full px-4 py-3.5 bg-gray-800/50 border border-gray-700 rounded-xl text-white placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-yellow-500 focus:border-yellow-500 transition duration-200 hover:border-gray-600 text-base'}})}}
                    {{ form_errors(form.customer) }}
                </div>

                <div>
                    <h3 class="text-xl font-bold text-yellow-400 mb-2">Order Items</h3>
                    <p class="text-yellow-500 text-sm mb-4">⚠️ Stock will be deducted automatically when order is created.</p>
                    
                    <div id="order-items" class="space-y-4"></div>
                    
                    <div id="item-template" class="hidden">
                        <div class="order-item bg-gray-800/50 border border-gray-700 rounded-xl p-4">
                            <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-4">
                                <div>
                                    <label class="block text-sm font-semibold text-yellow-300 mb-2">Product</label>
                                    <select name="order[orderItems][__index__][product]" class="product-select w-full px-4 py-3 bg-gray-800/50 border border-gray-700 rounded-xl text-white focus:outline-none focus:ring-2 focus:ring-yellow-500 focus:border-yellow-500 transition duration-200 hover:border-gray-600">
                                        <option value="">Select Product</option>
                                        {% for product in products %}
                                            <option value="{{ product.id }}" data-price="{{ product.price }}" data-stock="{{ product.stockQuantity }}">
                                                {{ product.name }} - ${{ product.price|number_format(2) }} (Stock: {{ product.stockQuantity }})
                                            </option>
                                        {% endfor %}
                                    </select>
                                </div>
                                <div>
                                    <label class="block text-sm font-semibold text-yellow-300 mb-2">Quantity</label>
                                    <input type="number" name="order[orderItems][__index__][quantity]" class="quantity-input w-full px-4 py-3 bg-gray-800/50 border border-gray-700 rounded-xl text-white focus:outline-none focus:ring-2 focus:ring-yellow-500 focus:border-yellow-500 transition duration-200 hover:border-gray-600" min="1" value="1">
                                </div>
                                <div>
                                    <label class="block text-sm font-semibold text-yellow-300 mb-2">Unit Price</label>
                                    <input type="text" name="order[orderItems][__index__][unitPrice]" class="unit-price-input w-full px-4 py-3 bg-gray-800/30 border border-gray-700/50 rounded-xl text-gray-400 cursor-not-allowed" readonly value="0.00">
                                </div>
                            </div>
                            <button type="button" class="remove-item text-red-400 hover:text-red-300 text-sm font-semibold">Remove Item</button>
                        </div>
                    </div>
                    
                    <button type="button" id="add-first-item" class="mt-3 text-yellow-500 hover:text-yellow-400 font-semibold">+ Add First Item</button>
                    <button type="button" id="add-item" class="hidden mt-3 text-yellow-500 hover:text-yellow-400 font-semibold">+ Add Another Item</button>
                </div>

                <div class="bg-yellow-900/20 border border-yellow-800/30 rounded-2xl p-6">
                    <div class="flex justify-between items-center">
                        <h3 class="text-lg font-bold text-yellow-300">Order Total</h3>
                        <div class="text-3xl font-bold text-white">$<span id="order-total">0.00</span></div>
                    </div>
                </div>

                <div>
                    {{ form_label(form.status, 'Order Status', {'label_attr': {'class': 'block text-sm font-semibold text-yellow-300 mb-2'}})}}
                    {{ form_widget(form.status, {'attr': {'class': 'w-full px-4 py-3.5 bg-gray-800/50 border border-gray-700 rounded-xl text-white focus:outline-none focus:ring-2 focus:ring-yellow-500 focus:border-yellow-500 transition duration-200 hover:border-gray-600 text-base'}})}}
                    {{ form_errors(form.status) }}
                </div>

                <div>
                    {{ form_label(form.notes, 'Order Notes', {'label_attr': {'class': 'block text-sm font-semibold text-yellow-300 mb-2'}})}}
                    {{ form_widget(form.notes, {'attr': {'class': 'w-full px-4 py-3.5 bg-gray-800/50 border border-gray-700 rounded-xl text-white placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-yellow-500 focus:border-yellow-500 transition duration-200 hover:border-gray-600 resize-y min-h-[120px] text-base', 'rows': 4, 'placeholder': 'Add any special instructions or notes for this order...'}})}}
                    {{ form_errors(form.notes) }}
                </div>

                <input type="hidden" id="items-count" name="items-count" value="0">

                <div class="flex flex-col sm:flex-row gap-4 pt-8 border-t border-gray-700">
                    <button type="submit" class="group inline-flex items-center justify-center gap-3 px-8 py-4 text-base font-bold bg-yellow-500 text-black rounded-xl hover:bg-yellow-400 active:scale-[0.98] shadow-lg hover:shadow-xl shadow-yellow-500/25 transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-yellow-500 focus:ring-offset-2 focus:ring-offset-gray-900 flex-1 sm:flex-none min-h-[52px]">
                        <svg class="w-5 h-5 transition-transform group-hover:scale-110" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                        </svg>
                        <span>Create Order</span>
                    </button>
                    
                    <a href="{{ path('app_order_index') }}" class="inline-flex items-center justify-center gap-3 px-8 py-4 text-base font-semibold bg-gray-600 text-white rounded-xl hover:bg-gray-500 hover:text-white active:scale-[0.98] border border-gray-500/50 transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-gray-500 focus:ring-offset-2 focus:ring-offset-gray-900 flex-1 sm:flex-none min-h-[52px]">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                        </svg>
                        <span>Cancel</span>
                    </a>
                </div>
            {{ form_end(form) }}
        </div>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    var itemCount = 0;
    
    function getStockData() {
        var stock = {};
        var options = document.querySelectorAll('.product-select option');
        for (var i = 0; i < options.length; i++) {
            var opt = options[i];
            if (opt.value) {
                stock[opt.value] = parseInt(opt.getAttribute('data-stock')) || 0;
            }
        }
        return stock;
    }
    
    function calculateTotal() {
        var total = 0;
        var items = document.querySelectorAll('.order-item');
        for (var i = 0; i < items.length; i++) {
            var qty = parseFloat(items[i].querySelector('.quantity-input').value) || 0;
            var price = parseFloat(items[i].querySelector('.unit-price-input').value) || 0;
            total = total + (qty * price);
        }
        var totalSpan = document.getElementById('order-total');
        if (totalSpan) totalSpan.innerText = total.toFixed(2);
    }
    
    function checkStock(productSelect, quantityInput) {
        var stockData = getStockData();
        var productId = productSelect.value;
        var available = stockData[productId] || 0;
        var requested = parseInt(quantityInput.value) || 0;
        
        if (requested > available && available > 0) {
            alert('Not enough stock! Only ' + available + ' units available for ' + productSelect.options[productSelect.selectedIndex].text.split(' -')[0]);
            quantityInput.value = available;
            calculateTotal();
        }
    }
    
    function addItemEventListeners(item) {
        var productSelect = item.querySelector('.product-select');
        var quantityInput = item.querySelector('.quantity-input');
        var unitPriceInput = item.querySelector('.unit-price-input');
        var removeBtn = item.querySelector('.remove-item');
        
        if (productSelect) {
            productSelect.addEventListener('change', function() {
                var opt = this.options[this.selectedIndex];
                var price = opt.getAttribute('data-price') || '0';
                if (unitPriceInput) unitPriceInput.value = parseFloat(price).toFixed(2);
                if (quantityInput) quantityInput.value = 1;
                calculateTotal();
            });
        }
        
        if (quantityInput) {
            quantityInput.addEventListener('input', function() {
                checkStock(productSelect, this);
            });
        }
        
        if (removeBtn) {
            removeBtn.addEventListener('click', function() {
                item.remove();
                calculateTotal();
                var itemsLeft = document.querySelectorAll('.order-item').length;
                var addFirstBtn = document.getElementById('add-first-item');
                var addItemBtn = document.getElementById('add-item');
                if (itemsLeft === 0) {
                    if (addFirstBtn) addFirstBtn.style.display = 'inline-block';
                    if (addItemBtn) addItemBtn.style.display = 'none';
                }
            });
        }
    }
    
    var addFirstBtn = document.getElementById('add-first-item');
    var addItemBtn = document.getElementById('add-item');
    var orderItems = document.getElementById('order-items');
    var template = document.getElementById('item-template');
    
    if (addFirstBtn) {
        addFirstBtn.addEventListener('click', function() {
            var html = template.innerHTML.replace(/__index__/g, itemCount);
            var div = document.createElement('div');
            div.innerHTML = html;
            var newItem = div.firstElementChild;
            if (orderItems) orderItems.appendChild(newItem);
            addItemEventListeners(newItem);
            itemCount = itemCount + 1;
            this.style.display = 'none';
            if (addItemBtn) addItemBtn.style.display = 'inline-block';
            calculateTotal();
        });
    }
    
    if (addItemBtn) {
        addItemBtn.addEventListener('click', function() {
            var html = template.innerHTML.replace(/__index__/g, itemCount);
            var div = document.createElement('div');
            div.innerHTML = html;
            var newItem = div.firstElementChild;
            if (orderItems) orderItems.appendChild(newItem);
            addItemEventListeners(newItem);
            itemCount = itemCount + 1;
            calculateTotal();
        });
    }
    
    var orderForm = document.getElementById('order-form');
    if (orderForm) {
        orderForm.addEventListener('submit', function(e) {
            var items = document.querySelectorAll('.order-item');
            
            var validItems = [];
            for (var i = 0; i < items.length; i++) {
                var productSelect = items[i].querySelector('.product-select');
                if (productSelect && productSelect.value) {
                    validItems.push(items[i]);
                }
            }
            
            if (validItems.length === 0) {
                e.preventDefault();
                alert('Please add at least one item to the order.');
                return false;
            }
            
            var stockData = getStockData();
            var productQuantities = {};
            
            for (var i = 0; i < validItems.length; i++) {
                var item = validItems[i];
                var productSelect = item.querySelector('.product-select');
                var quantityInput = item.querySelector('.quantity-input');
                var productId = productSelect.value;
                var quantity = parseInt(quantityInput.value) || 0;
                
                if (productQuantities[productId]) {
                    productQuantities[productId] = productQuantities[productId] + quantity;
                } else {
                    productQuantities[productId] = quantity;
                }
            }
            
            var hasError = false;
            var errorMessage = '';
            
            for (var productId in productQuantities) {
                var available = stockData[productId] || 0;
                var requested = productQuantities[productId];
                
                if (requested > available) {
                    var productName = '';
                    for (var i = 0; i < validItems.length; i++) {
                        var productSelect = validItems[i].querySelector('.product-select');
                        if (productSelect.value == productId) {
                            productName = productSelect.options[productSelect.selectedIndex].text.split(' -')[0];
                            break;
                        }
                    }
                    hasError = true;
                    errorMessage = errorMessage + 'Not enough stock for ' + productName + '. Requested: ' + requested + ', Available: ' + available + '\n';
                }
            }
            
            if (hasError) {
                e.preventDefault();
                alert('Stock validation failed:\n' + errorMessage);
                return false;
            }
            
            return true;
        });
    }
});
</script>
{% endblock %}