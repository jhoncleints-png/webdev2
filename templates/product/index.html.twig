{% extends 'layout.html.twig' %}

{% block title %}Products - Samaco Brewery{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <!-- DataTables CSS -->
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css">
    
    <style>
        .dataTables_paginate .paginate_button {
            display: inline-block !important;
            margin: 0 2px !important;
        }

        .dataTables_paginate {
            display: flex !important;
            flex-wrap: wrap !important;
            justify-content: flex-end !important;
            align-items: center !important;
            gap: 4px !important;
        }

        .dataTables_info {
            display: flex !important;
            align-items: center !important;
        }
    </style>
{% endblock %}

{% block dashboard_content %}
<div class="container mx-auto px-4 py-8">
    <!-- Page Header -->
    <div class="bg-gradient-to-r from-black to-gray-900 rounded-lg border-l-4 border-yellow-500 p-6 mb-6 shadow-lg">
        <h1 class="text-3xl font-bold text-yellow-500 mb-1">🍺 Products Management</h1>
        <p class="text-gray-400">Manage your brewery products inventory and details</p>
    </div>

    <!-- Top Actions -->
    <div class="mb-4">
        <a href="{{ path('app_product_new') }}" class="inline-flex items-center gap-2 px-6 py-3 bg-gradient-to-r from-yellow-500 to-yellow-300 text-black font-semibold rounded-lg hover:scale-105 transition duration-200 shadow-lg shadow-yellow-500/25">
            <span>+</span>
            <span>Create New Product</span>
        </a>
    </div>

    <!-- Advanced Filters -->
    <div class="bg-gray-800/80 rounded-lg border border-yellow-500/15 p-5 mb-6 shadow-lg">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
            <div>
                <label for="searchName" class="block text-yellow-500 text-sm font-semibold mb-2">Product Name</label>
                <input type="text" id="searchName" class="w-full px-3 py-2 bg-gray-700 border border-yellow-500/30 rounded-md text-white focus:outline-none focus:ring-2 focus:ring-yellow-500" placeholder="Search by name...">
            </div>
            
            <div>
                <label for="searchCreator" class="block text-yellow-500 text-sm font-semibold mb-2">Created By</label>
                <input type="text" id="searchCreator" class="w-full px-3 py-2 bg-gray-700 border border-yellow-500/30 rounded-md text-white focus:outline-none focus:ring-2 focus:ring-yellow-500" placeholder="Search creator...">
            </div>
            
            <div>
                <label for="minPrice" class="block text-yellow-500 text-sm font-semibold mb-2">Min Price</label>
                <input type="number" id="minPrice" class="w-full px-3 py-2 bg-gray-700 border border-yellow-500/30 rounded-md text-white focus:outline-none focus:ring-2 focus:ring-yellow-500" placeholder="$0.00" min="0" step="0.01">
            </div>
            
            <div>
                <label for="maxPrice" class="block text-yellow-500 text-sm font-semibold mb-2">Max Price</label>
                <input type="number" id="maxPrice" class="w-full px-3 py-2 bg-gray-700 border border-yellow-500/30 rounded-md text-white focus:outline-none focus:ring-2 focus:ring-yellow-500" placeholder="$999.99" min="0" step="0.01">
            </div>
        </div>
        
        <div class="mt-4">
            <button id="resetFilters" class="px-5 py-2 bg-gray-700 text-gray-400 border border-gray-500 rounded-md font-semibold hover:bg-gray-600 hover:text-white transition-all duration-200">
                Reset All Filters
            </button>
        </div>
    </div>

    <!-- Products Table -->
    <div class="bg-gray-800/80 rounded-lg shadow-lg p-6">
        {% if products is empty %}
            <div class="text-center py-12">
                <div class="text-5xl mb-3 opacity-60">🍺</div>
                <h3 class="text-yellow-500 text-xl mb-2">No Products Found</h3>
                <p class="text-yellow-500/70">Start by creating your first product to build your inventory</p>
                <a href="{{ path('app_product_new') }}" class="inline-flex items-center gap-2 px-6 py-3 mt-4 bg-gradient-to-r from-yellow-500 to-yellow-300 text-black font-semibold rounded-lg hover:scale-105 transition duration-200">
                    <span>+</span>
                    <span>Create First Product</span>
                </a>
            </div>
        {% else %}
            <table id="productTable" class="display w-full">
                <thead>
                    <tr class="bg-yellow-500/15">
                        <th class="px-4 py-3 text-left text-xs font-semibold text-yellow-500 uppercase tracking-wider">ID</th>
                        <th class="px-4 py-3 text-left text-xs font-semibold text-yellow-500 uppercase tracking-wider">Name</th>
                        <th class="px-4 py-3 text-left text-xs font-semibold text-yellow-500 uppercase tracking-wider">Description</th>
                        <th class="px-4 py-3 text-left text-xs font-semibold text-yellow-500 uppercase tracking-wider">Price</th>
                        <th class="px-4 py-3 text-left text-xs font-semibold text-yellow-500 uppercase tracking-wider">Created By</th>
                        <th class="px-4 py-3 text-left text-xs font-semibold text-yellow-500 uppercase tracking-wider">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for product in products %}
                        <tr class="border-b border-gray-700 hover:bg-yellow-500/10 transition-colors">
                            <td class="px-4 py-3 text-sm text-white">{{ product.id }}</td>
                            <td class="px-4 py-3 text-sm text-white font-medium">{{ product.name }}</td>
                            <td class="px-4 py-3 text-sm text-gray-300">{{ product.description|slice(0, 50) }}{% if product.description|length > 50 %}...{% endif %}</td>
                            <td class="px-4 py-3 text-sm text-yellow-500 font-bold">${{ product.price|number_format(2) }}</td>
                            <td class="px-4 py-3 text-sm text-gray-300">{{ product.createdBy.email }}</td>
                            <td class="px-4 py-3">
                                <div class="flex gap-2 flex-wrap">
                                    <a href="{{ path('app_product_show', {'id': product.id}) }}" class="inline-flex items-center gap-1 px-3 py-1.5 bg-teal-900/30 text-teal-300 border border-teal-500/50 rounded-md text-xs font-semibold hover:bg-teal-900/50 transition">
                                        👁️ View
                                    </a>
                                    
                                    {% if is_granted('ROLE_ADMIN') or (is_granted('ROLE_STAFF') and product.createdBy.id == app.user.id) %}
                                        <a href="{{ path('app_product_edit', {'id': product.id}) }}" class="inline-flex items-center gap-1 px-3 py-1.5 bg-blue-900/30 text-blue-300 border border-blue-500/50 rounded-md text-xs font-semibold hover:bg-blue-900/50 transition">
                                            ✏️ Edit
                                        </a>
                                    {% endif %}
                                    
                                    {% if is_granted('ROLE_ADMIN') %}
                                        <form method="post" action="{{ path('app_product_delete', {'id': product.id}) }}" style="display: inline;" onsubmit="return confirm('Are you sure you want to delete this product? This action cannot be undone.');">
                                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ product.id) }}">
                                            <button type="submit" class="inline-flex items-center gap-1 px-3 py-1.5 bg-red-900/30 text-red-300 border border-red-500/50 rounded-md text-xs font-semibold hover:bg-red-900/50 transition">
                                                🗑️ Delete
                                            </button>
                                        </form>
                                    {% endif %}
                                </div>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        {% endif %}
    </div>
</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    
    <!-- DataTables JS -->
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>
    
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            if ($('#productTable').length && !$.fn.DataTable.isDataTable('#productTable')) {
                window.productTable = $('#productTable').DataTable({
                    paging: true,
                    pageLength: 10,
                    lengthMenu: [[10, 25, 50, 100], [10, 25, 50, 100]],
                    searching: true,
                    ordering: true,
                    order: [[0, 'desc']],
                    responsive: true,
                    autoWidth: false,
                    language: {
                        search: "Search:",
                        searchPlaceholder: "Type to search...",
                        lengthMenu: "Show _MENU_ entries",
                        info: "Showing _START_ to _END_ of _TOTAL_ entries",
                        infoEmpty: "Showing 0 to 0 of 0 entries",
                        infoFiltered: "(filtered from _MAX_ total entries)",
                        zeroRecords: "No matching records found",
                        paginate: {
                            first: "« First",
                            last: "Last »",
                            next: "Next →",
                            previous: "← Previous"
                        }
                    },
                    dom: '<"flex flex-wrap justify-between items-center mb-4"l<"ml-auto"f>>rt<"flex flex-wrap justify-between items-center mt-4"ip>',
                });
                
                // Filters
                $('#searchName').on('keyup', function() {
                    window.productTable.column(1).search(this.value).draw();
                });
                
                $('#searchCreator').on('keyup', function() {
                    window.productTable.column(4).search(this.value).draw();
                });
                
                function applyPriceFilter() {
                    if (!window.productTable) return;
                    
                    $.fn.dataTable.ext.search = [];
                    
                    const minPrice = parseFloat($('#minPrice').val()) || 0;
                    const maxPrice = parseFloat($('#maxPrice').val()) || Number.MAX_VALUE;
                    
                    if ($('#minPrice').val() || $('#maxPrice').val()) {
                        $.fn.dataTable.ext.search.push(function(settings, data, dataIndex) {
                            const priceText = data[3];
                            const price = parseFloat(priceText.replace('$', '').replace(/,/g, ''));
                            return price >= minPrice && price <= maxPrice;
                        });
                    }
                    
                    window.productTable.draw();
                }
                
                $('#minPrice, #maxPrice').on('input', function() {
                    applyPriceFilter();
                });
                
                $('#resetFilters').on('click', function() {
                    $('#searchName').val('');
                    $('#searchCreator').val('');
                    $('#minPrice').val('');
                    $('#maxPrice').val('');
                    if (window.productTable) {
                        window.productTable.search('');
                        window.productTable.columns().search('');
                        $.fn.dataTable.ext.search = [];
                        window.productTable.draw();
                    }
                });
            }
        });
    </script>
{% endblock %}