{% extends 'layout.html.twig' %}

{% block title %}{{ product.name }} - Samaco Brewery{% endblock %}

{% block dashboard_content %}
<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
    
    <div class="mb-8">
        <nav class="flex items-center gap-2 text-sm text-gray-400 mb-6">
            <a href="{{ path('app_dashboard_home') }}" class="hover:text-yellow-400 transition-colors duration-200">Dashboard</a>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
            <a href="{{ path('app_product_index') }}" class="hover:text-yellow-400 transition-colors duration-200">Products</a>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
            <span class="text-yellow-400 font-medium">{{ product.name }}</span>
        </nav>
        
        <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
            <div>
                <h1 class="text-3xl md:text-4xl font-bold text-black mb-2 flex items-center gap-3">
                    <svg class="w-8 h-8 text-yellow-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"></path></svg>
                    {{ product.name }}
                </h1>
                <p class="text-black-400 ml-11">Product Details</p>
            </div>
            
            <a href="{{ path('app_product_index') }}"
               class="inline-flex items-center gap-2 px-5 py-3 text-sm font-semibold text-white 
                      bg-gray-700 rounded-xl hover:bg-gray-600 hover:text-white transition-all duration-200
                      border border-gray-600 focus:outline-none focus:ring-2 focus:ring-yellow-500 focus:ring-offset-2 focus:ring-offset-gray-900
                      self-start sm:self-center shadow-md">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
                </svg>
                Back to Products
            </a>
        </div>
    </div>

    <div class="bg-gray-900/50 backdrop-blur-sm rounded-2xl border border-gray-700/50 shadow-xl p-6 md:p-8">
        
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-6 mb-8">
            <div class="bg-gray-900 rounded-xl border border-gray-700 p-6">
                <div class="flex items-center gap-4 mb-4">
                    <div class="w-12 h-12 flex items-center justify-center bg-blue-900/30 rounded-xl border border-blue-800/30">
                        <svg class="w-6 h-6 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg>
                    </div>
                    <h3 class="text-lg font-semibold text-white">Product ID</h3>
                </div>
                <p class="text-3xl font-bold text-yellow-400">#{{ product.id }}</p>
                <p class="text-sm text-white mt-2">Unique identifier</p>
            </div>
            
            <div class="bg-gray-900 rounded-xl border border-gray-700 p-6">
                <div class="flex items-center gap-4 mb-4">
                    <div class="w-12 h-12 flex items-center justify-center bg-green-900/30 rounded-xl border border-green-800/30">
                        <svg class="w-6 h-6 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                    </div>
                    <h3 class="text-lg font-semibold text-white">Price</h3>
                </div>
                <p class="text-3xl font-bold text-yellow-400">${{ product.price|number_format(2) }}</p>
                <p class="text-sm text-white mt-2">Product price</p>
            </div>
            
            <div class="bg-gray-900 rounded-xl border border-gray-700 p-6">
                <div class="flex items-center gap-4 mb-4">
                    <div class="w-12 h-12 flex items-center justify-center bg-purple-900/30 rounded-xl border border-purple-800/30">
                        <svg class="w-6 h-6 text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"></path></svg>
                    </div>
                    <h3 class="text-lg font-semibold text-white">Category</h3>
                </div>
                <p class="text-lg font-medium text-yellow-400">
                    {% if product.category %}
                        {{ product.category.name }}
                    {% else %}
                        <span class="text-gray-400">Uncategorized</span>
                    {% endif %}
                </p>
                <p class="text-sm text-white mt-2">Product category</p>
            </div>
            
            <div class="bg-gray-900 rounded-xl border border-gray-700 p-6">
                <div class="flex items-center gap-4 mb-4">
                    <div class="w-12 h-12 flex items-center justify-center bg-orange-900/30 rounded-xl border border-orange-800/30">
                        <svg class="w-6 h-6 text-orange-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"></path></svg>
                    </div>
                    <h3 class="text-lg font-semibold text-white">Current Stock</h3>
                </div>
                <p class="text-3xl font-bold text-yellow-400">{{ product.stockQuantity ?? 0 }}</p>
                <p class="text-sm text-white mt-2">Units available</p>
            </div>
            
            <div class="bg-gray-900 rounded-xl border border-gray-700 p-6">
                <div class="flex items-center gap-4 mb-4">
                    <div class="w-12 h-12 flex items-center justify-center bg-red-900/30 rounded-xl border border-red-800/30">
                        <svg class="w-6 h-6 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.282 16.5c-.77.833.192 2.5 1.732 2.5z"></path></svg>
                    </div>
                    <h3 class="text-lg font-semibold text-white">Min Stock Alert</h3>
                </div>
                {% if product.minimumStock %}
                    <p class="text-3xl font-bold text-yellow-400">{{ product.minimumStock }}</p>
                    {% if product.stockQuantity <= product.minimumStock %}
                        <p class="text-sm text-red-400 mt-1">⚠️ Low stock! Restock soon.</p>
                    {% endif %}
                    <p class="text-sm text-white mt-2">Alert when stock falls below this</p>
                {% else %}
                    <p class="text-2xl font-bold text-white">Not set</p>
                    <p class="text-xs text-white mt-2">Set minimum stock to receive alerts</p>
                {% endif %}
            </div>
        </div>

        <div class="bg-gray-900 rounded-xl border border-gray-700 p-6 mb-8">
            <div class="flex items-center gap-4 mb-4">
                <div class="w-12 h-12 flex items-center justify-center bg-yellow-900/30 rounded-xl border border-yellow-800/30">
                    <svg class="w-6 h-6 text-yellow-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"></path></svg>
                </div>
                <h3 class="text-lg font-semibold text-yellow-500">Description</h3>
            </div>
            <div class="bg-gray-800/50 rounded-xl p-4 border border-gray-700">
                <p class="text-white">
                    {{ product.description ?? 'No description provided for this product.' }}
                </p>
            </div>
            <p class="text-sm text-white mt-2">Product details and information</p>
        </div>

        <div class="bg-gray-900 rounded-xl border border-gray-700 p-4 md:p-6">
            <div class="mb-4">
                <h2 class="text-lg font-bold text-yellow-400 mb-1 flex items-center gap-2">
                    <svg class="w-5 h-5 text-yellow-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                    Product Actions
                </h2>
                <p class="text-white text-sm">Manage this product</p>
            </div>
            
            <div class="flex flex-col sm:flex-row gap-3">
                {% set canEdit = false %}
                {% if is_granted('ROLE_ADMIN') %}
                    {% set canEdit = true %}
                {% elseif is_granted('ROLE_STAFF') and product.createdBy and product.createdBy.id == app.user.id %}
                    {% set canEdit = true %}
                {% endif %}
                
                {% if canEdit %}
                <a href="{{ path('app_product_edit', {'id': product.id}) }}"
                   class="group inline-flex items-center justify-center gap-2 px-4 py-2 text-sm font-semibold 
                          bg-yellow-500 text-black rounded-lg
                          hover:bg-yellow-400 active:scale-[0.98]
                          shadow-md hover:shadow-lg shadow-yellow-500/25
                          transition-all duration-200
                          focus:outline-none focus:ring-2 focus:ring-yellow-500 focus:ring-offset-2 focus:ring-offset-gray-900">
                    
                    <svg class="w-4 h-4 transition-transform group-hover:scale-110" 
                         fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path></svg>
                    
                    <span>Edit Product</span>
                </a>
                {% endif %}

                {% if is_granted('ROLE_ADMIN') %}
                <div>
                    <form method="post" 
                          action="{{ path('app_product_delete', {'id': product.id}) }}" 
                          onsubmit="return confirm('Are you sure you want to delete this product? This action cannot be undone.');">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ product.id) }}">
                        <button type="submit"
                                class="group inline-flex items-center justify-center gap-2 px-4 py-2 text-sm font-semibold 
                                       bg-red-600 text-white rounded-lg
                                       hover:bg-red-500 active:scale-[0.98]
                                       shadow-md hover:shadow-lg shadow-red-900/30
                                       transition-all duration-200
                                       focus:outline-none focus:ring-2 focus:ring-red-500 focus:ring-offset-2 focus:ring-offset-gray-900">
                            
                            <svg class="w-4 h-4 transition-transform group-hover:scale-110" 
                                 fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" 
                                      d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
                            </svg>
                            
                            <span>Delete Product</span>
                        </button>
                    </form>
                </div>
                {% endif %}
            </div>
        </div>
    </div>
</div>
{% endblock %}