{% extends 'layout.html.twig' %}

{% block title %}Change Password - Samaco Brewery{% endblock %}

{% block dashboard_content %}
<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
    
    <!-- Page Header -->
    <div class="mb-8">
        <!-- Breadcrumb -->
        <nav class="flex items-center gap-2 text-sm text-gray-400 mb-6">
            <a href="{{ path('app_dashboard_home') }}" 
               class="hover:text-yellow-400 transition-colors duration-200">
                Dashboard
            </a>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
            </svg>
            <a href="{{ path('app_profile_index') }}" 
               class="hover:text-yellow-400 transition-colors duration-200">
                Profile
            </a>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
            </svg>
            <span class="text-yellow-400 font-medium">Change Password</span>
        </nav>
        
        <!-- Main Heading -->
        <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
            <div>
                <h1 class="text-3xl md:text-4xl font-bold text-white mb-2">
                    Change Password
                </h1>
                <p class="text-gray-400">
                    Set a new password for your account
                </p>
            </div>
            
            <!-- Back Button -->
            <a href="{{ path('app_profile_index') }}"
               class="inline-flex items-center gap-2 px-5 py-3 text-sm font-semibold text-gray-300 
                      bg-gray-800/50 rounded-xl hover:bg-gray-800 hover:text-white transition-all duration-200
                      border border-gray-700/50 focus:outline-none focus:ring-2 focus:ring-gray-500 focus:ring-offset-2 focus:ring-offset-gray-900
                      self-start sm:self-center">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
                </svg>
                Back to Profile
            </a>
        </div>
    </div>

    <!-- Form Section -->
    <div class="max-w-2xl mx-auto">
        <div class="bg-gray-900/50 backdrop-blur-sm rounded-2xl border border-gray-700/50 shadow-xl p-6 md:p-8">
            <div class="mb-8">
                <h2 class="text-2xl font-bold text-yellow-400 mb-2 flex items-center gap-3">
                    <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z"></path>
                    </svg>
                    Security Settings
                </h2>
                <p class="text-gray-400">Update your account password</p>
            </div>
            
            <!-- Form -->
            {{ form_start(form, {'attr': {'class': 'space-y-6'}}) }}
                
                <!-- New Password Field -->
                <div>
                    {{ form_label(form.plainPassword.first, 'New Password', {
                        'label_attr': {
                            'class': 'block text-sm font-semibold text-yellow-300 mb-2'
                        }
                    }) }}
                    
                    {{ form_widget(form.plainPassword.first, {
                        'attr': {
                            'class': 'w-full px-4 py-3.5 bg-gray-800/50 border border-gray-700 rounded-xl 
                                     text-white placeholder-gray-500 focus:outline-none focus:ring-2 
                                     focus:ring-yellow-500 focus:border-yellow-500 transition duration-200
                                     hover:border-gray-600 text-base'
                        }
                    }) }}
                    
                    {% if form.plainPassword.first.vars.errors|length > 0 %}
                        <div class="mt-2 text-sm text-red-400 space-y-1">
                            {{ form_errors(form.plainPassword.first) }}
                        </div>
                    {% endif %}
                    <p class="text-sm text-gray-400 mt-2">Minimum 6 characters recommended</p>
                </div>

                <!-- Repeat Password Field -->
                <div>
                    {{ form_label(form.plainPassword.second, 'Confirm New Password', {
                        'label_attr': {
                            'class': 'block text-sm font-semibold text-yellow-300 mb-2'
                        }
                    }) }}
                    
                    {{ form_widget(form.plainPassword.second, {
                        'attr': {
                            'class': 'w-full px-4 py-3.5 bg-gray-800/50 border border-gray-700 rounded-xl 
                                     text-white placeholder-gray-500 focus:outline-none focus:ring-2 
                                     focus:ring-yellow-500 focus:border-yellow-500 transition duration-200
                                     hover:border-gray-600 text-base'
                        }
                    }) }}
                    
                    {% if form.plainPassword.second.vars.errors|length > 0 %}
                        <div class="mt-2 text-sm text-red-400 space-y-1">
                            {{ form_errors(form.plainPassword.second) }}
                        </div>
                    {% endif %}
                </div>

                <!-- Security Warning -->
                <div class="bg-yellow-900/20 border border-yellow-800/30 rounded-xl p-4">
                    <div class="flex items-start gap-3">
                        <svg class="w-5 h-5 text-yellow-400 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.282 16.5c-.77.833.192 2.5 1.732 2.5z"></path>
                        </svg>
                        <div>
                            <h3 class="text-sm font-semibold text-yellow-300 mb-1">Important Security Notice</h3>
                            <p class="text-sm text-gray-300">
                                After changing your password, you will be automatically logged out and need to login again with your new password.
                            </p>
                        </div>
                    </div>
                </div>

                <!-- Action Buttons -->
                <div class="flex flex-col sm:flex-row gap-4 mt-12 pt-8 border-t border-gray-700/50">
                    <!-- Submit Button -->
                    <button type="submit"
                            class="group inline-flex items-center justify-center gap-3 px-8 py-4 text-base font-bold 
                                   bg-gradient-to-r from-green-600 to-green-700 text-white rounded-xl
                                   hover:from-green-500 hover:to-green-600 active:scale-[0.98]
                                   shadow-lg hover:shadow-xl shadow-green-900/30
                                   border border-green-800/30 transition-all duration-200
                                   focus:outline-none focus:ring-2 focus:ring-green-500 focus:ring-offset-2 focus:ring-offset-gray-900
                                   flex-1 sm:flex-none min-h-[52px]">
                        
                        <svg class="w-5 h-5 transition-transform group-hover:scale-110" 
                             fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" 
                                  d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z"></path>
                        </svg>
                        
                        <span>Change Password</span>
                    </button>

                    <!-- Cancel Button -->
                    <a href="{{ path('app_profile_index') }}"
                       class="inline-flex items-center justify-center gap-3 px-8 py-4 text-base font-semibold
                              bg-gray-800/60 text-gray-300 rounded-xl hover:bg-gray-800 hover:text-white
                              active:scale-[0.98] border border-gray-700/50 transition-all duration-200
                              focus:outline-none focus:ring-2 focus:ring-gray-500 focus:ring-offset-2 focus:ring-offset-gray-900
                              flex-1 sm:flex-none min-h-[52px]">
                        
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" 
                                  d="M6 18L18 6M6 6l12 12"></path>
                        </svg>
                        
                        <span>Cancel</span>
                    </a>
                </div>
            {{ form_end(form) }}
        </div>
    </div>

</div>
{% endblock %}