{% extends 'layout.html.twig' %}

{% block title %}Edit Profile - Samaco Brewery{% endblock %}

{% block dashboard_content %}
<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
    
    <!-- Page Header -->
    <div class="mb-8">
        <!-- Breadcrumb -->
        <nav class="flex items-center gap-2 text-sm text-gray-400 mb-6">
            <a href="{{ path('app_dashboard_home') }}" 
               class="hover:text-yellow-400 transition-colors duration-200">
                Dashboard
            </a>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
            </svg>
            <a href="{{ path('app_profile_index') }}" 
               class="hover:text-yellow-400 transition-colors duration-200">
                Profile
            </a>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
            </svg>
            <span class="text-yellow-400 font-medium">Edit Profile</span>
        </nav>
        
        <!-- Main Heading -->
        <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
            <div>
                <h1 class="text-3xl md:text-4xl font-bold text-white mb-2">
                    Edit Profile
                </h1>
                <p class="text-gray-400">
                    Update your personal information
                </p>
            </div>
            
            <!-- Back Button -->
            <a href="{{ path('app_profile_index') }}"
               class="inline-flex items-center gap-2 px-5 py-3 text-sm font-semibold text-gray-300 
                      bg-gray-800/50 rounded-xl hover:bg-gray-800 hover:text-white transition-all duration-200
                      border border-gray-700/50 focus:outline-none focus:ring-2 focus:ring-gray-500 focus:ring-offset-2 focus:ring-offset-gray-900
                      self-start sm:self-center">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
                </svg>
                Back to Profile
            </a>
        </div>
    </div>

    <!-- Form Section -->
    <div class="max-w-2xl mx-auto">
        <div class="bg-gray-900/50 backdrop-blur-sm rounded-2xl border border-gray-700/50 shadow-xl p-6 md:p-8">
            <div class="mb-8">
                <h2 class="text-2xl font-bold text-yellow-400 mb-2 flex items-center gap-3">
                    <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
                    </svg>
                    Personal Information
                </h2>
                <p class="text-gray-400">Update your profile details</p>
            </div>
            
            <!-- Form -->
            {{ form_start(form, {'attr': {'class': 'space-y-6'}}) }}
                
                <!-- Email Field -->
                <div>
                    {{ form_label(form.email, 'Email Address', {
                        'label_attr': {
                            'class': 'block text-sm font-semibold text-yellow-300 mb-2'
                        }
                    }) }}
                    
                    {{ form_widget(form.email, {
                        'attr': {
                            'class': 'w-full px-4 py-3.5 bg-gray-800/50 border border-gray-700 rounded-xl 
                                     text-white placeholder-gray-500 focus:outline-none focus:ring-2 
                                     focus:ring-yellow-500 focus:border-yellow-500 transition duration-200
                                     hover:border-gray-600 text-base'
                        }
                    }) }}
                    
                    {% if form.email.vars.errors|length > 0 %}
                        <div class="mt-2 text-sm text-red-400 space-y-1">
                            {{ form_errors(form.email) }}
                        </div>
                    {% endif %}
                </div>

                <!-- First Name Field -->
                <div>
                    {{ form_label(form.firstName, 'First Name', {
                        'label_attr': {
                            'class': 'block text-sm font-semibold text-yellow-300 mb-2'
                        }
                    }) }}
                    
                    {{ form_widget(form.firstName, {
                        'attr': {
                            'class': 'w-full px-4 py-3.5 bg-gray-800/50 border border-gray-700 rounded-xl 
                                     text-white placeholder-gray-500 focus:outline-none focus:ring-2 
                                     focus:ring-yellow-500 focus:border-yellow-500 transition duration-200
                                     hover:border-gray-600 text-base'
                        }
                    }) }}
                    
                    {% if form.firstName.vars.errors|length > 0 %}
                        <div class="mt-2 text-sm text-red-400 space-y-1">
                            {{ form_errors(form.firstName) }}
                        </div>
                    {% endif %}
                </div>

                <!-- Last Name Field -->
                <div>
                    {{ form_label(form.lastName, 'Last Name', {
                        'label_attr': {
                            'class': 'block text-sm font-semibold text-yellow-300 mb-2'
                        }
                    }) }}
                    
                    {{ form_widget(form.lastName, {
                        'attr': {
                            'class': 'w-full px-4 py-3.5 bg-gray-800/50 border border-gray-700 rounded-xl 
                                     text-white placeholder-gray-500 focus:outline-none focus:ring-2 
                                     focus:ring-yellow-500 focus:border-yellow-500 transition duration-200
                                     hover:border-gray-600 text-base'
                        }
                    }) }}
                    
                    {% if form.lastName.vars.errors|length > 0 %}
                        <div class="mt-2 text-sm text-red-400 space-y-1">
                            {{ form_errors(form.lastName) }}
                        </div>
                    {% endif %}
                </div>

                <!-- Action Buttons -->
                <div class="flex flex-col sm:flex-row gap-4 mt-12 pt-8 border-t border-gray-700/50">
                    <!-- Submit Button -->
                    <button type="submit"
                            class="group inline-flex items-center justify-center gap-3 px-8 py-4 text-base font-bold 
                                   bg-gradient-to-r from-yellow-600 to-yellow-700 text-black rounded-xl
                                   hover:from-yellow-500 hover:to-yellow-600 active:scale-[0.98]
                                   shadow-lg hover:shadow-xl shadow-yellow-900/30
                                   border border-yellow-800/30 transition-all duration-200
                                   focus:outline-none focus:ring-2 focus:ring-yellow-500 focus:ring-offset-2 focus:ring-offset-gray-900
                                   flex-1 sm:flex-none min-h-[52px]">
                        
                        <svg class="w-5 h-5 transition-transform group-hover:scale-110" 
                             fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" 
                                  d="M5 13l4 4L19 7"></path>
                        </svg>
                        
                        <span>Save Changes</span>
                    </button>

                    <!-- Cancel Button -->
                    <a href="{{ path('app_profile_index') }}"
                       class="inline-flex items-center justify-center gap-3 px-8 py-4 text-base font-semibold
                              bg-gray-800/60 text-gray-300 rounded-xl hover:bg-gray-800 hover:text-white
                              active:scale-[0.98] border border-gray-700/50 transition-all duration-200
                              focus:outline-none focus:ring-2 focus:ring-gray-500 focus:ring-offset-2 focus:ring-offset-gray-900
                              flex-1 sm:flex-none min-h-[52px]">
                        
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" 
                                  d="M6 18L18 6M6 6l12 12"></path>
                        </svg>
                        
                        <span>Cancel</span>
                    </a>
                </div>
            {{ form_end(form) }}
        </div>
    </div>

</div>
{% endblock %}