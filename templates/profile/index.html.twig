{% extends 'layout.html.twig' %}

{% block title %}My Profile - Samaco Brewery{% endblock %}

{% block dashboard_content %}
<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
    
    <!-- Page Header -->
    <div class="mb-8">
        <nav class="flex items-center gap-2 text-sm text-gray-400 mb-6">
            <a href="{{ path('app_dashboard_home') }}" 
               class="hover:text-yellow-400 transition-colors duration-200">
                Dashboard
            </a>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
            </svg>
            <span class="text-yellow-400 font-medium">My Profile</span>
        </nav>
        
        <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
            <div>
                <h1 class="text-3xl md:text-4xl font-bold text-black mb-2 flex items-center gap-3">
                    <svg class="w-8 h-8 text-yellow-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
                    </svg>
                    My Profile
                </h1>
                <p class="text-gray-400 ml-11">Manage your account information</p>
            </div>
            
            <!-- Back Button -->
            <a href="{{ path('app_dashboard_home') }}"
               class="inline-flex items-center gap-2 px-5 py-3 text-sm font-semibold text-gray-300 
                      bg-gray-800/50 rounded-xl hover:bg-gray-800 hover:text-white transition-all duration-200
                      border border-gray-700/50 focus:outline-none focus:ring-2 focus:ring-gray-500 focus:ring-offset-2 focus:ring-offset-gray-900
                      self-start sm:self-center">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
                </svg>
                Back to Dashboard
            </a>
        </div>
    </div>

    <!-- Profile Cards -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
        
        <!-- Personal Information Card -->
        <div class="bg-gray-900/50 backdrop-blur-sm rounded-2xl border border-gray-700/50 shadow-xl p-6 md:p-8">
            <div class="mb-8">
                <h2 class="text-2xl font-bold text-yellow-400 mb-2 flex items-center gap-3">
                    <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
                    </svg>
                    Personal Information
                </h2>
                <p class="text-gray-400">Your account details</p>
            </div>
            
            <div class="space-y-6">
                <!-- Full Name -->
                <div>
                    <label class="block text-sm font-semibold text-yellow-300 mb-2">Full Name</label>
                    <p class="text-xl font-medium text-white">{{ user.firstName }} {{ user.lastName }}</p>
                </div>
                
                <!-- Email -->
                <div>
                    <label class="block text-sm font-semibold text-yellow-300 mb-2">Email Address</label>
                    <p class="text-xl font-medium text-white">{{ user.email }}</p>
                </div>
                
                <!-- Account Created -->
                <div>
                    <label class="block text-sm font-semibold text-yellow-300 mb-2">Account Created</label>
                    <p class="text-lg text-gray-300">{{ user.createdAt|date('F j, Y') }}</p>
                </div>
                
                <!-- User Role -->
                <div>
                    <label class="block text-sm font-semibold text-yellow-300 mb-2">User Role</label>
                    <div class="mt-2">
                        {% if 'ROLE_ADMIN' in user.roles %}
                            <span class="px-4 py-2 bg-red-900/30 text-red-400 rounded-xl border border-red-800/30 font-medium">Administrator</span>
                        {% elseif 'ROLE_STAFF' in user.roles %}
                            <span class="px-4 py-2 bg-yellow-900/30 text-yellow-400 rounded-xl border border-yellow-800/30 font-medium">Staff Member</span>
                        {% else %}
                            <span class="px-4 py-2 bg-blue-900/30 text-blue-400 rounded-xl border border-blue-800/30 font-medium">User</span>
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>

        <!-- Account Actions Card -->
        <div class="bg-gray-900/50 backdrop-blur-sm rounded-2xl border border-gray-700/50 shadow-xl p-6 md:p-8">
            <div class="mb-8">
                <h2 class="text-2xl font-bold text-yellow-400 mb-2 flex items-center gap-3">
                    <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path>
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                    </svg>
                    Account Actions
                </h2>
                <p class="text-gray-400">Manage your account settings</p>
            </div>
            
            <div class="space-y-4">
                <!-- Edit Profile Button -->
                <a href="{{ path('app_profile_edit') }}" 
                   class="group inline-flex items-center justify-center gap-3 w-full px-6 py-4 text-base font-semibold 
                          bg-gradient-to-r from-yellow-600 to-yellow-700 text-black rounded-xl
                          hover:from-yellow-500 hover:to-yellow-600 active:scale-[0.98]
                          shadow-lg hover:shadow-xl shadow-yellow-900/30
                          border border-yellow-800/30 transition-all duration-200
                          focus:outline-none focus:ring-2 focus:ring-yellow-500 focus:ring-offset-2 focus:ring-offset-gray-900">
                    
                    <svg class="w-5 h-5 transition-transform group-hover:scale-110" 
                         fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
                    </svg>
                    
                    <span>Edit Profile</span>
                </a>

                <!-- Change Password Button -->
                <a href="{{ path('app_profile_change_password') }}" 
                   class="group inline-flex items-center justify-center gap-3 w-full px-6 py-4 text-base font-semibold 
                          bg-gradient-to-r from-green-600 to-green-700 text-white rounded-xl
                          hover:from-green-500 hover:to-green-600 active:scale-[0.98]
                          shadow-lg hover:shadow-xl shadow-green-900/30
                          border border-green-800/30 transition-all duration-200
                          focus:outline-none focus:ring-2 focus:ring-green-500 focus:ring-offset-2 focus:ring-offset-gray-900">
                    
                    <svg class="w-5 h-5 transition-transform group-hover:scale-110" 
                         fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z"></path>
                    </svg>
                    
                    <span>Change Password</span>
                </a>

                <!-- Logout Button -->
                <a href="{{ path('app_logout') }}" 
                   class="group inline-flex items-center justify-center gap-3 w-full px-6 py-4 text-base font-semibold 
                          bg-gray-800/60 text-gray-300 rounded-xl hover:bg-gray-800 hover:text-white
                          active:scale-[0.98] border border-gray-700/50 transition-all duration-200
                          focus:outline-none focus:ring-2 focus:ring-gray-500 focus:ring-offset-2 focus:ring-offset-gray-900">
                    
                    <svg class="w-5 h-5 transition-transform group-hover:scale-110" 
                         fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"></path>
                    </svg>
                    
                    <span>Logout</span>
                </a>
            </div>

            <!-- Account Security -->
            <div class="mt-8 pt-8 border-t border-gray-700/50">
                <h3 class="text-lg font-semibold text-yellow-300 mb-4 flex items-center gap-2">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
                    </svg>
                    Account Security
                </h3>
                
                <ul class="space-y-3">
                    <li class="flex items-center gap-3 text-gray-300">
                        <svg class="w-5 h-5 text-green-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                        </svg>
                        <span>Password is securely hashed</span>
                    </li>
                    <li class="flex items-center gap-3 text-gray-300">
                        <svg class="w-5 h-5 text-green-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                        </svg>
                        <span>Email is verified</span>
                    </li>
                    <li class="flex items-center gap-3 text-gray-300">
                        <svg class="w-5 h-5 text-green-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                        </svg>
                        <span>Last login activity recorded</span>
                    </li>
                </ul>
            </div>
        </div>

    </div>
</div>
{% endblock %}