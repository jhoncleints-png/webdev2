{% extends 'base.html.twig' %}

{% block title %}Register - Samaco Brewery{% endblock %}

{% block body %}
<div class="min-h-screen flex items-center justify-center bg-gradient-to-br from-gray-900 to-black py-12 px-4 sm:px-6 lg:px-8">
    <div class="max-w-md w-full space-y-8 bg-gray-800 p-8 rounded-2xl shadow-2xl border border-yellow-500/20">
        <div>
            <div class="flex justify-center">
                <div class="bg-gradient-to-r from-yellow-500 to-yellow-300 p-3 rounded-full">
                    <img src="{{ asset('images/logo.png') }}" alt="Samaco Brewery Logo" class="w-12 h-12 object-contain">
                </div>
            </div>
            <h2 class="mt-6 text-center text-3xl font-extrabold text-yellow-500">
                Create Account
            </h2>
            <p class="mt-2 text-center text-sm text-gray-300">
                Join Samaco Brewery
            </p>
        </div>

        {{ form_start(registrationForm, { 'attr': {'class': 'mt-8 space-y-6'} }) }}
        
            {% if form_errors(registrationForm) %}
                <div class="rounded-md bg-red-900/50 p-4 border border-red-500">
                    <div class="text-sm text-red-200">
                        {{ form_errors(registrationForm) }}
                    </div>
                </div>
            {% endif %}

            <div class="space-y-4">
                <!-- Email Field -->
                <div>
                    {{ form_label(registrationForm.email, null, {
                        'label_attr': {'class': 'block text-sm font-medium text-gray-300 mb-1'}
                    }) }}
                    {{ form_widget(registrationForm.email, {
                        'attr': {
                            'class': 'appearance-none relative block w-full px-4 py-3 border border-gray-600 bg-gray-900 text-white placeholder-gray-500 rounded-lg focus:outline-none focus:ring-2 focus:ring-yellow-500 focus:border-transparent focus:z-10 sm:text-sm',
                            'placeholder': 'Enter your email',
                            'autocomplete': 'email'
                        }
                    }) }}
                    {% if registrationForm.email.vars.errors|length > 0 %}
                        <div class="mt-1 text-sm text-red-400">
                            {{ form_errors(registrationForm.email) }}
                        </div>
                    {% endif %}
                </div>

                <!-- First Name Field (if exists) -->
                {% if registrationForm.firstName is defined %}
                <div>
                    {{ form_label(registrationForm.firstName, null, {
                        'label_attr': {'class': 'block text-sm font-medium text-gray-300 mb-1'}
                    }) }}
                    {{ form_widget(registrationForm.firstName, {
                        'attr': {
                            'class': 'appearance-none relative block w-full px-4 py-3 border border-gray-600 bg-gray-900 text-white placeholder-gray-500 rounded-lg focus:outline-none focus:ring-2 focus:ring-yellow-500 focus:border-transparent focus:z-10 sm:text-sm',
                            'placeholder': 'Enter your first name',
                            'autocomplete': 'given-name'
                        }
                    }) }}
                    {% if registrationForm.firstName.vars.errors|length > 0 %}
                        <div class="mt-1 text-sm text-red-400">
                            {{ form_errors(registrationForm.firstName) }}
                        </div>
                    {% endif %}
                </div>
                {% endif %}

                <!-- Last Name Field (if exists) -->
                {% if registrationForm.lastName is defined %}
                <div>
                    {{ form_label(registrationForm.lastName, null, {
                        'label_attr': {'class': 'block text-sm font-medium text-gray-300 mb-1'}
                    }) }}
                    {{ form_widget(registrationForm.lastName, {
                        'attr': {
                            'class': 'appearance-none relative block w-full px-4 py-3 border border-gray-600 bg-gray-900 text-white placeholder-gray-500 rounded-lg focus:outline-none focus:ring-2 focus:ring-yellow-500 focus:border-transparent focus:z-10 sm:text-sm',
                            'placeholder': 'Enter your last name',
                            'autocomplete': 'family-name'
                        }
                    }) }}
                    {% if registrationForm.lastName.vars.errors|length > 0 %}
                        <div class="mt-1 text-sm text-red-400">
                            {{ form_errors(registrationForm.lastName) }}
                        </div>
                    {% endif %}
                </div>
                {% endif %}
                
                <!-- Password Field -->
                <div>
                    {{ form_label(registrationForm.plainPassword, null, {
                        'label_attr': {'class': 'block text-sm font-medium text-gray-300 mb-1'}
                    }) }}
                    {{ form_widget(registrationForm.plainPassword, {
                        'attr': {
                            'class': 'appearance-none relative block w-full px-4 py-3 border border-gray-600 bg-gray-900 text-white placeholder-gray-500 rounded-lg focus:outline-none focus:ring-2 focus:ring-yellow-500 focus:border-transparent focus:z-10 sm:text-sm',
                            'placeholder': 'Enter your password',
                            'autocomplete': 'new-password'
                        }
                    }) }}
                    {% if registrationForm.plainPassword.vars.errors|length > 0 %}
                        <div class="mt-1 text-sm text-red-400">
                            {{ form_errors(registrationForm.plainPassword) }}
                        </div>
                    {% endif %}
                    <p class="mt-1 text-xs text-gray-400">
                        Password must be at least 6 characters long
                    </p>
                </div>

                <!-- Confirm Password Field (if exists) -->
                {% if registrationForm.confirmPassword is defined %}
                <div>
                    {{ form_label(registrationForm.confirmPassword, null, {
                        'label_attr': {'class': 'block text-sm font-medium text-gray-300 mb-1'}
                    }) }}
                    {{ form_widget(registrationForm.confirmPassword, {
                        'attr': {
                            'class': 'appearance-none relative block w-full px-4 py-3 border border-gray-600 bg-gray-900 text-white placeholder-gray-500 rounded-lg focus:outline-none focus:ring-2 focus:ring-yellow-500 focus:border-transparent focus:z-10 sm:text-sm',
                            'placeholder': 'Confirm your password',
                            'autocomplete': 'new-password'
                        }
                    }) }}
                    {% if registrationForm.confirmPassword.vars.errors|length > 0 %}
                        <div class="mt-1 text-sm text-red-400">
                            {{ form_errors(registrationForm.confirmPassword) }}
                        </div>
                    {% endif %}
                </div>
                {% endif %}

                <!-- Agree Terms Field -->
                <div class="flex items-start">
                    {{ form_widget(registrationForm.agreeTerms, {
                        'attr': {'class': 'h-4 w-4 text-yellow-500 focus:ring-yellow-500 border-gray-600 rounded bg-gray-900 mt-1'}
                    }) }}
                    <div class="ml-2">
                        {{ form_label(registrationForm.agreeTerms, null, {
                            'label_attr': {'class': 'block text-sm text-gray-300 cursor-pointer'}
                        }) }}
                        <p class="text-xs text-gray-400 mt-1">
                            I agree to the <a href="#" class="text-yellow-400 hover:text-yellow-300">Terms of Service</a> and <a href="#" class="text-yellow-400 hover:text-yellow-300">Privacy Policy</a>
                        </p>
                    </div>
                    {% if registrationForm.agreeTerms.vars.errors|length > 0 %}
                        <div class="mt-1 text-sm text-red-400">
                            {{ form_errors(registrationForm.agreeTerms) }}
                        </div>
                    {% endif %}
                </div>
            </div>

            <!-- Register Button -->
            <div>
                <button type="submit" class="group relative w-full flex justify-center py-3 px-4 border border-transparent text-sm font-medium rounded-lg text-black bg-gradient-to-r from-yellow-500 to-yellow-300 hover:from-yellow-400 hover:to-yellow-200 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-yellow-500 transition-all duration-200 shadow-lg shadow-yellow-500/25">
                    <span class="absolute left-0 inset-y-0 flex items-center pl-3">
                        <svg class="h-5 w-5 text-black group-hover:text-gray-900" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z"></path>
                        </svg>
                    </span>
                    Create Account
                </button>
            </div>

        {{ form_end(registrationForm) }}

        <!-- Login Link -->
        <div class="mt-6">
            <div class="relative">
                <div class="absolute inset-0 flex items-center">
                    <div class="w-full border-t border-gray-700"></div>
                </div>
                <div class="relative flex justify-center text-sm">
                    <span class="px-2 bg-gray-800 text-gray-400">
                        Already have an account?
                    </span>
                </div>
            </div>

            <div class="mt-6">
                <a href="{{ path('app_login') }}" class="w-full flex justify-center py-3 px-4 border-2 border-gray-600 rounded-lg text-sm font-medium text-gray-300 hover:text-white hover:border-gray-500 transition-all duration-200">
                    <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 16l-4-4m0 0l4-4m-4 4h14m-5 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h7a3 3 0 013 3v1"></path>
                    </svg>
                    Sign in instead
                </a>
            </div>
        </div>
    </div>
</div>
{% endblock %}