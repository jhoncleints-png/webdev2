{% extends 'layout.html.twig' %}

{% block title %}Adjust Stock - {{ product.name }}{% endblock %}

{% block dashboard_content %}
<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
    
    <div class="mb-8">
        <nav class="flex items-center gap-2 text-sm text-black mb-6">
            <a href="{{ path('app_dashboard_home') }}" class="hover:text-yellow-400 transition-colors duration-200">Dashboard</a>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
            <a href="{{ path('app_stock_index') }}" class="hover:text-yellow-400 transition-colors duration-200">Stock</a>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
            <span class="text-yellow-400 font-medium">Adjust Stock</span>
        </nav>
        
        <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
            <div>
                <h1 class="text-3xl md:text-4xl font-bold text-black mb-2 flex items-center gap-3">
                    <svg class="w-8 h-8 text-yellow-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"></path></svg>
                    Adjust Stock
                </h1>
                <p class="text-black ml-11">Update inventory for {{ product.name }}</p>
            </div>
            
            <a href="{{ path('app_stock_index') }}"
               class="inline-flex items-center gap-2 px-5 py-3 text-sm font-semibold text-white 
                      bg-gray-700 rounded-xl hover:bg-gray-600 hover:text-white transition-all duration-200
                      border border-gray-600 focus:outline-none focus:ring-2 focus:ring-yellow-500 focus:ring-offset-2 focus:ring-offset-gray-900
                      self-start sm:self-center shadow-md">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
                Back to Stock
            </a>
        </div>
    </div>

    <div class="bg-gray-900/50 backdrop-blur-sm rounded-2xl border border-gray-700/50 shadow-xl p-6 md:p-8 max-w-2xl mx-auto">
        
        <div class="bg-gray-900 rounded-xl border border-gray-700 p-6 md:p-8">
            <div class="mb-6">
                <h2 class="text-xl font-bold text-yellow-400 mb-2 flex items-center gap-3">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"></path></svg>
                    {{ product.name }}
                </h2>
                <p class="text-gray-400">Update inventory levels</p>
            </div>
            
            <div class="bg-gray-800/50 rounded-xl p-4 border border-gray-700 mb-6">
                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <p class="text-sm text-gray-400">Current Stock</p>
                        <p class="text-3xl font-bold text-yellow-400">{{ product.stockQuantity }}</p>
                    </div>
                    {% if product.minimumStock %}
                    <div>
                        <p class="text-sm text-gray-400">Minimum Stock Alert</p>
                        <p class="text-3xl font-bold text-yellow-400">{{ product.minimumStock }}</p>
                        {% if product.stockQuantity <= product.minimumStock %}
                            <p class="text-xs text-red-400 mt-1">⚠️ Low stock!</p>
                        {% endif %}
                    </div>
                    {% endif %}
                </div>
            </div>

            <form method="POST" class="space-y-6">
                <div>
                    <label class="block text-sm font-semibold text-yellow-300 mb-2">Quantity</label>
                    <input type="number" name="quantity" required min="1" 
                           class="w-full px-4 py-3.5 bg-gray-800/50 border border-gray-700 rounded-xl text-white placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-yellow-500 focus:border-yellow-500 transition duration-200 hover:border-gray-600 text-base">
                </div>

                <div>
                    <label class="block text-sm font-semibold text-yellow-300 mb-2">Action</label>
                    <div class="space-y-2">
                        <label class="flex items-center p-3 rounded-xl bg-gray-800/30 border border-gray-700 hover:bg-gray-800/50 transition cursor-pointer">
                            <input type="radio" name="action" value="add" class="mr-3 text-yellow-500 focus:ring-yellow-500 w-4 h-4" checked>
                            <span class="text-white">➕ Add to Stock (Increase)</span>
                        </label>
                        <label class="flex items-center p-3 rounded-xl bg-gray-800/30 border border-gray-700 hover:bg-gray-800/50 transition cursor-pointer">
                            <input type="radio" name="action" value="remove" class="mr-3 text-yellow-500 focus:ring-yellow-500 w-4 h-4">
                            <span class="text-white">➖ Remove from Stock (Decrease)</span>
                        </label>
                        <label class="flex items-center p-3 rounded-xl bg-gray-800/30 border border-gray-700 hover:bg-gray-800/50 transition cursor-pointer">
                            <input type="radio" name="action" value="set" class="mr-3 text-yellow-500 focus:ring-yellow-500 w-4 h-4">
                            <span class="text-white">📝 Set Exact Quantity (Override)</span>
                        </label>
                    </div>
                </div>

                <div class="pt-4 border-t border-gray-700">
                    <button type="submit" 
                            class="group w-full inline-flex items-center justify-center gap-3 px-8 py-4 text-base font-bold 
                                   bg-yellow-500 text-black rounded-xl
                                   hover:bg-yellow-400 active:scale-[0.98]
                                   shadow-lg hover:shadow-xl shadow-yellow-500/25
                                   transition-all duration-200
                                   focus:outline-none focus:ring-2 focus:ring-yellow-500 focus:ring-offset-2 focus:ring-offset-gray-900">
                        <svg class="w-5 h-5 transition-transform group-hover:scale-110" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path>
                        </svg>
                        <span>Update Stock</span>
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
{% endblock %}