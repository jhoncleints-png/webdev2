{% extends 'layout.html.twig' %}

{% block title %}Adjust Stock - {{ product.name }}{% endblock %}

{% block dashboard_content %}
<div class="container mx-auto px-4 py-8">
    <div class="max-w-md mx-auto">
        <div class="flex justify-between items-center mb-6">
            <h1 class="text-3xl font-bold text-yellow-500">📦 Adjust Stock</h1>
            <a href="{{ path('app_stock_index') }}" class="text-gray-400 hover:text-white transition duration-200">
                ← Back to Stock
            </a>
        </div>

        <div class="bg-gray-800/80 rounded-lg shadow-lg p-6 border border-yellow-500/15">
            <div class="mb-6">
                <h2 class="text-xl font-semibold text-white">{{ product.name }}</h2>
                <div class="mt-3 space-y-1">
                    <p class="text-gray-300">Current Stock: <span class="font-bold text-yellow-500 text-xl">{{ product.stockQuantity }}</span></p>
                    {% if product.minimumStock %}
                        <p class="text-gray-400">Minimum Stock: <span class="text-yellow-500">{{ product.minimumStock }}</span></p>
                        {% if product.stockQuantity <= product.minimumStock %}
                            <p class="text-red-400 text-sm mt-2">⚠️ Low stock alert! Consider restocking.</p>
                        {% endif %}
                    {% endif %}
                </div>
            </div>

            <form method="POST" class="space-y-5">
                <div>
                    <label class="block text-sm font-medium text-gray-300 mb-2">Quantity</label>
                    <input type="number" name="quantity" required min="1" class="w-full px-4 py-2 bg-gray-700 border border-gray-600 rounded-lg text-white focus:outline-none focus:ring-2 focus:ring-yellow-500 focus:border-transparent">
                </div>

                <div>
                    <label class="block text-sm font-medium text-gray-300 mb-2">Action</label>
                    <div class="space-y-2">
                        <label class="flex items-center p-2 rounded-lg hover:bg-gray-700/50 transition cursor-pointer">
                            <input type="radio" name="action" value="add" class="mr-3 text-yellow-500 focus:ring-yellow-500" checked>
                            <span class="text-white">➕ Add to Stock (Increase)</span>
                        </label>
                        <label class="flex items-center p-2 rounded-lg hover:bg-gray-700/50 transition cursor-pointer">
                            <input type="radio" name="action" value="remove" class="mr-3 text-yellow-500 focus:ring-yellow-500">
                            <span class="text-white">➖ Remove from Stock (Decrease)</span>
                        </label>
                        <label class="flex items-center p-2 rounded-lg hover:bg-gray-700/50 transition cursor-pointer">
                            <input type="radio" name="action" value="set" class="mr-3 text-yellow-500 focus:ring-yellow-500">
                            <span class="text-white">📝 Set Exact Quantity (Override)</span>
                        </label>
                    </div>
                </div>

                <div class="pt-4">
                    <button type="submit" class="w-full bg-gradient-to-r from-yellow-500 to-yellow-300 hover:scale-105 text-black font-bold py-3 px-4 rounded-lg transition-all duration-200 shadow-lg shadow-yellow-500/25">
                        🔄 Update Stock
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
{% endblock %}