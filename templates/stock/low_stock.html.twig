{% extends 'layout.html.twig' %}

{% block title %}Low Stock Alerts - Samaco Brewery{% endblock %}

{% block dashboard_content %}
<div class="container mx-auto px-4 py-8">
    <div class="flex justify-between items-center mb-6">
        <h1 class="text-3xl font-bold text-yellow-500">⚠️ Low Stock Alerts</h1>
        <a href="{{ path('app_stock_index') }}" class="bg-gray-600 hover:bg-gray-700 text-white px-4 py-2 rounded-lg transition duration-200">
            ← Back to Stock
        </a>
    </div>

    {% if products|length > 0 %}
        <div class="bg-red-900/20 border border-red-500 rounded-lg p-4 mb-6">
            <p class="text-red-400 flex items-center gap-2">
                <span>⚠️</span> The following products are below their minimum stock level!
            </p>
        </div>

        <div class="bg-gray-800/80 rounded-lg shadow-lg overflow-hidden">
            <table class="min-w-full divide-y divide-gray-700">
                <thead class="bg-gray-900">
                    <tr class="bg-yellow-500/15">
                        <th class="px-6 py-3 text-left text-xs font-semibold text-yellow-500 uppercase tracking-wider">Product</th>
                        <th class="px-6 py-3 text-left text-xs font-semibold text-yellow-500 uppercase tracking-wider">Category</th>
                        <th class="px-6 py-3 text-left text-xs font-semibold text-yellow-500 uppercase tracking-wider">Current Stock</th>
                        <th class="px-6 py-3 text-left text-xs font-semibold text-yellow-500 uppercase tracking-wider">Minimum Stock</th>
                        <th class="px-6 py-3 text-left text-xs font-semibold text-yellow-500 uppercase tracking-wider">Shortage</th>
                        <th class="px-6 py-3 text-left text-xs font-semibold text-yellow-500 uppercase tracking-wider">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-700">
                    {% for product in products %}
                        {% set shortage = product.minimumStock - product.stockQuantity %}
                        <tr class="hover:bg-yellow-500/10 bg-red-900/10 transition-colors">
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-white font-medium">{{ product.name }}</td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-300">{{ product.category.name ?? 'Uncategorized' }}</td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm font-bold text-red-500">{{ product.stockQuantity }}</td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-300">{{ product.minimumStock }}</td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-yellow-500 font-semibold">-{{ shortage }}</td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm">
                                <a href="{{ path('app_stock_adjust', {'id': product.id}) }}" class="inline-flex items-center gap-1 px-3 py-1.5 bg-yellow-900/30 text-yellow-300 border border-yellow-500/50 rounded-md text-xs font-semibold hover:bg-yellow-900/50 transition">
                                    📦 Restock Now
                                </a>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    {% else %}
        <div class="bg-green-900/20 border border-green-500 rounded-lg p-6 text-center">
            <div class="text-5xl mb-3 opacity-60">✅</div>
            <p class="text-green-400 text-lg">All products have sufficient stock!</p>
            <p class="text-gray-400 mt-2">No low stock alerts at this time.</p>
        </div>
    {% endif %}
</div>
{% endblock %}