<div class="max-w-4xl mx-auto p-4">
    {{ form_start(form, {'attr': {'class': 'space-y-8'}}) }}
        
        <!-- Form Container -->
        <div class="bg-gray-900/80 backdrop-blur-sm rounded-2xl border border-gray-700/50 shadow-2xl p-6 md:p-8">
            
            <!-- Form Header -->
            <div class="mb-8">
                <h2 class="text-2xl md:text-3xl font-bold text-yellow-400 mb-2">
                    {{ button_label|default('Create User') }}
                </h2>
                <p class="text-gray-400">Manage user account details and permissions</p>
            </div>

            <!-- Form Fields -->
            <div class="space-y-8">
                <!-- Email Field -->
                <div>
                    {{ form_label(form.email, 'Email Address', {
                        'label_attr': {
                            'class': 'block text-sm font-semibold text-yellow-300 mb-2'
                        }
                    }) }}
                    
                    {{ form_widget(form.email, {
                        'attr': {
                            'class': 'w-full px-4 py-3.5 bg-gray-800/50 border border-gray-700 rounded-xl 
                                     text-white placeholder-gray-500 focus:outline-none focus:ring-2 
                                     focus:ring-yellow-500 focus:border-yellow-500 transition duration-200
                                     hover:border-gray-600 text-base',
                            'placeholder': 'user@example.com',
                            'autocomplete': 'email'
                        }
                    }) }}
                    
                    {% if form.email.vars.errors|length > 0 %}
                        <div class="mt-2 text-sm text-red-400 space-y-1">
                            {{ form_errors(form.email) }}
                        </div>
                    {% endif %}
                </div>

                <!-- Name Grid -->
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <!-- First Name Field -->
                    <div>
                        {{ form_label(form.firstName, 'First Name', {
                            'label_attr': {
                                'class': 'block text-sm font-semibold text-yellow-300 mb-2'
                            }
                        }) }}
                        
                        {{ form_widget(form.firstName, {
                            'attr': {
                                'class': 'w-full px-4 py-3.5 bg-gray-800/50 border border-gray-700 rounded-xl 
                                         text-white placeholder-gray-500 focus:outline-none focus:ring-2 
                                         focus:ring-yellow-500 focus:border-yellow-500 transition duration-200
                                         hover:border-gray-600 text-base',
                                'placeholder': 'John',
                                'autocomplete': 'given-name'
                            }
                        }) }}
                        
                        {% if form.firstName.vars.errors|length > 0 %}
                            <div class="mt-2 text-sm text-red-400 space-y-1">
                                {{ form_errors(form.firstName) }}
                            </div>
                        {% endif %}
                    </div>

                    <!-- Last Name Field -->
                    <div>
                        {{ form_label(form.lastName, 'Last Name', {
                            'label_attr': {
                                'class': 'block text-sm font-semibold text-yellow-300 mb-2'
                            }
                        }) }}
                        
                        {{ form_widget(form.lastName, {
                            'attr': {
                                'class': 'w-full px-4 py-3.5 bg-gray-800/50 border border-gray-700 rounded-xl 
                                         text-white placeholder-gray-500 focus:outline-none focus:ring-2 
                                         focus:ring-yellow-500 focus:border-yellow-500 transition duration-200
                                         hover:border-gray-600 text-base',
                                'placeholder': 'Doe',
                                'autocomplete': 'family-name'
                            }
                        }) }}
                        
                        {% if form.lastName.vars.errors|length > 0 %}
                            <div class="mt-2 text-sm text-red-400 space-y-1">
                                {{ form_errors(form.lastName) }}
                            </div>
                        {% endif %}
                    </div>
                </div>

                <!-- Password Field -->
                <div>
                    {{ form_label(form.plainPassword, 'Password', {
                        'label_attr': {
                            'class': 'block text-sm font-semibold text-yellow-300 mb-2'
                        }
                    }) }}
                    
                    <div class="relative">
                        {{ form_widget(form.plainPassword, {
                            'attr': {
                                'class': 'w-full px-4 py-3.5 pr-12 bg-gray-800/50 border border-gray-700 rounded-xl 
                                         text-white placeholder-gray-500 focus:outline-none focus:ring-2 
                                         focus:ring-yellow-500 focus:border-yellow-500 transition duration-200
                                         hover:border-gray-600 text-base',
                                'placeholder': 'Enter password',
                                'autocomplete': 'new-password'
                            }
                        }) }}
                        
                        <!-- Password Toggle Icon -->
                        <button type="button"
                                class="absolute right-3 top-1/2 transform -translate-y-1/2 text-gray-400 hover:text-yellow-400 transition-colors"
                                onclick="togglePasswordVisibility(this)">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" id="eye-icon">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" 
                                      d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" 
                                      d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
                            </svg>
                        </button>
                    </div>
                    
                    <!-- Password Requirements -->
                    <div class="mt-3 bg-gray-800/30 rounded-lg p-4">
                        <p class="text-sm font-medium text-gray-300 mb-2">Password requirements:</p>
                        <ul class="text-xs text-gray-400 space-y-1">
                            <li class="flex items-center gap-2">
                                <svg class="w-4 h-4 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                                </svg>
                                At least 8 characters
                            </li>
                            <li class="flex items-center gap-2">
                                <svg class="w-4 h-4 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                                </svg>
                                Mix of uppercase & lowercase letters
                            </li>
                            <li class="flex items-center gap-2">
                                <svg class="w-4 h-4 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                                </svg>
                                Include numbers and special characters
                            </li>
                        </ul>
                    </div>
                    
                    {% if form.plainPassword.vars.errors|length > 0 %}
                        <div class="mt-2 text-sm text-red-400 space-y-1">
                            {{ form_errors(form.plainPassword) }}
                        </div>
                    {% endif %}
                </div>

                <!-- Roles Field -->
                <div>
                    {{ form_label(form.roles, 'User Roles', {
                        'label_attr': {
                            'class': 'block text-sm font-semibold text-yellow-300 mb-2'
                        }
                    }) }}
                    
                    {{ form_widget(form.roles, {
                        'attr': {
                            'class': 'w-full px-4 py-3.5 bg-gray-800/50 border border-gray-700 rounded-xl 
                                     text-white placeholder-gray-500 focus:outline-none focus:ring-2 
                                     focus:ring-yellow-500 focus:border-yellow-500 transition duration-200
                                     hover:border-gray-600 text-base'
                        }
                    }) }}
                    
                    <div class="mt-3 flex flex-wrap gap-2">
                        <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium bg-yellow-900/30 text-yellow-300 border border-yellow-700/50">
                            <svg class="w-3 h-3 mr-1" fill="currentColor" viewBox="0 0 20 20">
                                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                            </svg>
                            ROLE_USER - Basic access
                        </span>
                        <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium bg-purple-900/30 text-purple-300 border border-purple-700/50">
                            <svg class="w-3 h-3 mr-1" fill="currentColor" viewBox="0 0 20 20">
                                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                            </svg>
                            ROLE_ADMIN - Full access
                        </span>
                    </div>
                    
                    {% if form.roles.vars.errors|length > 0 %}
                        <div class="mt-2 text-sm text-red-400 space-y-1">
                            {{ form_errors(form.roles) }}
                        </div>
                    {% endif %}
                </div>
            </div>

            <!-- Action Buttons -->
            <div class="flex flex-col sm:flex-row gap-4 mt-12 pt-8 border-t border-gray-700/50">
                <!-- Submit Button -->
                <button type="submit"
                        class="group inline-flex items-center justify-center gap-3 px-8 py-4 text-base font-bold 
                               bg-gradient-to-r from-yellow-600 to-yellow-700 text-black rounded-xl
                               hover:from-yellow-500 hover:to-yellow-600 active:scale-[0.98]
                               shadow-lg hover:shadow-xl shadow-yellow-900/30
                               border border-yellow-800/30 transition-all duration-200
                               focus:outline-none focus:ring-2 focus:ring-yellow-500 focus:ring-offset-2 focus:ring-offset-gray-900
                               flex-1 sm:flex-none min-h-[52px]">
                    
                    <svg class="w-5 h-5 transition-transform group-hover:scale-110" 
                         fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" 
                              d="M5 13l4 4L19 7"></path>
                    </svg>
                    
                    <span>{{ button_label|default('Save User') }}</span>
                </button>

                <!-- Cancel Button -->
                <a href="{{ path('app_user_index') }}"
                   class="inline-flex items-center justify-center gap-3 px-8 py-4 text-base font-semibold
                          bg-gray-800/60 text-gray-300 rounded-xl hover:bg-gray-800 hover:text-white
                          active:scale-[0.98] border border-gray-700/50 transition-all duration-200
                          focus:outline-none focus:ring-2 focus:ring-gray-500 focus:ring-offset-2 focus:ring-offset-gray-900
                          flex-1 sm:flex-none min-h-[52px]">
                    
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" 
                              d="M6 18L18 6M6 6l12 12"></path>
                    </svg>
                    
                    <span>Cancel</span>
                </a>
            </div>
        </div>

    {{ form_end(form) }}
</div>

<!-- Password Toggle Script -->
<script>
function togglePasswordVisibility(button) {
    const input = button.previousElementSibling;
    const eyeIcon = button.querySelector('#eye-icon');
    
    if (input.type === 'password') {
        input.type = 'text';
        eyeIcon.innerHTML = `
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" 
                  d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.878 9.878L6.59 6.59m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21"/>
        `;
        button.setAttribute('aria-label', 'Hide password');
    } else {
        input.type = 'password';
        eyeIcon.innerHTML = `
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" 
                  d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" 
                  d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
        `;
        button.setAttribute('aria-label', 'Show password');
    }
}
</script>