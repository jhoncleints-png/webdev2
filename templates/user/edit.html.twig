{% extends 'layout.html.twig' %}

{% block title %}Edit User - Samaco Brewery{% endblock %}

{% block dashboard_content %}
<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
    
    <!-- Page Header -->
    <div class="mb-8">
        <!-- Breadcrumb -->
        <nav class="flex items-center gap-2 text-sm text-gray-400 mb-6">
            <a href="{{ path('app_dashboard_home') }}" 
               class="hover:text-yellow-400 transition-colors duration-200">
                Dashboard
            </a>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
            </svg>
            <a href="{{ path('app_user_index') }}" 
               class="hover:text-yellow-400 transition-colors duration-200">
                Users
            </a>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
            </svg>
            <span class="text-yellow-400 font-medium">Edit User</span>
        </nav>
        
        <!-- Main Heading -->
        <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
            <div>
                <h1 class="text-3xl md:text-4xl font-bold text-white mb-2 flex items-center gap-3">
                    <svg class="w-8 h-8 text-yellow-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
                    </svg>
                    Edit User
                </h1>
                <p class="text-gray-400 ml-11">
                    Update user information and permissions
                </p>
            </div>
            
            <!-- Back Button -->
            <a href="{{ path('app_user_index') }}"
               class="inline-flex items-center gap-2 px-5 py-3 text-sm font-semibold text-white 
                      bg-gray-700 rounded-xl hover:bg-gray-600 hover:text-white transition-all duration-200
                      border border-gray-600 focus:outline-none focus:ring-2 focus:ring-yellow-500 focus:ring-offset-2 focus:ring-offset-gray-900
                      self-start sm:self-center shadow-md">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
                </svg>
                Back to Users
            </a>
        </div>
    </div>

    <!-- Single Grey Outer Box -->
    <div class="bg-gray-900/50 backdrop-blur-sm rounded-2xl border border-gray-700/50 shadow-xl p-6 md:p-8">
        
        <!-- Form Section -->
        <div class="mb-8">
            <div class="mb-6">
                <h2 class="text-2xl font-bold text-yellow-400 mb-2 flex items-center gap-3">
                    <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
                    </svg>
                    User Information
                </h2>
                <p class="text-gray-400">Modify user details, permissions, and account settings</p>
            </div>
            
            <!-- Include Form -->
            <div class="max-w-4xl mx-auto">
                {{ include('user/_form.html.twig', {'button_label': 'Update User'}) }}
            </div>
        </div>

        <!-- Account Info Section -->
        <div class="mb-8 pt-8 border-t border-gray-700">
            <div class="mb-6">
                <div class="flex items-center gap-3 mb-2">
                    <svg class="w-7 h-7 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
                    </svg>
                    <h2 class="text-2xl font-bold text-blue-400">Account Status</h2>
                </div>
                <p class="text-gray-400 ml-10">Current account information and statistics</p>
            </div>
            
            <div class="bg-gray-900 rounded-xl border border-gray-700 p-6">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        <h3 class="text-lg font-semibold text-white mb-4">Account Details</h3>
                        <div class="space-y-4">
                            <div class="flex items-center justify-between">
                                <span class="text-gray-400">Member Since</span>
                                <span class="text-white font-medium">
                                    {{ user.createdAt ? user.createdAt|date('M d, Y') : 'N/A' }}
                                </span>
                            </div>
                            <div class="flex items-center justify-between">
                                <span class="text-gray-400">Last Updated</span>
                                <span class="text-white font-medium">
                                    {{ user.updatedAt ? user.updatedAt|date('M d, Y') : 'N/A' }}
                                </span>
                            </div>
                            <div class="flex items-center justify-between">
                                <span class="text-gray-400">Account Status</span>
                                <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-green-900/30 text-green-400 border border-green-700/50">
                                    Active
                                </span>
                            </div>
                        </div>
                    </div>
                    <div>
                        <h3 class="text-lg font-semibold text-white mb-4">Current Permissions</h3>
                        <div class="space-y-3">
                            {% for role in user.roles %}
                                <div class="flex items-center justify-between">
                                    <span class="text-gray-300">{{ role }}</span>
                                    {% if role == 'ROLE_ADMIN' %}
                                        <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-purple-900/30 text-purple-300 border border-purple-700/50">
                                            Administrator
                                        </span>
                                    {% else %}
                                        <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-yellow-900/30 text-yellow-300 border border-yellow-700/50">
                                            Standard User
                                        </span>
                                    {% endif %}
                                </div>
                            {% endfor %}
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Danger Zone (Admin Only) -->
        {% if is_granted('ROLE_ADMIN') %}
        <div class="pt-8 border-t border-gray-700">
            <div class="mb-6">
                <div class="flex items-center gap-3 mb-2">
                    <svg class="w-7 h-7 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.282 16.5c-.77.833.192 2.5 1.732 2.5z"></path>
                    </svg>
                    <h2 class="text-2xl font-bold text-red-400">Danger Zone</h2>
                </div>
                <p class="text-gray-400 ml-10">Irreversible actions that will permanently affect this user account</p>
            </div>
            
            <!-- Delete Form - Black inner box -->
            <div class="bg-gray-900 rounded-xl border border-gray-700 p-6">
                {{ include('user/_delete_form.html.twig') }}
            </div>
        </div>
        {% endif %}

    </div>
</div>
{% endblock %}