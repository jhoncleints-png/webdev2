{% extends 'layout.html.twig' %}

{% block title %}Edit User - Samaco Brewery{% endblock %}

{% block dashboard_content %}
<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
    
    <!-- Page Header -->
    <div class="mb-8">
        <!-- Breadcrumb -->
        <nav class="flex items-center gap-2 text-sm text-gray-400 mb-6">
            <a href="{{ path('app_dashboard_home') }}" 
               class="hover:text-yellow-400 transition-colors duration-200">
                Dashboard
            </a>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
            </svg>
            <a href="{{ path('app_user_index') }}" 
               class="hover:text-yellow-400 transition-colors duration-200">
                Users
            </a>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
            </svg>
            <span class="text-yellow-400 font-medium">Edit User</span>
        </nav>
        
        <!-- Main Heading -->
        <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
            <div>
                <h1 class="text-3xl md:text-4xl font-bold text-white mb-2">
                    Edit User
                </h1>
                <p class="text-gray-400">
                    Update user information and permissions
                </p>
            </div>
            
            <!-- Back Button -->
            <a href="{{ path('app_user_index') }}"
               class="inline-flex items-center gap-2 px-5 py-3 text-sm font-semibold text-gray-300 
                      bg-gray-800/50 rounded-xl hover:bg-gray-800 hover:text-white transition-all duration-200
                      border border-gray-700/50 focus:outline-none focus:ring-2 focus:ring-gray-500 focus:ring-offset-2 focus:ring-offset-gray-900
                      self-start sm:self-center">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
                </svg>
                Back to Users
            </a>
        </div>
    </div>

    <!-- Main Content -->
    <div class="space-y-8">
        
        <!-- Form Section -->
        <div class="bg-gray-900/50 backdrop-blur-sm rounded-2xl border border-gray-700/50 shadow-xl p-6 md:p-8">
            <div class="mb-8">
                <h2 class="text-2xl font-bold text-yellow-400 mb-2 flex items-center gap-3">
                    <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" 
                              d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
                    </svg>
                    User Information
                </h2>
                <p class="text-gray-400">Modify user details, permissions, and account settings</p>
            </div>
            
            <!-- Include Form -->
            <div class="max-w-4xl mx-auto">
                {{ include('user/_form.html.twig', {'button_label': 'Update User'}) }}
            </div>
        </div>

        <!-- Account Status -->
        <div class="bg-blue-900/10 backdrop-blur-sm rounded-2xl border border-blue-800/30 shadow-xl p-6 md:p-8">
            <div class="mb-8">
                <h2 class="text-2xl font-bold text-blue-400 mb-2 flex items-center gap-3">
                    <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" 
                              d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
                    </svg>
                    Account Status
                </h2>
                <p class="text-gray-400">Current account information and statistics</p>
            </div>
            
            <div class="max-w-4xl mx-auto">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <!-- Account Info Card -->
                    <div class="bg-gray-800/30 rounded-xl p-6 border border-gray-700/50">
                        <h3 class="text-lg font-semibold text-white mb-4">Account Details</h3>
                        <div class="space-y-4">
                            <div class="flex items-center justify-between">
                                <span class="text-gray-400">Member Since</span>
                                <span class="text-white font-medium">
                                    {{ user.createdAt ? user.createdAt|date('M d, Y') : 'N/A' }}
                                </span>
                            </div>
                            <div class="flex items-center justify-between">
                                <span class="text-gray-400">Last Updated</span>
                                <span class="text-white font-medium">
                                    {{ user.updatedAt ? user.updatedAt|date('M d, Y') : 'N/A' }}
                                </span>
                            </div>
                            <div class="flex items-center justify-between">
                                <span class="text-gray-400">Account Status</span>
                                <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-green-900/30 text-green-400 border border-green-700/50">
                                    <svg class="w-3 h-3 mr-1" fill="currentColor" viewBox="0 0 20 20">
                                        <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                                    </svg>
                                    Active
                                </span>
                            </div>
                        </div>
                    </div>

                    <!-- Permissions Card -->
                    <div class="bg-gray-800/30 rounded-xl p-6 border border-gray-700/50">
                        <h3 class="text-lg font-semibold text-white mb-4">Current Permissions</h3>
                        <div class="space-y-3">
                            {% for role in user.roles %}
                                <div class="flex items-center justify-between">
                                    <span class="text-gray-300">{{ role }}</span>
                                    {% if role == 'ROLE_ADMIN' %}
                                        <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-purple-900/30 text-purple-300 border border-purple-700/50">
                                            Administrator
                                        </span>
                                    {% else %}
                                        <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-yellow-900/30 text-yellow-300 border border-yellow-700/50">
                                            Standard User
                                        </span>
                                    {% endif %}
                                </div>
                            {% endfor %}
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Danger Zone (Admin Only) -->
        {% if is_granted('ROLE_ADMIN') %}
        <div class="bg-red-900/10 backdrop-blur-sm rounded-2xl border border-red-800/30 shadow-xl p-6 md:p-8">
            <div class="mb-8">
                <h2 class="text-2xl font-bold text-red-400 mb-2 flex items-center gap-3">
                    <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.282 16.5c-.77.833.192 2.5 1.732 2.5z"></path>
                    </svg>
                    Danger Zone
                </h2>
                <p class="text-gray-400">Irreversible actions that will permanently affect this user account</p>
            </div>
            
            <div class="max-w-4xl mx-auto space-y-6">
                <!-- Account Actions -->
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <!-- Reset Password Card -->
                    <div class="bg-gray-800/30 rounded-xl p-6 border border-gray-700/50">
                        <div class="flex items-start gap-4">
                            <div class="p-3 rounded-lg bg-yellow-900/20 border border-yellow-800/30">
                                <svg class="w-6 h-6 text-yellow-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" 
                                          d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z"></path>
                                </svg>
                            </div>
                            <div>
                                <h3 class="text-lg font-semibold text-white mb-2">Reset Password</h3>
                                <p class="text-gray-400 text-sm mb-4">
                                    Generate a new temporary password for this user
                                </p>
                                <button type="button"
                                        onclick="alert('Password reset functionality would be implemented here')"
                                        class="inline-flex items-center gap-2 px-4 py-2 text-sm font-medium 
                                               bg-yellow-900/30 text-yellow-300 rounded-lg hover:bg-yellow-900/40 
                                               border border-yellow-800/50 transition-colors duration-200">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" 
                                              d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path>
                                    </svg>
                                    Reset Password
                                </button>
                            </div>
                        </div>
                    </div>

                    <!-- Deactivate Account Card -->
                    <div class="bg-gray-800/30 rounded-xl p-6 border border-gray-700/50">
                        <div class="flex items-start gap-4">
                            <div class="p-3 rounded-lg bg-orange-900/20 border border-orange-800/30">
                                <svg class="w-6 h-6 text-orange-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" 
                                          d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636"></path>
                                </svg>
                            </div>
                            <div>
                                <h3 class="text-lg font-semibold text-white mb-2">Deactivate Account</h3>
                                <p class="text-gray-400 text-sm mb-4">
                                    Temporarily disable this user's account access
                                </p>
                                <button type="button"
                                        onclick="alert('Account deactivation would be implemented here')"
                                        class="inline-flex items-center gap-2 px-4 py-2 text-sm font-medium 
                                               bg-orange-900/30 text-orange-300 rounded-lg hover:bg-orange-900/40 
                                               border border-orange-800/50 transition-colors duration-200">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" 
                                              d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.878 9.878L6.59 6.59m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21"></path>
                                    </svg>
                                    Deactivate Account
                                </button>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Delete Form -->
                {{ include('user/_delete_form.html.twig') }}
            </div>
        </div>
        {% endif %}

    </div>
</div>
{% endblock %}