{% extends 'layout.html.twig' %}

{% block title %}User Management - Samaco Brewery{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <!-- DataTables CSS -->
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css">
{% endblock %}

{% block dashboard_content %}
<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
    
    <!-- Page Header with Icon -->
    <div class="bg-gradient-to-r from-black to-gray-900 rounded-2xl border-l-4 border-yellow-400 p-6 mb-8 shadow-xl">
        <div class="flex items-center gap-3 mb-2">
            <div class="w-12 h-12 bg-yellow-500/20 rounded-xl flex items-center justify-center border border-yellow-500/30">
                <svg class="w-7 h-7 text-yellow-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"></path>
                </svg>
            </div>
            <div>
                <h1 class="text-2xl md:text-3xl font-bold text-yellow-400">User Management</h1>
                <p class="text-gray-400 text-sm">Manage system users and their permissions</p>
            </div>
        </div>
    </div>

    <!-- Create Button -->
    <div class="mb-8">
        <a href="{{ path('app_user_new') }}" 
           class="inline-flex items-center gap-3 px-6 py-3 bg-yellow-500 text-black font-bold rounded-xl hover:bg-yellow-400 transition-all duration-200 shadow-lg shadow-yellow-500/25 hover:shadow-xl hover:scale-105">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
            </svg>
            <span>Create New User</span>
        </a>
    </div>

    <!-- View Toggle - Modern Design -->
    <div class="flex gap-2 mb-6">
        <button class="toggle-btn active flex items-center gap-2 px-5 py-2.5 bg-yellow-500 text-black font-semibold rounded-lg transition-all duration-200 shadow-md" data-view="grid">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"></path>
            </svg>
            <span>Grid View</span>
        </button>
        <button class="toggle-btn flex items-center gap-2 px-5 py-2.5 bg-gray-800 text-gray-300 font-semibold rounded-lg hover:bg-gray-700 transition-all duration-200" data-view="table">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M3 14h18m-9-4v8m-7 0h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"></path>
            </svg>
            <span>Table View</span>
        </button>
    </div>

    <!-- Advanced Filters - Grid View Only -->
    <div id="customFilters" class="bg-gray-900/80 backdrop-blur-sm rounded-2xl border border-gray-700/50 p-6 mb-8 shadow-xl">
        <div class="flex items-center gap-2 mb-5">
            <svg class="w-5 h-5 text-yellow-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z"></path>
            </svg>
            <h3 class="text-yellow-400 font-semibold">Filter Users</h3>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
            <div>
                <label class="block text-yellow-300 text-sm font-semibold mb-2">Full Name</label>
                <input type="text" id="searchName" placeholder="Search by name..." 
                       class=" px-4 py-2.5 bg-gray-800/50 border border-gray-700 rounded-xl text-white placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-yellow-500 focus:border-yellow-500 transition duration-200">
            </div>
            <div>
                <label class="block text-yellow-300 text-sm font-semibold mb-2">Email Address</label>
                <input type="text" id="searchEmail" placeholder="Search by email..." 
                       class=" px-4 py-2.5 bg-gray-800/50 border border-gray-700 rounded-xl text-white placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-yellow-500 focus:border-yellow-500 transition duration-200">
            </div>
            <div>
                <label class="block text-yellow-300 text-sm font-semibold mb-2">User Role</label>
                <select id="filterRole" style="min-width: 160px;" class="px-4 py-2.5 bg-gray-800/50 border border-gray-700 rounded-xl text-white focus:outline-none focus:ring-2 focus:ring-yellow-500 focus:border-yellow-500 transition duration-200">
                    <option value="">All Roles</option>
                    <option value="ROLE_ADMIN">Administrator</option>
                    <option value="ROLE_STAFF">Staff Member</option>
                    <option value="ROLE_USER">Regular User</option>
                </select>
            </div>
            <div>
                <label class="block text-yellow-300 text-sm font-semibold mb-2">Account Status</label>
                <select id="filterStatus" style="min-width: 160px;" class="px-4 py-2.5 bg-gray-800/50 border border-gray-700 rounded-xl text-white focus:outline-none focus:ring-2 focus:ring-yellow-500 focus:border-yellow-500 transition duration-200">
                    <option value="">All Status</option>
                    <option value="Active">Active</option>
                    <option value="Disabled">Disabled</option>
                </select>
            </div>
        </div>
        <div class="flex justify mt-6">
            <button id="resetFilters" class="inline-flex items-center gap-2 px-5 py-2.5 bg-gray-800 text-gray-300 font-semibold rounded-xl hover:bg-gray-700 transition-all duration-200 border border-gray-700">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path>
                </svg>
                Reset Filters
            </button>
        </div>
    </div>

    <!-- Grid View -->
    <div id="grid-view">
        {% if users is empty %}
            <div class="text-center py-16 px-4 bg-gray-900/50 backdrop-blur-sm rounded-2xl border border-gray-700/50">
                <div class="text-6xl mb-4 opacity-60">👤</div>
                <h3 class="text-xl font-bold text-yellow-400 mb-2">No Users Found</h3>
                <p class="text-gray-400 mb-6">Get started by creating your first user</p>
                <a href="{{ path('app_user_new') }}" class="inline-flex items-center gap-2 px-5 py-2.5 bg-yellow-500 text-black font-semibold rounded-xl hover:bg-yellow-400 transition-all duration-200 shadow-md">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
                    </svg>
                    Create First User
                </a>
            </div>
        {% else %}
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6" id="usersGrid">
                {% for user in users %}
                    <div class="user-card bg-gray-900/80 backdrop-blur-sm rounded-2xl border border-gray-700/50 hover:border-yellow-500/40 hover:-translate-y-1 transition-all duration-300 overflow-hidden shadow-lg"
                         data-name="{{ (user.firstName ~ ' ' ~ user.lastName)|lower }}" 
                         data-email="{{ user.email|lower }}"
                         data-roles="{{ user.roles|join(' ')|lower }}"
                         data-status="{{ user.isActive ? 'active' : 'disabled' }}">
                        
                        <!-- Card Header Gradient -->
                        <div class="h-1.5 bg-gradient-to-r from-yellow-500 to-yellow-600"></div>
                        
                        <div class="p-5">
                            <div class="text-center mb-4">
                                <h3 class="text-lg font-bold text-white">{{ user.firstName }} {{ user.lastName }}</h3>
                                <p class="text-gray-400 text-sm mt-1">{{ user.email }}</p>
                                <span class="inline-block mt-2 text-xs text-gray-500 bg-gray-800/50 px-2 py-0.5 rounded-full">ID: #{{ user.id }}</span>
                            </div>
                            
                            <div class="space-y-2 mb-5">
                                <div class="flex justify-between items-center py-1.5 border-b border-gray-800">
                                    <span class="text-gray-400 text-sm flex items-center gap-2">
                                        <svg class="w-3.5 h-3.5 text-yellow-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
                                        </svg>
                                        Role:
                                    </span>
                                    <div class="flex flex-wrap gap-1">
                                        {% for role in user.roles %}
                                            {% if role == 'ROLE_ADMIN' %}
                                                <span class="px-2 py-0.5 text-xs font-semibold rounded-full bg-red-900/40 text-red-300 border border-red-700/50">Admin</span>
                                            {% elseif role == 'ROLE_STAFF' %}
                                                <span class="px-2 py-0.5 text-xs font-semibold rounded-full bg-yellow-900/40 text-yellow-300 border border-yellow-700/50">Staff</span>
                                            {% elseif role == 'ROLE_USER' %}
                                                <span class="px-2 py-0.5 text-xs font-semibold rounded-full bg-blue-900/40 text-blue-300 border border-blue-700/50">User</span>
                                            {% endif %}
                                        {% endfor %}
                                    </div>
                                </div>
                                <div class="flex justify-between items-center py-1.5 border-b border-gray-800">
                                    <span class="text-gray-400 text-sm flex items-center gap-2">
                                        <svg class="w-3.5 h-3.5 text-yellow-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                                        </svg>
                                        Status:
                                    </span>
                                    {% if user.isActive %}
                                        <span class="px-2 py-0.5 text-xs font-semibold rounded-full bg-green-900/40 text-green-300 border border-green-700/50">● Active</span>
                                    {% else %}
                                        <span class="px-2 py-0.5 text-xs font-semibold rounded-full bg-gray-700 text-gray-400 border border-gray-600">● Disabled</span>
                                    {% endif %}
                                </div>
                                <div class="flex justify-between items-center py-1.5">
                                    <span class="text-gray-400 text-sm flex items-center gap-2">
                                        <svg class="w-3.5 h-3.5 text-yellow-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                                        </svg>
                                        Joined:
                                    </span>
                                    <span class="text-gray-300 text-sm">{{ user.createdAt|date('M d, Y') }}</span>
                                </div>
                            </div>

                            {# action buttons #}
                            <div class="flex gap-2 pt-4 border-t border-gray-800">
                                <a href="{{ path('app_user_show', {'id': user.id}) }}" class="flex-1 text-center px-3 py-2 rounded-xl transition-all duration-200" style="background-color: rgba(16, 185, 129, 0.2); border: 1px solid rgba(16, 185, 129, 0.4);">
                                    <div class="text-base mb-0.5" style="color: #10b981;">👁️</div>
                                    <div class="text-xs font-semibold" style="color: #10b981;">View</div>
                                </a>
                                <a href="{{ path('app_user_edit', {'id': user.id}) }}" class="flex-1 text-center px-3 py-2 rounded-xl transition-all duration-200" style="background-color: rgba(59, 130, 246, 0.2); border: 1px solid rgba(59, 130, 246, 0.4);">
                                    <div class="text-base mb-0.5" style="color: #3b82f6;">✏️</div>
                                    <div class="text-xs font-semibold" style="color: #3b82f6;">Edit</div>
                                </a>
                                {% if user.id != app.user.id %}
                                    <form method="post" action="{{ path('app_user_toggle_status', {'id': user.id}) }}" class="flex-1">
                                        <input type="hidden" name="_token" value="{{ csrf_token('toggle-status' ~ user.id) }}">
                                        <button type="submit" class="w-full text-center px-3 py-2 rounded-xl transition-all duration-200" style="background-color: rgba(245, 158, 11, 0.2); border: 1px solid rgba(245, 158, 11, 0.4);">
                                            <div class="text-base mb-0.5" style="color: #f59e0b;">🔒</div>
                                            <div class="text-xs font-semibold" style="color: #f59e0b;">{{ user.isActive ? 'Disable' : 'Enable' }}</div>
                                        </button>
                                    </form>
                                    <form method="post" action="{{ path('app_user_delete', {'id': user.id}) }}" class="flex-1">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ user.id) }}">
                                        <button type="submit" class="w-full text-center px-3 py-2 rounded-xl transition-all duration-200" style="background-color: rgba(239, 68, 68, 0.2); border: 1px solid rgba(239, 68, 68, 0.4);">
                                            <div class="text-base mb-0.5" style="color: #ef4444;">🗑️</div>
                                            <div class="text-xs font-semibold" style="color: #ef4444;">Delete</div>
                                        </button>
                                    </form>
                                {% else %}
                                    <span class="flex-1 text-center px-3 py-2 text-xs text-gray-500 italic bg-gray-800/30 rounded-xl">Current</span>
                                {% endif %}
                            </div>
                        </div>
                    </div>
                {% endfor %}
            </div>
            
            <!-- No Results Message -->
            <div id="noResults" class="text-center py-16 px-4 bg-gray-900/50 backdrop-blur-sm rounded-2xl border border-gray-700/50 hidden">
                <div class="text-5xl mb-4 opacity-60">🔍</div>
                <h3 class="text-xl font-bold text-yellow-400 mb-2">No Users Found</h3>
                <p class="text-gray-400">No users match your filter criteria. Try adjusting your search.</p>
            </div>
        {% endif %}
    </div>

    <!-- Table View (Hidden by default) -->
    <div id="table-view" style="display: none;">
        {% if users is not empty %}
            <div class="bg-gray-900/80 backdrop-blur-sm rounded-2xl border border-gray-700/50 shadow-xl overflow-hidden">
                <div class="overflow-x-auto">
                    <table id="userTable" class="w-full">
                        <thead>
                            <tr class="bg-gray-800/50 border-b border-gray-700">
                                <th class="py-4 px-4 text-left text-sm font-semibold text-yellow-400">ID</th>
                                <th class="py-4 px-4 text-left text-sm font-semibold text-yellow-400">Email</th>
                                <th class="py-4 px-4 text-left text-sm font-semibold text-yellow-400">Name</th>
                                <th class="py-4 px-4 text-left text-sm font-semibold text-yellow-400">Roles</th>
                                <th class="py-4 px-4 text-left text-sm font-semibold text-yellow-400">Status</th>
                                <th class="py-4 px-4 text-left text-sm font-semibold text-yellow-400">Created</th>
                                <th class="py-4 px-4 text-left text-sm font-semibold text-yellow-400">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for user in users %}
                                <tr class="border-b border-gray-800 hover:bg-yellow-500/5 transition-all duration-200">
                                    <td class="py-3 px-4 text-white font-mono text-sm">#{{ user.id }}</td>
                                    <td class="py-3 px-4 text-gray-300">{{ user.email }}</td>
                                    <td class="py-3 px-4 text-white font-medium">{{ user.firstName }} {{ user.lastName }}</td>
                                    <td class="py-3 px-4">
                                        <div class="flex flex-wrap gap-1">
                                            {% for role in user.roles %}
                                                {% if role == 'ROLE_ADMIN' %}
                                                    <span class="px-2 py-0.5 text-xs font-semibold rounded-full bg-red-900/40 text-red-300 border border-red-700/50">Admin</span>
                                                {% elseif role == 'ROLE_STAFF' %}
                                                    <span class="px-2 py-0.5 text-xs font-semibold rounded-full bg-yellow-900/40 text-yellow-300 border border-yellow-700/50">Staff</span>
                                                {% elseif role == 'ROLE_USER' %}
                                                    <span class="px-2 py-0.5 text-xs font-semibold rounded-full bg-blue-900/40 text-blue-300 border border-blue-700/50">User</span>
                                                {% endif %}
                                            {% endfor %}
                                        </div>
                                    </td>
                                    <td class="py-3 px-4">
                                        {% if user.isActive %}
                                            <span class="px-2 py-0.5 text-xs font-semibold rounded-full bg-green-900/40 text-green-300 border border-green-700/50">Active</span>
                                        {% else %}
                                            <span class="px-2 py-0.5 text-xs font-semibold rounded-full bg-gray-700 text-gray-400 border border-gray-600">Disabled</span>
                                        {% endif %}
                                    </td>
                                    <td class="py-3 px-4 text-gray-400 text-sm">{{ user.createdAt|date('M d, Y') }}</td>
                                    <td class="py-3 px-4">
                                        <div class="flex gap-2">
                                            <a href="{{ path('app_user_show', {'id': user.id}) }}" class="px-3 py-1.5 text-sm font-medium text-emerald-400 bg-emerald-900/20 rounded-lg hover:bg-emerald-900/40 transition-all duration-200">
                                                View
                                            </a>
                                            <a href="{{ path('app_user_edit', {'id': user.id}) }}" class="px-3 py-1.5 text-sm font-medium text-blue-400 bg-blue-900/20 rounded-lg hover:bg-blue-900/40 transition-all duration-200">
                                                Edit
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        {% endif %}
    </div>
</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    
    <script>
        if (typeof window.userTableInitialized === 'undefined') {
            window.userTableInitialized = false;
        }
        
        document.addEventListener('DOMContentLoaded', function() {
            const customFilters = document.getElementById('customFilters');
            const gridView = document.getElementById('grid-view');
            const tableView = document.getElementById('table-view');
            
            // View toggle functionality
            document.querySelectorAll('.toggle-btn').forEach(btn => {
                btn.addEventListener('click', function() {
                    document.querySelectorAll('.toggle-btn').forEach(b => {
                        b.classList.remove('active', 'bg-yellow-500', 'text-black');
                        b.classList.add('bg-gray-800', 'text-gray-300');
                    });
                    this.classList.add('active', 'bg-yellow-500', 'text-black');
                    this.classList.remove('bg-gray-800', 'text-gray-300');
                    
                    const view = this.dataset.view;
                    if (view === 'grid') {
                        gridView.style.display = 'block';
                        tableView.style.display = 'none';
                        customFilters.style.display = 'block';
                    } else {
                        gridView.style.display = 'none';
                        tableView.style.display = 'block';
                        customFilters.style.display = 'none';
                        
                        if (!window.userTableInitialized && $('#userTable').length) {
                            window.userTable = $('#userTable').DataTable({
                                paging: true,
                                pageLength: 10,
                                lengthMenu: [[5, 10, 25, 50, 100], [5, 10, 25, 50, 100]],
                                searching: true,
                                ordering: true,
                                order: [[0, 'desc']],
                                autoWidth: false,
                                language: {
                                    search: "Search:",
                                    lengthMenu: "Show _MENU_ entries",
                                    info: "Showing _START_ to _END_ of _TOTAL_ users",
                                    infoEmpty: "Showing 0 to 0 of 0 users",
                                    infoFiltered: "(filtered from _MAX_ total users)",
                                    zeroRecords: "No matching users found",
                                    paginate: {
                                        first: "First",
                                        last: "Last",
                                        next: "Next",
                                        previous: "Previous"
                                    }
                                },
                                drawCallback: function() {
                                    $('.paginate_button').addClass('px-3 py-1.5 mx-1 rounded-lg bg-gray-800 text-gray-300 hover:bg-yellow-500 hover:text-black transition-all duration-200');
                                    $('.paginate_button.current').removeClass('bg-gray-800').addClass('bg-yellow-500 text-black');
                                },
                                initComplete: function() {
                                    window.userTableInitialized = true;
                                    $('.dataTables_filter input').addClass('px-4 py-2.5 bg-gray-800/50 border border-gray-700 rounded-xl text-white focus:outline-none focus:ring-2 focus:ring-yellow-500');
                                    $('.dataTables_length select').addClass('px-2 py-1.5 bg-gray-800 border border-gray-700 rounded-lg text-white');
                                    $('.dataTables_length label, .dataTables_filter label, .dataTables_info').addClass('text-gray-300');
                                    $('.dataTables_wrapper').addClass('p-4');
                                }
                            });
                        }
                    }
                });
            });
            
            // Filter functionality for grid view
            function filterUsers() {
                const nameFilter = document.getElementById('searchName').value.toLowerCase();
                const emailFilter = document.getElementById('searchEmail').value.toLowerCase();
                const roleFilter = document.getElementById('filterRole').value.toLowerCase();
                const statusFilter = document.getElementById('filterStatus').value.toLowerCase();
                
                const cards = document.querySelectorAll('.user-card');
                const noResults = document.getElementById('noResults');
                const usersGrid = document.getElementById('usersGrid');
                let visibleCount = 0;
                
                cards.forEach(card => {
                    const name = card.dataset.name;
                    const email = card.dataset.email;
                    const roles = card.dataset.roles;
                    const status = card.dataset.status;
                    
                    const matchesName = nameFilter === '' || name.includes(nameFilter);
                    const matchesEmail = emailFilter === '' || email.includes(emailFilter);
                    const matchesRole = roleFilter === '' || roles.includes(roleFilter);
                    const matchesStatus = statusFilter === '' || status.includes(statusFilter);
                    
                    if (matchesName && matchesEmail && matchesRole && matchesStatus) {
                        card.style.display = 'block';
                        visibleCount++;
                    } else {
                        card.style.display = 'none';
                    }
                });
                
                if (noResults && usersGrid) {
                    if (visibleCount === 0 && cards.length > 0) {
                        noResults.classList.remove('hidden');
                        usersGrid.classList.add('hidden');
                    } else {
                        noResults.classList.add('hidden');
                        usersGrid.classList.remove('hidden');
                    }
                }
            }
            
            document.getElementById('searchName').addEventListener('input', filterUsers);
            document.getElementById('searchEmail').addEventListener('input', filterUsers);
            document.getElementById('filterRole').addEventListener('change', filterUsers);
            document.getElementById('filterStatus').addEventListener('change', filterUsers);
            
            document.getElementById('resetFilters').addEventListener('click', function() {
                document.getElementById('searchName').value = '';
                document.getElementById('searchEmail').value = '';
                document.getElementById('filterRole').value = '';
                document.getElementById('filterStatus').value = '';
                filterUsers();
                
                if (window.userTable) {
                    window.userTable.search('').columns().search('').draw();
                }
            });
            
            filterUsers();
        });
