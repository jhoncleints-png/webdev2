{% extends 'layout.html.twig' %}

{% block title %}New User - Samaco Brewery{% endblock %}

{% block dashboard_content %}
<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
    
    <!-- Page Header -->
    <div class="mb-8">
        <!-- Breadcrumb -->
        <nav class="flex items-center gap-2 text-sm text-gray-400 mb-6">
            <a href="{{ path('app_dashboard_home') }}" 
               class="hover:text-yellow-400 transition-colors duration-200">
                Dashboard
            </a>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
            </svg>
            <a href="{{ path('app_user_index') }}" 
               class="hover:text-yellow-400 transition-colors duration-200">
                Users
            </a>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
            </svg>
            <span class="text-yellow-400 font-medium">New User</span>
        </nav>
        
        <!-- Main Heading -->
        <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
            <div>
                <h1 class="text-3xl md:text-4xl font-bold text-white mb-2 flex items-center gap-3">
                    <svg class="w-8 h-8 text-yellow-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" 
                              d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z"></path>
                    </svg>
                    Create New User
                </h1>
                <p class="text-gray-400 ml-11">
                    Add a new user account to your brewery system
                </p>
            </div>
            
            <!-- Back Button -->
            <a href="{{ path('app_user_index') }}"
               class="inline-flex items-center gap-2 px-5 py-3 text-sm font-semibold text-gray-300 
                      bg-gray-800/50 rounded-xl hover:bg-gray-800 hover:text-white transition-all duration-200
                      border border-gray-700/50 focus:outline-none focus:ring-2 focus:ring-gray-500 focus:ring-offset-2 focus:ring-offset-gray-900
                      self-start sm:self-center">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
                </svg>
                Back to Users
            </a>
        </div>
    </div>

    <!-- Form Section -->
    <div class="bg-gray-900/50 backdrop-blur-sm rounded-2xl border border-gray-700/50 shadow-xl p-6 md:p-8">
        <div class="mb-8">
            <h2 class="text-2xl font-bold text-yellow-400 mb-2 flex items-center gap-3">
                <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" 
                          d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
                </svg>
                User Account Details
            </h2>
            <p class="text-gray-400">Fill in the details to create a new user account</p>
        </div>
        
        <!-- Include Form -->
        <div class="max-w-4xl mx-auto">
            {{ include('user/_form.html.twig') }}
        </div>
    </div>

    <!-- Role Information Section -->
    <div class="mt-8 bg-purple-900/10 backdrop-blur-sm rounded-2xl border border-purple-800/30 shadow-xl p-6 md:p-8">
        <div class="mb-6">
            <h2 class="text-xl font-bold text-purple-300 mb-2 flex items-center gap-3">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" 
                          d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
                </svg>
                Role Permissions Guide
            </h2>
            <p class="text-gray-400">Understanding different user roles and their capabilities</p>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <!-- Standard User Card -->
            <div class="bg-gray-800/30 rounded-xl p-6 border border-gray-700/50 hover:border-yellow-800/50 transition-colors duration-200">
                <div class="flex items-center gap-3 mb-4">
                    <div class="p-2 rounded-lg bg-yellow-900/20 border border-yellow-800/30">
                        <svg class="w-5 h-5 text-yellow-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" 
                                  d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path>
                        </svg>
                    </div>
                    <h3 class="text-lg font-semibold text-white">Standard User (ROLE_USER)</h3>
                </div>
                <ul class="space-y-3">
                    <li class="flex items-start gap-2 text-sm text-gray-300">
                        <svg class="w-4 h-4 text-green-400 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                        </svg>
                        <span>Basic dashboard access</span>
                    </li>
                    <li class="flex items-start gap-2 text-sm text-gray-300">
                        <svg class="w-4 h-4 text-green-400 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                        </svg>
                        <span>View product catalog</span>
                    </li>
                    <li class="flex items-start gap-2 text-sm text-gray-300">
                        <svg class="w-4 h-4 text-green-400 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                        </svg>
                        <span>Basic reporting access</span>
                    </li>
                    <li class="flex items-start gap-2 text-sm text-gray-400">
                        <svg class="w-4 h-4 text-red-400 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                        </svg>
                        <span>No user management</span>
                    </li>
                    <li class="flex items-start gap-2 text-sm text-gray-400">
                        <svg class="w-4 h-4 text-red-400 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                        </svg>
                        <span>No product editing</span>
                    </li>
                </ul>
                <div class="mt-4 pt-4 border-t border-gray-700/50">
                    <span class="text-xs text-gray-500">Recommended for: Staff members, basic access</span>
                </div>
            </div>

            <!-- Administrator Card -->
            <div class="bg-gray-800/30 rounded-xl p-6 border border-gray-700/50 hover:border-purple-800/50 transition-colors duration-200">
                <div class="flex items-center gap-3 mb-4">
                    <div class="p-2 rounded-lg bg-purple-900/20 border border-purple-800/30">
                        <svg class="w-5 h-5 text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" 
                                  d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path>
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                        </svg>
                    </div>
                    <h3 class="text-lg font-semibold text-white">Administrator (ROLE_ADMIN)</h3>
                </div>
                <ul class="space-y-3">
                    <li class="flex items-start gap-2 text-sm text-gray-300">
                        <svg class="w-4 h-4 text-green-400 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                        </svg>
                        <span>Full system access</span>
                    </li>
                    <li class="flex items-start gap-2 text-sm text-gray-300">
                        <svg class="w-4 h-4 text-green-400 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                        </svg>
                        <span>User management</span>
                    </li>
                    <li class="flex items-start gap-2 text-sm text-gray-300">
                        <svg class="w-4 h-4 text-green-400 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                        </svg>
                        <span>Product editing & creation</span>
                    </li>
                    <li class="flex items-start gap-2 text-sm text-gray-300">
                        <svg class="w-4 h-4 text-green-400 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                        </svg>
                        <span>Advanced reporting</span>
                    </li>
                    <li class="flex items-start gap-2 text-sm text-gray-300">
                        <svg class="w-4 h-4 text-green-400 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                        </svg>
                        <span>System configuration</span>
                    </li>
                </ul>
                <div class="mt-4 pt-4 border-t border-gray-700/50">
                    <span class="text-xs text-gray-500">Recommended for: Managers, system administrators</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Security Tips Section -->
    <div class="mt-8 bg-blue-900/10 backdrop-blur-sm rounded-2xl border border-blue-800/30 shadow-xl p-6 md:p-8">
        <div class="flex items-start gap-4">
            <svg class="w-6 h-6 text-blue-400 mt-1 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" 
                      d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
            </svg>
            <div>
                <h3 class="text-lg font-semibold text-blue-300 mb-3">Security Best Practices</h3>
                <ul class="text-gray-400 space-y-2 text-sm">
                    <li class="flex items-start gap-2">
                        <span class="text-blue-400">•</span>
                        <span>Use strong passwords with a mix of uppercase, lowercase, numbers, and symbols</span>
                    </li>
                    <li class="flex items-start gap-2">
                        <span class="text-blue-400">•</span>
                        <span>Assign roles based on the principle of least privilege - give only necessary permissions</span>
                    </li>
                    <li class="flex items-start gap-2">
                        <span class="text-blue-400">•</span>
                        <span>Use unique email addresses for each user account</span>
                    </li>
                    <li class="flex items-start gap-2">
                        <span class="text-blue-400">•</span>
                        <span>Regularly review and update user permissions as roles change</span>
                    </li>
                    <li class="flex items-start gap-2">
                        <span class="text-blue-400">•</span>
                        <span>Consider implementing two-factor authentication for administrative accounts</span>
                    </li>
                </ul>
            </div>
        </div>
    </div>

</div>
{% endblock %}